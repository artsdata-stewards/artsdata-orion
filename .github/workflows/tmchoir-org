name: Fetch tmchoir-org Events

on:
  workflow_dispatch:
  schedule:
    - cron: '25 7 * * 5'
    
jobs:
  artsdata-fetch-and-push:
    runs-on: ubuntu-latest
    steps:
      - name: Action setup
        uses: culturecreates/artsdata-pipeline-action@v4
        with:
          mode: "fetch-push"
          artifact: "tmchoir-org"
          publisher: "${{ vars.CAPACOA_BOT }}"
          page-url: "https://www.tmchoir.org/"
          token: "${{ secrets.GITHUB_TOKEN }}"
          cloudflare-private-key: ${{ secrets.CLOUDFLARE_PRIVATE_KEY }}
