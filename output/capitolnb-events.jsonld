  {
    "@id": "https://capitol.nb.ca/#972_2027-03-09T19:00:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/one-fell-swoop-circus"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
