      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-09"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/one-fell-swoop-circus"
      }
    ],
    "http://schema.org/location": [
      {
