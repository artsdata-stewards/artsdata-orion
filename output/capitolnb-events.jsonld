  {
    "@id": "https://capitol.nb.ca/#1033_2026-10-22T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/jimmy-rankin"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
