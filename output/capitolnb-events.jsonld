  {
    "@id": "https://capitol.nb.ca/#978_2027-04-10T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/patrice-lecuyer"
