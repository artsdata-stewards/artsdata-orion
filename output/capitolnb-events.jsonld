  {
    "@id": "https://capitol.nb.ca/#961_2026-10-18T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/relive-the-music-50s-60s-70s-show"
