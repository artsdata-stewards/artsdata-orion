    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Bringing Back Broadway"
      },
      {
        "@language": "fr",
        "@value": "Bringing Back Broadway"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "en",
        "@value": ""
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Hazy Grape Theatre presents a stellar evening of beautiful Broadway song and dance to entertain all of Moncton and to raise awareness of the need for living organ donation.\r\nTwo acts of amazing voices and glamorous costumes guarantee to enchant audiences, as some of the best in Broadway comedy, romance and drama is presented live by a cast of phenomenal local talents.\r\nLOVE Broadway? Then this show is for you! "
      },
      {
        "@language": "fr",
        "@value": "Le Hazy Grape Theatre présente une soirée exceptionnelle de chansons et de danses de Broadway pour divertir tous les habitants de Moncton et pour sensibiliser la population au besoin de dons d'organes de son vivant.\r\nUn spectacle en deux actes qui propose des voix étonnantes et des costumes glamour qui enchanteront le public, alors que certaines des meilleures chansons comiques, romantiques et dramatiques de Broadway sont présentées en direct par une distribution de talents locaux phénoménaux.\r\nVous aimez Broadway? Ce spectacle est pour vous! "
      }
    ],
    "http://schema.org/eventAttendanceMode": [
