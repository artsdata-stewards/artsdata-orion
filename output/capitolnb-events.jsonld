    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Trent McClellan, stand-up veteran, star of This Hour Has 22 Minutes, N.I.C.E Agent, and host of the Halifax Comedy Fest, is touring Canada with The Be Nice Tour, a brand new hour of material. Fresh off the success of last year’s special Worry Muffins, Trent returns with new stories, sharp observations, and the signature warmth that has made him one of the country’s most beloved comedians. "
      },
      {
        "@language": "fr",
        "@value": "Trent McClellan, vétéran du stand-up, vedette de This Hour Has 22 Minutes et de N.I.C.E Agent, et animateur du Halifax Comedy Fest, part en tournée à travers le Canada avec The Be Nice Tour, un tout nouveau spectacle d’une heure. Fort du succès de son spectacle spécial de l’année dernière, Worry Muffins, Trent revient avec de nouvelles anecdotes, des observations acérées et cette chaleur caractéristique qui a fait de lui l’un des humoristes les plus appréciés du pays. "
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
