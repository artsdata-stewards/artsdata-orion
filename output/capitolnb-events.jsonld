  {
    "@id": "https://capitol.nb.ca/#800_2026-09-26T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/james-mullinger-2026"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
