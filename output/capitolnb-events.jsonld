  {
    "@id": "https://capitol.nb.ca/#979_2027-04-13T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/kathleen-edwards"
