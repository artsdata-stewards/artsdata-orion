    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Noël avec Les Muses, les frères Belivo & Roland Gauvin"
      },
      {
        "@language": "fr",
        "@value": "Noël avec Les Muses, les frères Belivo & Roland Gauvin"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "en",
        "@value": ""
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "For 25 years, the “Noël avec les Muses, les Frères Belivo et Roland Gauvin” show has been one of Acadie's must-see holiday traditions.\r\nA few songs and you'll feel like you're part of a big family!\r\nBe part of the tradition in 2026. Les Jeunes chanteurs d'Acadie, François Emond, Jean-Pascal Comeau and Denis Hachey will also be performing. And, weather permitting, Santa Claus will be along for the ride… another must-see tradition!*Performance in French. "
      },
      {
        "@language": "fr",
        "@value": "Depuis 25 ans, le spectacle Noël avec les Muses, les Frères Belivo et Roland Gauvin fait partie des traditions incontournables du temps des fêtes en Acadie.\r\nLe temps de quelques chansons et on a l’impression de faire partie de la même grande famille!\r\nFaites partie de la tradition en 2026. Les Jeunes chanteurs d’Acadie, François Emond, Jean-Pascal Comeau et Denis Hachey seront aussi fidèles au rendez-vous. Et si la météo le permet, Père Noël viendra faire un p’tit tour…une tradition ça aussi! "
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
