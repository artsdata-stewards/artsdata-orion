  {
    "@id": "https://capitol.nb.ca/#861_2026-05-24T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/barra-macneils-2026"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
