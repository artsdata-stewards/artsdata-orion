  {
    "@id": "https://capitol.nb.ca/#807_2026-10-03T19:00:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/jimmy-moore-drag"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-03T19:00:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-03"
      }
    ],
    "http://schema.org/sameAs": [
