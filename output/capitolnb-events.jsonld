    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Originaire de Halifax, Wintersleep a tranquillement redessiné les contours du rock moderne depuis sa création en 2001. Ancré par le baryton évocateur du leader Paul Murphy, par la batterie hypnotique et propulsive de Loel Campbell et par le travail chatoyant de Tim D'Eon à la guitare et au piano, ..."
      },
