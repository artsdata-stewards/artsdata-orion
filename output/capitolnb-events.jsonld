    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/tutta-musica-orchestra-presents-queens-of-the-stage"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Tutta Musica Orchestra Presents: Queens of the Stage"
      },
      {
        "@language": "fr",
        "@value": "Tutta Musica Orchestra Presents: Queens of the Stage"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "en",
        "@value": ""
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Originally scheduled for November 23, 2025. Please note the time change. Tickets showing the original date and time will be accepted at the door.\r\n&nbsp;\r\nBroadway meets Rock in a Royal Showdown\r\nTwo powerhouse performers, each reigning over her own musical kingdom, come together for one unforgettable afternoon at the Capitol Theatre.Josée Boudreau&nbsp;– Broadway’s dazzling queenIzabelle Ouellet&nbsp;– Rock’s electrifying empressBacked by the&nbsp;Tutta Musica Orchestra, these divas prove that no matter the genre, true queens command the stage. From iconic show tunes to legendary rock anthems, expect a coronation of music filled with drama, glamour, and a finale where Broadway and Rock unite in one unforgettable crown jewel performance. "
      },
      {
        "@language": "fr",
        "@value": "Initialement prévu pour le 23 novembre 2025. Veuillez prendre note du changement d'heure. Les billets indiquant la date et l'heure originale seront acceptés à la porte.\r\n&nbsp;\r\nBroadway rencontre le rock dans un face-à-face royalDeux artistes puissantes, chacune régnant sur son propre royaume musical, se réunissent pour un après-midi inoubliable au Théâtre Capitol.Josée Boudreau&nbsp;– La reine éblouissante de BroadwayIzabelle Ouellet&nbsp;– L'impératrice électrisante du rockAccompagnées par l'orchestre Tutta Musica, ces divas prouvent que, quel que soit le genre musical, les vraies reines dominent la scène. Des airs de comédies musicales emblématiques aux hymnes rock légendaires, attendez-vous à un couronnement musical rempli de drame, de&nbsp;glamour&nbsp;et à une grande finale où Broadway et le rock s'unissent dans une performance inoubliable!\r\n&nbsp; "
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventRescheduled"
      }
    ]
  },
