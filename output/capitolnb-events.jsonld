  {
    "@id": "https://capitol.nb.ca/en/tickets-events/trent-mcclellans-be-nice-tour",
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Trent McClellan's Be Nice Tour"
