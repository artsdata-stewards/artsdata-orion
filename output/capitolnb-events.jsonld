  {
    "@id": "https://capitol.nb.ca/#646_2026-06-09T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/epidermis-circus"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
