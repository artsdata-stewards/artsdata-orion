  {
    "@id": "https://capitol.nb.ca/#859_2026-10-13T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/loreena-mckennitt"
      }
    ],
    "http://schema.org/startDate": [
      {
