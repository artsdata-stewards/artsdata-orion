  {
    "@id": "https://capitol.nb.ca/#958_2027-01-26T19:00:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/yamato-the-drummers-of-japan"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-26T19:00:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-26"
      }
    ],
    "http://schema.org/sameAs": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/yamato-the-drummers-of-japan"
      }
    ],
    "http://schema.org/location": [
      {
