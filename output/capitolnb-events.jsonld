  {
    "@id": "https://capitol.nb.ca/#986_2027-05-22T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/jean-michel-blais"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
