  {
    "@id": "https://capitol.nb.ca/en/tickets-events/philippe-bond",
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Philippe Bond"
      },
      {
        "@language": "en-ca",
        "@value": "Philippe Bond - Capitol Theatre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "\"In this 4th one-man-show, I'm back with new anecdotes and plenty of food for thought. They say that what doesn't kill you makes you stronger. That's why I'm so excited to be back with you and to present my brand-new show: Rebondir.\" *Performance in French."
      },
