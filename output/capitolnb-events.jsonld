    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "en",
        "@value": ""
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Time Warp Promotions Presents\r\nPIANO MAN – A Tribute to Billy Joel is a high-energy live theatre tribute celebrating the songs that made Billy Joel an icon.\r\nFronted by Jeff Brewer on vocals and piano, the show delivers outstanding musicianship, strong audience connection, and the kind of pacing that keeps the room engaged from start to finish. With over 20 years of experience entertaining audiences across Canada, the United States, and Mexico, Brewer brings the hits to life with authenticity, charisma, and real concert energy — from intimate Piano Man moments to full-tilt singalongs.\r\nA must-see night out for Billy Joel fans… and the perfect show to create new ones. "
      },
      {
        "@language": "fr",
        "@value": "Time Warp Promotions Presents\r\nPIANO MAN – A Tribute to Billy Joel est un spectacle théâtral haut en énergie qui rend hommage aux chansons qui ont fait de Billy Joel une icône.\r\nMené par Jeff Brewer à la voix et au piano, le spectacle offre une musicalité exceptionnelle, une forte connexion avec le public et un rythme qui captive l'auditoire du début à la fin. Fort de plus de 20 ans d'expérience dans le divertissement du public au Canada, aux États-Unis et au Mexique, Brewer donne vie aux chansons avec authenticité, charisme et une véritable énergie de concert, des moments intimes de Piano Man aux chansons à chanter en chœur.\r\nUne soirée incontournable pour les fans de Billy Joel... et le spectacle idéal pour en créer de nouveaux. "
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
