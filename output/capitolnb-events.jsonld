  {
    "@id": "https://capitol.nb.ca/fr/spectacles-et-billets/philippe-bond",
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Philippe Bond"
      },
      {
        "@language": "fr-ca",
        "@value": "Philippe Bond - Théâtre Capitol"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "« Dans ce 4e one-man-show, je vous reviens avec de nouvelles anecdotes et de nombreuses réflexions. On dit que ce qui ne nous tue pas nous rend plus fort. C'est pourquoi je suis fébrile à l'idée de vous retrouver et de vous présenter mon tout nouveau spectacle : Rebondir. »"
      },
