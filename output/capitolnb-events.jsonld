      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://capitol.nb.ca/images/stories/flexicontent/item_988_field_41/original/pierre-hebert-intro.jpg"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://capitol.nb.ca/genid/4d495190631b7f1f"
