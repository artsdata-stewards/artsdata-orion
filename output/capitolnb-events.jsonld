  {
    "@id": "https://capitol.nb.ca/#980_2027-04-14T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/hey-viola"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-14T19:30:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-14"
      }
    ],
    "http://schema.org/sameAs": [
      {
