    "http://schema.org/organizer": [
      {
        "@id": "_:g580300"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/bringing-back-broadway-2026"
