  {
    "@id": "https://capitol.nb.ca/#977_2027-04-02T19:30:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://capitol.nb.ca/en/tickets-events/aquakultre-1783-live"
