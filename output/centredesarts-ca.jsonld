    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "À travers son nouveau spectacle, l'humoriste Maude Landry vous invite dans un périple au cœur de ses réflexions, ses doutes et ses déboires, pour que vous sortiez de la salle en disant « C’était trop cool! »"
      }
