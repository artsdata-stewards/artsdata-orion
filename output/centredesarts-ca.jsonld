    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Pour son troisième one-man-show intitulé « Naturel », l'humoriste Jérémy Demay réussit à la fois à faire rire à gorge déployée et à toucher droit au cœur, tout ça pour le grand plaisir de tous!"
      }
    ],
