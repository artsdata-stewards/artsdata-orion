    "http://schema.org/name": [
      {
        "@value": "Curtain Call Academy with Lincoln Inglis JR"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Now in its fifth year, Lincoln puts his spin on the decades-long Astor Theatre Camp tradition. In this one-of-a-kind program, Lincoln will explore campers’ creativity by developing an original play from start to finish, learning plenty of theatre skills along the way! This year, Lincoln is bringing this fun and exciting camp to 7-13-year-olds.&lt;/p&gt;\\n"
      }
    ],
