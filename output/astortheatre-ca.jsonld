    "http://schema.org/name": [
      {
        "@value": "The Once"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;A modern indie folk trio from Newfoundland, The Once have collected a trio of Canadian Folk Music Awards, numerous ECMA awards, and was named Artist of the Year by the Newfoundland &amp; Labrador Arts Council. They have earned not one, but two JUNO nominations for Roots Album of the Year and continue to take their music around the world.&lt;/p&gt;\\n"
      }
    ],
