    "http://schema.org/name": [
      {
        "@value": "The Devil Wears Prada 2"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Twenty years after making their iconic turns as Miranda, Andy, Emily and Nigel—Meryl Streep, Anne Hathaway, Emily Blunt and Stanley Tucci return to the fashionable streets of New York City and the sleek offices of Runway Magazine in 20th Century Studios’ “The Devil Wears Prada 2,” the eagerly awaited sequel to the 2006 phenomenon that defined a generation.&lt;/p&gt;\\n"
      }
    ],
