    "http://schema.org/name": [
      {
        "@value": "Met Tuesdays: The National Theatre Live : The Audience"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;For 60 years, Queen Elizabeth II met with each of her 12 prime ministers in a private weekly meeting. This meeting is known as The Audience. From Winston Churchill to Margaret Thatcher and David Cameron, the Queen advised her prime ministers on matters both public and personal. Through these private audiences, we see glimpses of the woman behind the crown and witness the moments that shaped a monarch.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@value": "Organization"
      }
    ],
