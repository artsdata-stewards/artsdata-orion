    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;TULUA are a young traditional Irish band hailing from the southeast of Ireland. Meaning &quot;tribe of many paths&quot; TULUA have been deeply exploring and sharing music of their local area and other parts of Ireland, bringing the audience with them on a captivating journey of songs about love, tunes about life and everything in between.&lt;/p&gt;\\n"
      }
