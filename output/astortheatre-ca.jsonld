      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;On Sunday, June 28th, our Spotlight Guild will be performing their original production &quot;The Pirate\\'s Tempest.&quot;   An exiled Pirate King uses his magic to conjure a storm to complete his ultimate revenge.  Our take on Shakespeare\\'s The Tempest brings a pirate\\'s tale full of betrayal,  love, revenge and a few laughs along the way. &lt;/p&gt;\\n"
      }
    ],
