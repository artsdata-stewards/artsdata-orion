    "http://schema.org/name": [
      {
        "@value": "At the Place of Ghosts"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;At the Place of Ghosts  is a 2025 supernatural thriller film written and directed by Bretten Hannam. The film stars Forrest Goodluck and Blake Alec Miranda as Mise\\'l and Antle, two Mi\\'kmaq brothers who have become estranged in adulthood due to childhood trauma, who become haunted by a malevolent spirit and must reunite and journey into Sk+te\\'kmujue\\'katik, the Place of Ghosts, to face their demons and heal.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@value": "Organization"
      }
    ],
