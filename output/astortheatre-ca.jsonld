    "http://schema.org/name": [
      {
        "@value": "Curtain Call Academy with Lincoln Inglis"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Now in its fifth year, Lincoln puts his spin on the decades-long Astor Theatre Camp tradition. In this one-of-a-kind program, Lincoln will explore campers’ creativity by developing an original play from start to finish, learning plenty of theatre skills along the way!&lt;/p&gt;\\n"
      }
    ],
