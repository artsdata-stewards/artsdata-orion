        "@value": "Radio Theatre Camp"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;The Astor Academy Radio Theatre Camp allows campers aged 8–17 to learn to create audio-driven dramas, with a focus on voice acting, sound effects, scriptwriting, and audio editing. In this camp, we will record, polish, and perform a radio play on a community radio station.&lt;/p&gt;\\n"
      }
