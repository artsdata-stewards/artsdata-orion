      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;&quot;The Coldplay Show&quot; is the most authentic tribute, bringing the closest sonic and visual performance experience imaginable, featuring the biggest hits of all-time that include: Clocks, Scientist, Adventure of a Lifetime, Sky Full of Stars, Yellow, Paradise, Fix You, Something Just Like This, My Universe, Higher Power, Trouble and other recognizable chart-toppers.&lt;/p&gt;\\n"
      }
