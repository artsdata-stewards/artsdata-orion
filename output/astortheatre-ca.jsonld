    "http://schema.org/name": [
      {
        "@value": "Milton Canoe and Camera Club Art Exhibition"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Come view Milton Canoe and Camera Club\\'s Art Exhibition in our Lower Gallery from August 6 to September 25, 2026.&lt;/p&gt;\\n&lt;p&gt;The opening reception for this show will be held on Thursday, August 6, 2026 at 6:30 pm.  This is your first opportunity to view this beautiful show and meet the artists.&lt;/p&gt;\\n&lt;p&gt;Established in 1949, the Milton Canoe and Camera Club has been inspiring photographers throughout Milton and Queens County for decades. This exhibition showcases the creativity, curiosity, and unique perspectives of club members as they capture moments from the world around them.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@value": "Organization"
      }
