    ],
    "http://schema.org/name": [
      {
        "@value": "Scary Movie 6"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Twenty-six years after outrunning a suspiciously familiar masked killer (“Ghostface”), the Core Four are back in the killer’s crosshairs and no horror movie IP is safe. Marlon Wayans (“Shorty”), Shawn Wayans (“Ray”), Anna Faris (“Cindy”), and Regina Hall (“Brenda”) reunite in Scary Movie alongside returning favorites and fresh faces to slash through reboots, remakes, requels, prequels, sequels, spin-offs, elevated horror, origin stories, anything with the word legacy in it, and every “final chapter” that absolutely isn’t final. Nothing is sacred. No trope survives. Every line gets crossed. The Wayans are back to cancel the Cancel Culture.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@value": "Organization"
      }
    ],
