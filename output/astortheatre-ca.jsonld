    ],
    "http://schema.org/name": [
      {
        "@value": "Directors Cut : From Script to Screen Movie Camp"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Returning for the third year, this week-long afternoon camp allows children to find out all about what goes on behind the camera. Budding filmmaker and long-time Astor Theatre friend, Easton Goodwin, will work in a group to formulate an idea, create a script and storyboard, and then film your masterpiece! The week will finish with watching your movie on the big screen (complete with the famous Astor popcorn!)&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@value": "Organization"
      }
    ],
