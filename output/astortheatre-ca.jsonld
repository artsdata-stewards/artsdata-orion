    "http://schema.org/name": [
      {
        "@value": "Off the Rock &#8211; Great Big Sea Tribute"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;An incredible high-energy show that features the greatest hits of Great Big Sea and a few select traditional east coast classics. “Off The Rock” delivers an interactive and engaging show that keep audiences talking for days, weeks and sometimes months after the event, leaving lasting memories of good times, great music, and tons of fun out on the town!&lt;/p&gt;\\n"
      }
    ],
