    "http://schema.org/name": [
      {
        "@value": "Shark Week: Jaws: 50th (ish) Anniversary"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;When a gigantic great white shark begins to menace the small island community of Amity, a police chief, a marine scientist and grizzled fisherman set out to stop it. Jaws is considered one of the greatest films of all time and often credited as being the first summer blockbuster. Steven Spielberg\\'s breakthrough movie, it solidified his relationship with Universal, won three Academy Awards®, spawned three sequels, two video games, two musicals, two theme park rides and ranks as one of the top-grossing films in Universal history.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@value": "Organization"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
