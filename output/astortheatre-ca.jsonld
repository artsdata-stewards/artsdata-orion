    ],
    "http://schema.org/name": [
      {
        "@value": "Care for All &#8211; North American Premiere"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;Experience the North American premiere of Care for All, an acclaimed new Welsh musical that tells the inspiring story of the people who believed healthcare should be available to everyone.&lt;/p&gt;\\n&lt;p&gt;Featuring powerful original music and compelling storytelling, Care for All explores themes of compassion, community, sacrifice, and hope that continue to resonate today.&lt;/p&gt;\\n"
      }
    ],
