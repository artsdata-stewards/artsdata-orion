    "http://schema.org/name": [
      {
        "@value": "&#8220;Hello Again&#8221; featuring the music of Neil Diamond with Sean Andrews"
      }
    ],
    "http://schema.org/description": [
      {
        "@value": "&lt;p&gt;A life story told through the music of Neil Diamond&lt;br /&gt;\\nBoardwalk Productions is excited to bring Sean Andrews in &quot;Hello Again&quot; featuring the music of Neil Diamond, to the Astor Theatre for an unforgettable evening of story, song, and nostalgia. This powerful musical experience has played to sold-out audiences, earning standing ovations and glowing reviews wherever it appears.&lt;/p&gt;\\n"
      }
    ],
