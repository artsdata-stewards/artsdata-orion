  {
    "@id": "https://artspring.ca/temporary/de13ee15-3402-4ee2-ba5c-70da74118e9b",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/hiromoto-ida-vacant-lot/"
