  {
    "@id": "https://artspring.ca/temporary/b577e80b-da62-4127-bbb3-56cd73f3fddd",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
