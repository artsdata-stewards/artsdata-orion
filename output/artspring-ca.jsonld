  {
    "@id": "https://artspring.ca/temporary/a76ad96d-ce3c-4191-a219-4e7a6ddd3680",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
