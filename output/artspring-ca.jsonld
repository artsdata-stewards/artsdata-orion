  {
    "@id": "https://artspring.ca/temporary/49b94d03-6b78-4abc-83c3-af368b00504a",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/william-shakespeares-as-you-like-it-a-radical-retelling-by-cliff-cardinal/"
