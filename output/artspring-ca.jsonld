  {
    "@id": "https://artspring.ca/temporary/d62a8b1a-8d84-44f0-8f36-310503f3e43a",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/my-sense-of-sing-meta-folk-sensation-illiteratty-jams-with-viva-chorale/2024-11-16/"
