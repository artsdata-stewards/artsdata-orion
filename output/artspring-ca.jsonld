  {
    "@id": "https://artspring.ca/temporary/594f920a-0994-48fa-a2e1-9b2091ca0886",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
