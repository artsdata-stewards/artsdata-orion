  {
    "@id": "https://artspring.ca/temporary/0b999f50-04db-4485-9fba-cb17cd435bb5",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
