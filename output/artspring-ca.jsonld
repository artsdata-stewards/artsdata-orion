  {
    "@id": "https://artspring.ca/temporary/33556837-3285-41a0-b225-aff101bec58b",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/makana-youth-choirs-fall-term/"
