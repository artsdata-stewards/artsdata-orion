  {
    "@id": "https://artspring.ca/temporary/c91807c6-8fb1-4693-8859-ffd990d8b89f",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/hearafter-a-cabaret-of-divine-love/2025-06-28/"
