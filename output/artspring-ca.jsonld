  {
    "@id": "https://artspring.ca/temporary/48eda84e-f106-4c7e-bc0c-58642174d1b2",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/tom-keenlyside-quartet-a-night-of-dave-brubeck/"
