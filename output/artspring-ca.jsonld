  {
    "@id": "https://artspring.ca/temporary/f56a0422-1704-4179-b4bb-85d09871c2e1",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
