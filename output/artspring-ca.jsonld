  {
    "@id": "https://artspring.ca/temporary/d2dd77fc-fb1b-4d6d-a9f9-ae046daa58bd",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
