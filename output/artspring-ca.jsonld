  {
    "@id": "https://artspring.ca/temporary/83aff29d-a60c-4999-a71f-49116e88dc95",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
