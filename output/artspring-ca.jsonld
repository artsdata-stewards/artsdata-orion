  {
    "@id": "https://artspring.ca/temporary/dc8f02a0-7f11-40aa-b3d0-13c9db0e6a20",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
