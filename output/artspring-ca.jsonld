  {
    "@id": "https://artspring.ca/temporary/211cf2ef-d8ae-42af-9176-dca7406e65ac",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/ssi-foundation-40-years-of-giving-celebration-event/"
