  {
    "@id": "https://artspring.ca/temporary/18fe34ea-9c1e-4bcd-a256-0516dfffa935",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
