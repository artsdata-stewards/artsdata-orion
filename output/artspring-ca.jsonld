  {
    "@id": "https://artspring.ca/temporary/c86bf35c-e448-433b-85f3-4903af23ea13",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/lobby-exhibition-seth-berkowitz-presents-open-spaces/"
      }
