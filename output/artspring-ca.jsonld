  {
    "@id": "https://artspring.ca/temporary/fdce7b54-ab0d-4235-8635-512507f252ec",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/masterplants-orchestra-concert-western-canada-tour/"
      }
