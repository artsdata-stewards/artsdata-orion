  {
    "@id": "https://artspring.ca/temporary/d95340e4-d26e-49c9-8aa7-303bd72a9b13",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/salt-spring-film-festival-presents-singing-back-the-buffalo/"
      }
