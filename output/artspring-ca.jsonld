  {
    "@id": "https://artspring.ca/temporary/f483bd98-cd28-4b13-a3b8-c670b7d4f233",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
