  {
    "@id": "https://artspring.ca/temporary/4a1cccbc-a514-4592-a881-801e0d4302a3",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/lobby-exhibition-diverse-threads/"
      }
