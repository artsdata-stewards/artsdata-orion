  {
    "@id": "https://artspring.ca/temporary/a2f10bea-7c95-43d5-be0c-89e47180dc1e",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
