  {
    "@id": "https://artspring.ca/temporary/0f06ebcd-94e8-41d8-ba13-31a3b488ce0d",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
