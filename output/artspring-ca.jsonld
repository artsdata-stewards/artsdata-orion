  {
    "@id": "https://artspring.ca/temporary/46c7a055-a3ce-4c38-91b4-ecd0f75c5245",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/remi-bolduc-jazz-ensemble-the-great-masters-of-jazz/"
