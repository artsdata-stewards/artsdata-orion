    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Lobby Exhibition: Indigenous Art Show"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Sweetgrass Arts and Music Society Presents: Indigenous Art Show at ArtSpring Join us at ArtSpring for a vibrant celebration of Indigenous creativity, culture, and community. This special exhibition brings together a diverse mix of Indigenous artists, showcasing works that reflect story, land, tradition, and contemporary expression. Alongside the main show, we are hoping to include [&hellip;]&lt;/p&gt;\\n"
      }
