  {
    "@id": "https://artspring.ca/temporary/13de09a7-552a-4dd7-9512-9a8e93b9bd86",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/charles-richard-hamelin/"
