  {
    "@id": "https://artspring.ca/temporary/45f6e9c8-396a-4262-a89d-50d540585efe",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
