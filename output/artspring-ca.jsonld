  {
    "@id": "https://artspring.ca/temporary/ec326f85-6cc8-423e-80f2-0c5a19a12ee6",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/sweetgrass-arts-music-presents-ss-island-indigenous-art-show-lobby-exhibition/"
