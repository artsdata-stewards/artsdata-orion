  {
    "@id": "https://artspring.ca/temporary/af527222-6bf3-4d8f-9785-e663218537a1",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
