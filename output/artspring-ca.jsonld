        "@value": "Exhibition Opening Event: Undiscovered Country"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;OPENING EVENT: Saturday April 5 | 5pm-7pm In HamletŌĆÖs &quot;To Be or Not To Be&quot; soliloquy he contemplates life and death, using ŌĆ£Undiscovered Country&quot; as a metaphor for the unknown [&hellip;]&lt;/p&gt;\\n"
      }
    ],
