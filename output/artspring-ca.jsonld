  {
    "@id": "https://artspring.ca/temporary/828e0956-db35-4552-997d-81ecfa0ce26c",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/penderecki-string-quartet-2/"
