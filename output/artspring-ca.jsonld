  {
    "@id": "https://artspring.ca/temporary/b05f5dc3-707a-4c78-b3f9-a0f395a32a3d",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/giss-dance-presents-community-dance-performance/"
