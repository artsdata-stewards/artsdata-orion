  {
    "@id": "https://artspring.ca/temporary/a885e037-4922-4b71-b6f4-6d01ec631b77",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
