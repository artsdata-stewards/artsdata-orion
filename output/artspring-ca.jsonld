  {
    "@id": "https://artspring.ca/temporary/9aea8ee0-acd6-4114-955c-f68c0ce6d1fd",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/renew-your-artspring-membership/"
      }
    ],
    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\t\t\t \n\n                 \t\n\n\n\t « All Events\n\n\t\n\tThis event has passed.\n\n\t\t\t\n\t\t\t\n\n\t\t\t\n\n\t\t\t\tRenew Your ArtSpring Membership\n\t\t\t\t\n\t\t\t\t\tAugust 31, 2024\t\t\t\t\t\t\t\t\t\t\t-\n\t\t\t\t\t\t$30 – $50\n\t\t\t\t\t\t\t\t\t\n\n\t\t\t\t\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\tNew membership season is NOW OPEN to purchase or renew your ArtSpring annual membership! Why is membership important? It builds a community of supporters who believe in ArtSpring’s mission and mandate to enrich, uplift, and connect the community through the arts.\nIt gives you a voice and a vote at December’s AGM. AND – it means you’ll be invited to the 2024/25 Launch Event August 29 to get a sneak preview of our most robust ArtSpring Presents season ever.\nRenew by August 31 to get a one-week advance head start on the tickets and seats of your choice, before the season is opened up to the general public.\nMembership runs September 1-August 31.\n$30 for an individual.\n$50 for a couple.\nArtspring.ca/membership\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\n\t\n\n\n\n\t Details \n\t\n\n\t\t\n\t\t\t\n\t\t\t\tDate:\n\t\t\t\t\n\t\t\t\t\t August 31, 2024 \n\t\t\t\t\n\t\t\t\n\n\t\t\n\t\t\n\t\t\n\t\t\t\n\t\t\t\tCost:\n\t\t\t\t $30 – $50 \n\t\t\t\n\t\t\n\t\t\n\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\t\t\tWebsite:\n\t\t\t\t\t\t\t\t Artspring.ca/membership \n\t\t\t\n\t\t\n\t\t\t\n\n\n\n\tOrganizer\n\t\n\t\t\t\t\t\n\t\t\t\tArtSpring\t\t\t\n\t\t\t\t\n\n\n\t\n\n\n\t\t\t\n\t\t\n\n\t Venue \n\t\n\t\t\t\t ArtSpring – Theatre \n\n\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\n\n100 Jackson Avenue\n\t\n\t\t\n\t\tSalt Spring Island,\n\n\tBC\n\n\tV8K 2V8\n\n\tCanada\n\n\n\n\t\t\t\t\t\t\t\t\t\t\t\t\t+ Google Map\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\n\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\tPhone\n\t\t\t\t\t 250.537.2102 \n\t\t\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\n\n\n\n\t\n\n\n\n\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\n\t\n\t\n\n\t\t\t\t\n\t\t\t\t\tAdd to calendar\t\t\t\t\n\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\n\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\n\n\t\n\t\tGoogle Calendar\t\n\n\t\t\t\t\t\t\t\t\t\t\t\n\n\t\n\t\tiCalendar\t\n\n\t\t\t\t\t\t\t\t\t\t\t\n\n\t\n\t\tOutlook 365\t\n\n\t\t\t\t\t\t\t\t\t\t\t\n\n\t\n\t\tOutlook Live\t\n\n\t\t\t\t\t\t\t\t\t\n\t\t\t\n\t\t\n\t\n\n\n\t\t\t\t\n\t\t\t \n\n\t\t\t\n\n\t\t\t\t\t\n\n\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\n\t\n\n\n\n\t Details \n\t\n\n\t\t\n\t\t\t\n\t\t\t\tDate:\n\t\t\t\t\n\t\t\t\t\t August 31, 2024 \n\t\t\t\t\n\t\t\t\n\n\t\t\n\t\t\n\t\t\n\t\t\t\n\t\t\t\tCost:\n\t\t\t\t $30 – $50 \n\t\t\t\n\t\t\n\t\t\n\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\t\t\tWebsite:\n\t\t\t\t\t\t\t\t Artspring.ca/membership \n\t\t\t\n\t\t\n\t\t\t\n\n\n\n\tOrganizer\n\t\n\t\t\t\t\t\n\t\t\t\tArtSpring\t\t\t\n\t\t\t\t\n\n\n\t\n\n\n\t\t\t\n\t\t\n\n\t Venue \n\t\n\t\t\t\t ArtSpring – Theatre \n\n\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\n\n100 Jackson Avenue\n\t\n\t\t\n\t\tSalt Spring Island,\n\n\tBC\n\n\tV8K 2V8\n\n\tCanada\n\n\n\n\t\t\t\t\t\t\t\t\t\t\t\t\t+ Google Map\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\n\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\tPhone\n\t\t\t\t\t 250.537.2102 \n\t\t\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\n\n\n\n\t\n\n\n\n\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\n\t\t\t\n\n\n\t\t\t \n\n\t\n\t\n    \n\t\t\n\t\t\n\t\tEvent Navigation\n\t\t\n\t\t\t« NEW SEASON TICKET SALES OPEN\n\t\t\tLobby Exhibition: Diverse Threads »\n\t\t\n\t\n\n\n\n\n\n\t\t\t\t\t \n\n\t\t\t\t\n\t\t\t\t"
      }
    ]
