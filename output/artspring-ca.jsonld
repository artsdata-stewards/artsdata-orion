  {
    "@id": "https://artspring.ca/temporary/d7db696e-ca62-43a0-bd03-137030b5b1a2",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/remi-bolduc-jazz-ensemble-the-great-masters-of-jazz/"
