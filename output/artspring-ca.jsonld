  {
    "@id": "https://artspring.ca/temporary/798a10c0-1720-42b0-b300-e4bbad257077",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/masterplants-orchestra-concert-western-canada-tour/"
