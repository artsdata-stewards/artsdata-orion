  {
    "@id": "https://artspring.ca/temporary/308ad6f6-a9de-4280-91c2-36c416b2077d",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
