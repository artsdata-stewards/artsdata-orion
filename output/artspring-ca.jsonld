  {
    "@id": "https://artspring.ca/temporary/a21f0103-63e1-4488-9035-4686e6c220a3",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
