  {
    "@id": "https://artspring.ca/temporary/dbc8a0b1-b1c7-4dc0-af6c-158cdf247884",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/ss-forum-presents-adam-olsen-whos-afraid-of-dripa/"
