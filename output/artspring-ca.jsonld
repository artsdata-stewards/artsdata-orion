    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Photograph by Kali Spitzer &nbsp; ŌĆ£VoxŌĆØ ŌĆō a contemporary fine art photography exhibition featuring twelve renowned Canadian fine art photographers including Kali Spitzer, Whitney Lewis-Smith, Sage Szkabarnicki-Stuart, Rydel Cerezo, Stacey [&hellip;]&lt;/p&gt;\\n"
