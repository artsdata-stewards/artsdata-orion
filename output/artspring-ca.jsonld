  {
    "@id": "https://artspring.ca/temporary/d7f1ee82-b213-486d-bd4c-5b2fc78dedc0",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
