  {
    "@id": "https://artspring.ca/temporary/94713b9c-43f0-43a4-8c31-13a51d6c25f8",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/salt-spring-film-festival-presents-everest-dark/"
