  {
    "@id": "https://artspring.ca/temporary/0f7ad077-d93b-4491-8828-e0573ca4c9f9",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
