    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;The Salish Sea Bassoon Collective presents Bassoon-apalooza: a rare chance to see twelve bassoons on one stage! Bassoon-apalooza brings together four of Salt Spring Island’s bright new student bassoonists alongside eight professional players for an unforgettable musical showcase. From playful children’s songs and rowdy sea shanties to dramatic tangos and classical favourites, this concert proves [&hellip;]&lt;/p&gt;\\n"
      }
