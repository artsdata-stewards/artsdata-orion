  {
    "@id": "https://artspring.ca/temporary/aa318c21-012c-4b88-8370-b96e9e099da1",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
