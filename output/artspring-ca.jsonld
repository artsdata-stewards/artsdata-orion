    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Stratum"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;United by a focus on process and material, driven by the challenges of the ephemeral, mysterious, precarious and elusive, four Saltspring-based artists come together in Stratum, an exhibition of two-dimensional works. Stratum is layers, depth, building up and excavating down. It is smooth and textured wax, opaque and translucent, charcoal set down thick as velvet, [&hellip;]&lt;/p&gt;\\n"
      }
    ],
