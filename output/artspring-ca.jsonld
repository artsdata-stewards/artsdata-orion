  {
    "@id": "https://artspring.ca/temporary/755246de-c80b-4b0c-b467-1ff28d95c6f0",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/creedence-clearwater-relived-bad-moon-riders-ccr-tribute-concert/"
