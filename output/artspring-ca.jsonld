  {
    "@id": "https://artspring.ca/temporary/7ff89713-b05b-4d7b-9c93-03f3cb80ffee",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
