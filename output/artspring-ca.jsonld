  {
    "@id": "https://artspring.ca/temporary/3bf83cfc-8087-4756-9ad2-1b1061235697",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/remi-bolduc-jazz-ensemble-the-great-masters-of-jazz/"
