    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;&nbsp; To Have a Face explores the tension between visibility and vulnerability. The faceŌĆöour first site of encounterŌĆöacts as both a mask and a mirror, an invitation into the vastness of the self. Through figurative abstraction, face and body become shifting surfaces where identity is revealed, concealed, and continually negotiated. To have a face is [&hellip;]&lt;/p&gt;\\n"
      }
