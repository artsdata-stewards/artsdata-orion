  {
    "@id": "https://artspring.ca/temporary/d1fd574f-f15f-439f-9d31-75952b1b340c",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
