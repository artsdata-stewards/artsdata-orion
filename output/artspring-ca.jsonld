  {
    "@id": "https://artspring.ca/temporary/7c89f0f5-dbea-4c9d-b7b6-e0725a0a3c9b",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
