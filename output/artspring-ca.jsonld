  {
    "@id": "https://artspring.ca/temporary/28b59161-7bb4-4e53-b8eb-e122ef98afb6",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
