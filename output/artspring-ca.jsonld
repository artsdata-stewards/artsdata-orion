    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Steffany McAren is a Salt Spring Island based artist whose work captures the natural beauty and atmosphere of the Gulf Islands. Using acrylic paint on both canvas and live edge [&hellip;]&lt;/p&gt;\\n"
