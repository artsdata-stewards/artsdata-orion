  {
    "@id": "https://artspring.ca/temporary/eabf2065-bfe0-461a-bde2-eabc41e9afef",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/ss-forum-2024-provincial-election-candidates-debate/"
