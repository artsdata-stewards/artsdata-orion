  {
    "@id": "https://artspring.ca/temporary/50434f20-f994-487c-8868-3f6b81663bb3",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
