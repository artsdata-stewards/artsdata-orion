  {
    "@id": "https://artspring.ca/temporary/d2437c48-a67f-4792-a07e-e7cae8688783",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/met-opera-il-barbiere-di-siviglia-rossini/"
      }
