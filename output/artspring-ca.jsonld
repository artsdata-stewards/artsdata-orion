  {
    "@id": "https://artspring.ca/temporary/e74c64e8-fd1c-415b-bdf9-c18ec9156c4d",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/small-town-chicks-event-2/"
