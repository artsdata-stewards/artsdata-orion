  {
    "@id": "https://artspring.ca/temporary/7539b671-dd5e-4b8e-9da7-09aa56ccfc78",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/the-flame-storytelling-workshop-2/2025-01-18/"
      }
