  {
    "@id": "https://artspring.ca/temporary/6029ad90-ebcb-4929-b4d5-f3b7db6bd0c3",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/ss-photography-club-annual-artspring-lobby-exhibition/"
