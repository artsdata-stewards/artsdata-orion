    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;SUN APR 6 | 2:30pm | Canadian pianist Sarah Hagen performs this classic programme featuring BachŌĆÖs formidable Goldberg Variations as part of the celebration of the recent release of her [&hellip;]&lt;/p&gt;\\n"
