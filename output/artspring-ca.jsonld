    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "LOBBY EXHIBITION: Life in Glass"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;ONE DAY ONLY! STAINED GLASS SHOW Lorne Tippett is a local artist who specializes in stained glass. He grew up in picturesque eastern Canada and has been living on the west coast of B.C. since the mid 1990’s. He is an avid sea kayaker exploring our rugged shores which are an inspiration for many of [&hellip;]&lt;/p&gt;\\n"
      }
    ],
