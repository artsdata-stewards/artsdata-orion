  {
    "@id": "https://artspring.ca/temporary/cd501926-c48d-4fc4-8320-3f76d6c02d73",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
