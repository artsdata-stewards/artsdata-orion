  {
    "@id": "https://artspring.ca/temporary/11610485-d179-4a24-9a53-5233c2d3648d",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/penderecki-string-quartet-2/"
