  {
    "@id": "https://artspring.ca/temporary/562fce67-d6c3-4cde-9482-d6385dbb9c25",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/giss-dance-presents-community-dance-performance/"
