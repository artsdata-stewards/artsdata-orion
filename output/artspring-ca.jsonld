  {
    "@id": "https://artspring.ca/temporary/21569e9a-f92c-483f-82b4-ae756ac89d48",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/african-chamber-music-zimbabwean-south-african-and-ghanaian-traditions/"
