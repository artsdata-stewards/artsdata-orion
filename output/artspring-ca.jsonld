    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Immersive Experience Week Feb 14-20, 2025: In concert with Black History Month, engage with a week-long residency celebrating Black artistry and excellence through concerts, open rehearsals, public talks, and educational [&hellip;]&lt;/p&gt;\\n"
