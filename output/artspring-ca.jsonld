  {
    "@id": "https://artspring.ca/temporary/4e1297f8-eda5-40c1-aa09-88edbfa6d36e",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://artspring.ca/event/ssi-weavers-spinners-annual-show-sale/"
