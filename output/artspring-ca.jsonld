  {
    "@id": "https://artspring.ca/temporary/02305c3d-ae26-4ba3-8bb0-7fd07e6e9666",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
