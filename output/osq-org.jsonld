  {
    "@id": "https://www.osq.org/concerts/noel-droit-au-choeur/#event",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.osq.org/concerts/noel-droit-au-choeur/"
