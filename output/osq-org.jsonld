        "@id": "https://www.osq.org/concerts/romeo-et-juliette-de-prokofiev/#primaryimage"
      },
      {
        "@id": "https://www.osq.org/genid/747cf094aed2f2f0"
      },
      {
        "@id": "https://www.osq.org/genid/d00999b8eaa80ddb"
