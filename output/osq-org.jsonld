  {
    "@id": "https://www.osq.org/concerts/monumentale-4e-symphonie-de-tchaikovski/#event",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.osq.org/concerts/monumentale-4e-symphonie-de-tchaikovski/"
      }
    ],
    "http://schema.org/location": [
