  {
    "@id": "https://www.osq.org/concerts/maman-jai-rate-lavion-en-concert/#event",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.osq.org/concerts/maman-jai-rate-lavion-en-concert/"
