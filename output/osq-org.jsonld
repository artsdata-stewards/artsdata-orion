    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Le bouleversant Stabat Mater de Dvořák | Orchestre symphonique de Québec"
      }
    ],
    "http://ogp.me/ns#description": [
      {
