      {
        "@id": "https://www.osq.org/concerts/dialogues-des-carmelites/#primaryimage"
      },
      {
        "@id": "https://www.osq.org/genid/f9c1b1c4ce7bd78c"
      },
      {
        "@id": "https://www.osq.org/genid/5c083e09bd12f326"
