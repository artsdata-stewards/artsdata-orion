    "http://ogp.me/ns#title": [
      {
        "@language": "fr-fr",
        "@value": "Rayonnante Huitième symphonie de Dvořák | Orchestre symphonique de Québec"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-fr",
        "@value": "Un concert éclatant sous la direction de Gergely Madaras, où lumière et musique brillent à travers Dohnányi, Mendelssohn et Dvořák. Avec la talentueuse Élisabeth Pion au piano, laissez-vous porter par cette célébration radieuse!"
      }
    ],
