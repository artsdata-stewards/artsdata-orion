      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Cirque"
      },
      {
        "@language": "fr",
        "@value": "Famille"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/6e19bbe7b159eeac"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/b5243578c81444da"
      }
    ],
    "http://schema.org/organizer": [
      {
