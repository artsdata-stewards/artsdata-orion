  {
    "@id": "https://co-motion.ca/spectacles/mathieu-cyr-adulte/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "C’est aussi une critique punchée de notre société actuelle, avec les jeunes en «têtes de brocolis», les 147 orientations sexuelles et les chirurgies…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
