  {
    "@id": "https://co-motion.ca/temporary/67461610-f57b-416b-8fb5-57755be4352f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/lama-daventures-en-aventures/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/a41f22345028aa8d"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/lama-daventures-en-aventures/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-11T19:30:00-04:00"
      }
    ],
