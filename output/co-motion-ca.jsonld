  {
    "@id": "https://co-motion.ca/temporary/62ff476b-c00f-43c2-a83e-f03da3f1e8b4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/equipage-recherche/"
      }
    ],
