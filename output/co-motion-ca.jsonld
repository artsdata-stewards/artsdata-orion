  {
    "@id": "https://co-motion.ca/spectacles/philippe-laprise-au-sommet/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Dans ce spectacle solo, Philippe se questionne sur ce que c’est réellement être au sommet à notre époque où tout évolue rapidement."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Philippe-Laprise-2.jpg?mtime=1759516238"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
