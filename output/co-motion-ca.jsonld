  {
    "@id": "https://co-motion.ca/temporary/91cba58b-472a-445f-8d84-d7e7c79fa0c5",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/laurence-jalbert-tournee-35e-anniversaire/"
      }
    ],
    "http://schema.org/image": [
