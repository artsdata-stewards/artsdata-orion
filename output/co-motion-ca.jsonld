        "@value": "2026-09-24T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1196080"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1196120"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g1196140"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/cest-quoi-ta-toune/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p dir=\"ltr\"><em>C’est quoi ta toune?</em> est LE spectacle interactif où le public est maître de la soirée! Revivez les grands succès des années 60 à aujourd’hui qui ont fait chanter et danser toutes les générations! De <strong>Céline Dion à Tina Turner</strong>, en passant par <strong>Queen</strong>, vivez une soirée festive qui plaira à tous les goûts!<br /></p>\n<p dir=\"ltr\">À chaque représentation, l’expérience est unique : c’est vous qui choisissez les blocs musicaux qui façonneront la soirée! Les artistes découvriront en même temps que vous le spectacle qu’ils interpréteront. Grâce à une plateforme immersive, suivez en direct les résultats des votes et voyez l’impact de vos choix sur scène. Près de 150 chansons sont prêtes: à vous de décider ce que vous voulez entendre!<br /></p>\n<p dir=\"ltr\">Sur scène, <strong>Suzie Villeneuve, Renee Wilkin, Jordan Lévesque, Jason McNally</strong>, mis en scène et animé par <strong>Joël Legendre.</strong> Ce spectacle vous plongera dans une ambiance festive et vous fera chanter et danser du début à la fin!<br /></p>\n<p dir=\"ltr\">Laissez-vous emporter par l’énergie contagieuse de ce spectacle original où chaque soir réserve son lot de surprises et d’émotions.<br /></p>\n<p dir=\"ltr\"><strong>Alors, c'est quoi ta toune?</strong><br /></p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
