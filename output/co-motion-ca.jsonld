  {
    "@id": "https://co-motion.ca/temporary/c257b91d-5930-4f2b-96cd-979712cb0019",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/va-falloir-toujours-toujours/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/a58f05f516923e72"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/va-falloir-toujours-toujours/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
