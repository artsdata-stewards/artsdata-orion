  {
    "@id": "https://co-motion.ca/temporary/671582af-0638-4645-9c83-27749ceb0307",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/zaman-ou-on-a-le-meme-temps-quon-avait/"
      }
    ],
    "http://schema.org/image": [
