  {
    "@id": "https://co-motion.ca/temporary/d19fee50-d0c0-4e36-acad-b4cc04a04fd3",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/leffet-lisa/"
      }
    ],
