  {
    "@id": "https://co-motion.ca/temporary/dbb01727-4701-44f7-8398-2afd6414393c",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/zones-musicales-maia-barouh/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/b733665b4d1fb18e"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/zones-musicales-maia-barouh/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-08-06T17:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
