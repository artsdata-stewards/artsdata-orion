      {
        "@language": "fr",
        "@value": "Spectacle hommage"
      },
      {
        "@language": "fr",
        "@value": "Musique"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1252160"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g1252180"
      }
    ],
    "http://schema.org/organizer": [
      {
