  {
    "@id": "https://co-motion.ca/temporary/b091525d-65da-4464-882d-abe11f7a8539",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mommy-le-retour/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2181360"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mommy-le-retour/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-05T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2181380"
