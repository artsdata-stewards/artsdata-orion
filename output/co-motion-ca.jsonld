  {
    "@id": "https://co-motion.ca/temporary/5dc148bc-9c13-47d6-b248-9f5e989d25cb",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/cirque-alfonse-la-noce-dalfonse/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/32db35510b8165e3"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/cirque-alfonse-la-noce-dalfonse/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
