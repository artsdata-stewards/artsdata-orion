  {
    "@id": "https://co-motion.ca/temporary/ceb0e214-ff32-4218-a9b8-e459b46a9176",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/tommy-neron-les-fleurs-poussent-encore/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/6261ca4b13d8dcf1"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/tommy-neron-les-fleurs-poussent-encore/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-12T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
