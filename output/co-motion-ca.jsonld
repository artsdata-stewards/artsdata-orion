  {
    "@id": "https://co-motion.ca/spectacles/la-bas/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "L’Aubergine Durée : 55 minutes Ce spectacle d’art clownesque est une production de L’Aubergine."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/MDA/Jeune-Public-2026/_1200x630_crop_center-center_82_none/Là-bas.jpg?mtime=1778009440"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr",
        "@value": "fr_ca"
      }
    ]
  },
  {
    "@id": "https://co-motion.ca/temporary/80a4e233-c17c-48c5-8391-70ae11a6ae8f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/la-bas/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/dd5f79fea7bcd0c9"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/la-bas/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-24T15:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/d807056899cadf66"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Jeune public"
      },
      {
        "@language": "fr",
        "@value": "Art clownesque"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/f0ff1fb3f2f2facb"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/a1298efc717fbd24"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/la-bas/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><sup>L’Aubergine<br />Durée : 55 minutes</sup><br /></p>\n\n\n\n<p>Ce spectacle d’art clownesque est une production de L’Aubergine.</p>\n<p>Trois inséparables ont plié bagage. Ils trimbalent leurs souvenirs sur la grande route de la vie. Traversant une multitude de péripéties cocasses et loufoques, ils feront des rencontres inattendues et farfelues… Nos trois zigotos incomparables se serreront les coudes et feront des pieds et des mains pour affronter les folles aventures qu’ils croiseront sur leur chemin. </p>\n<p><em>Là-bas </em>est un spectacle réconfortant où l’humour intemporel se mêle aux acrobaties et à la poésie. Le spectacle est une ode à l’imagination et à la complicité. Une histoire drôle, tendre et ludique sur l’entraide, la résilience et les petites joies de la vie.</p>\n<p>Spectacle présenté en collaboration avec En Piste - Regroupement national des arts du cirque.<br /><br /></p>\n\n\n<p><a href=\"http://www.laval.ca/diffusart\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Diffusart</a></p>\n<p><sub>Suivre la production<br /><a href=\"https://www.laubergine.qc.ca/\" target=\"_blank\" rel=\"noreferrer noopener\">Site web</a><br /><a href=\"http://facebook.com/www.laubergine.qc.ca/\" target=\"_blank\" rel=\"noreferrer noopener\">facebook</a></sub></p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Là bas"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
