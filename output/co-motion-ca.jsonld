  {
    "@id": "https://co-motion.ca/spectacles/tommy-neron-les-fleurs-poussent-encore/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Ces termes-là, c’est comme le mot Flamboyant, Y’a pas un humoriste qui se décrit lui-même comme flamboyant."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
