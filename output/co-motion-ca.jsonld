  {
    "@id": "https://co-motion.ca/spectacles/betes-de-fete/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Une invitation, spécialement dédiée aux enfants, petits et grands, à venir tout donner sur la piste de danse, vêtu.es des atours les plus loufoques!"
      }
    ],
