  {
    "@id": "https://co-motion.ca/temporary/e22d5f38-fc99-42d2-a981-85dd9f8c4144",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/tocadeo-le-meilleur-de-nous/"
      }
    ],
    "http://schema.org/image": [
