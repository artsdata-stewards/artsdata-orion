  {
    "@id": "https://co-motion.ca/temporary/429e03cd-3289-4492-9835-8e060f5e286e",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/marie-elaine-thibert-parlez-moi-delle/"
      }
    ],
