  {
    "@id": "https://co-motion.ca/temporary/af38726c-25bf-42ea-bf58-1f258ba74bd2",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/hommes-de-pioche-renee-robitaille/"
      }
    ],
