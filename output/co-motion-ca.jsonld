  {
    "@id": "https://co-motion.ca/temporary/6e08bf3f-d229-4461-8d46-2cc7db0125ae",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/pascal-cameron-nouveau-spectacle/"
      }
    ],
