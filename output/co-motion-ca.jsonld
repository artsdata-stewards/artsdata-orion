  {
    "@id": "https://co-motion.ca/spectacles/jose-gaudet-nouveau-spectacle/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Il a à son actif plus de 25 ans d’animation radio, deux tournées de spectacles bien récompensées, animation de galas et 10 ans à la barre de talks-shows…"
      }
    ],
