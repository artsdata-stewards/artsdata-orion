  {
    "@id": "https://co-motion.ca/temporary/0b85a196-ee77-46b1-bd71-1ae59d142638",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/jean-michel-anctil-surprise-cest-ma-fete/"
      }
    ],
