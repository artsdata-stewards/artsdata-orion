  {
    "@id": "https://co-motion.ca/temporary/862fee30-28ae-47f0-ba39-148dfdec2755",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/zones-musicales-constellation-de-cordes/"
      }
    ],
    "http://schema.org/image": [
