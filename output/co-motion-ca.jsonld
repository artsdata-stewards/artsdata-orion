  {
    "@id": "https://co-motion.ca/temporary/d90435da-bb4a-4b7e-b08a-271ce99e97e4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/michel-barrette-drole-depuis-1957/"
      }
    ],
