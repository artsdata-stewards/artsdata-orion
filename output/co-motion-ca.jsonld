  {
    "@id": "https://co-motion.ca/temporary/4ad6cf88-8295-4961-a4f8-29927143ef29",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/la-revue-finale-des-ballets-jazz-de-montreal/"
      }
    ],
    "http://schema.org/image": [
