  {
    "@id": "https://co-motion.ca/temporary/d44d6fb2-7c34-4aef-bfe1-300daf1abc0d",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/la-plume-des-perilleuses-peripeties/"
      }
    ],
