    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "L’icône française de la chanson, Serge Lama (Je suis malade, d’Aventures en aventures, Les Ballons rouges) , devait faire une dernière tournée. C’est…"
      }
    ],
