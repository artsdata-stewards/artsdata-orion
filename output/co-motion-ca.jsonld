        "@id": "_:g2168640"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/patrick-groulx-trop-longtemps-seul/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
