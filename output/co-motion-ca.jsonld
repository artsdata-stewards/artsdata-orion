        "@id": "https://co-motion.ca/genid/7820e6fb180714db"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/sonido-pesao/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-28T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/d807056899cadf66"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/cc249b3978be4879"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/ca91bb26ab84308b"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/sonido-pesao/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><sup>Durée : 75 minutes, sans entracte</sup></p>\n<p>Fusionnant les influences latin-<em>urban</em>-rap, le son unique de Sonido Pesao est le reflet de la diversité de ses membres originaires de différents pays d’Amérique latine et de la métropole montréalaise. Leurs textes percutants oscillent entre la réalité des rues et les célébrations de la vie, en plus de susciter la réflexion. Sur scène, où l'atmosphère explosive dément toute classification conventionnelle, leur musique déborde d'une énergie contagieuse. <em>¡Vamos a romper con Sonido Pesao! </em></p>\n<p><strong>Ronald Lemus (rappeur)<br />Marco Antonio (rappeur)<br />Elodie Synnott (rappeuse-chanteuse)<br />Julien Senez-Gagnon (basse)<br />Javier Munoz (guitare)<br />Axel Bonnaire (batterie)</strong></p>\n<p>Photo : Giannia Salomone<br /><a href=\"http://www.laval.ca/diffusart\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Diffusart</a><sub><br /></sub></p>\n<p><sub>Suivre le groupe<br /><a href=\"https://www.facebook.com/sonidopesao\" target=\"_blank\" rel=\"noreferrer noopener\">Facebook</a></sub><br /></p>"
      }
    ],
