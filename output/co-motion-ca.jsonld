    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/spectacle-de-danse-des-loisirs-st-francois/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><strong>Le spectacle de danse des Loisirs St-François </strong>clos la boucle d'une année complète d'apprentissage et d’évolution réalisée par nos jeunes vedettes talentueuses. Sur le thème de ­ “La quête”, les jeunes interprètes nous présenteront des chorégraphies divertissantes, surprenantes, et parfois touchantes. Parce que nous sommes tous en quête de la même chose: le bonheur!</p>\n\n<p>Nous invitons parents, amis et familles à venir célébrer le talent et le travail de chaque interprète. Encouragez la relève et par le fait même, l'art de la danse!</p>"
      }
    ],
