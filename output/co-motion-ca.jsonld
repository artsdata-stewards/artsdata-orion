  {
    "@id": "https://co-motion.ca/temporary/75016665-edda-4a0e-8358-9ee06b9309cb",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/le-petit-roi-pour-toujours/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/0117bd13eca9afb5"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/le-petit-roi-pour-toujours/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-10T20:00:00-04:00"
      }
    ],
