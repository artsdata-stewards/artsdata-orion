  {
    "@id": "https://co-motion.ca/temporary/915e651c-8f2c-45c8-b605-1716fe461a70",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/noel-une-tradition-en-chanson-2026/"
      }
    ],
