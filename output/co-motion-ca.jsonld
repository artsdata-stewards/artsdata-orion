  {
    "@id": "https://co-motion.ca/spectacles/josiane-aubuchon-en-promenade/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après trois ans en résidence mensuelle à Montréal, Josiane Aubuchon part en promenade à travers la province!"
      }
    ],
