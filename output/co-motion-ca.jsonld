    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/christine-morency-bien-faite/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>C’est reparti pour une deuxième tournée!<br /><br />Christine vous rejoint pour partager ses histoires les plus intimes et vous montrer à quel point elle est BIEN FAITE!<br /><br />Bien faite physiquement (évidemment!), bien faite par les valeurs qui lui ont été transmises, mais surtout bien faite dans sa capacité à en rire plutôt qu’à en pleurer. </p>\n\n<p> As-tu tes billets pour le show de Christine Morency? Oui? T’AS BIEN FAITE! </p>"
      }
    ],
