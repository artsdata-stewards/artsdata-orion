        "@language": "fr",
        "@value": "Dans son tout nouveau spectacle Drôle depuis 1957 , Michel Barrette revient en force avec un regard hilarant et tendre sur sa génération."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Nouv-siteweb_poster_Spectacle-756-x-1100-px-27.jpg?mtime=1761232937"
