    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le Carrousel, compagnie de théâtre Durée : 50 minutes Joséphine est une petite fille coach de vie pour enfants. Au fil des 10 leçons de coaching, on…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/MDA/Jeune-Public-2026/_1200x630_crop_center-center_82_none/Josephine-et-grandes-personnes.jpg?mtime=1778009439"
      }
    ],
