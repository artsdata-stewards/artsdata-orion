  {
    "@id": "https://co-motion.ca/temporary/a04d92a4-8f34-4440-ad66-f6645c4746e4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/brouillamini-joyeux/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1025200"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/brouillamini-joyeux/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
