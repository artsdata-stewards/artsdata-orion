  {
    "@id": "https://co-motion.ca/spectacles/zac-bulle-mon-super-spectacle/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Zac Bulle , 8 ans et demi, s'est fait connaître grâce à ses vidéos virales où il partage ses plus grandes passions : la mayo, ses aventures quotidiennes,…"
      }
    ],
