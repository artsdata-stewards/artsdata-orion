        "@language": "fr",
        "@value": "Musique"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/0343019762118e46"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/959d1050c06fef39"
      }
    ],
    "http://schema.org/organizer": [
