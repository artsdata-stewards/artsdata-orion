  {
    "@id": "https://co-motion.ca/temporary/587d8e0e-9f1c-42e0-9452-ce63a4d1cb86",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/sonido-pesao/"
      }
    ],
    "http://schema.org/image": [
