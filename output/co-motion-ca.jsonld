  {
    "@id": "https://co-motion.ca/temporary/17a8040d-7b93-4c30-bb1e-372ebe0a8d4f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/va-falloir-toujours-toujours/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g3105720"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/va-falloir-toujours-toujours/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
