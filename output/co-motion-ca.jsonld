  {
    "@id": "https://co-motion.ca/temporary/898ab387-7946-49cb-955e-b76fd1746014",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/patrick-groulx-trop-longtemps-seul/"
      }
    ],
