  {
    "@id": "https://co-motion.ca/temporary/7f3cf9e5-32df-42d3-ad54-cbf859eb1184",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/breen-leboeuf-mes-blues-passent-pu-dans-porte/"
      }
    ],
    "http://schema.org/image": [
