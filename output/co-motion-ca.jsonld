    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Ce dernier concert des Chambristes vous invite à un voyage empreint de douceur et d'élégance, guidé par un duo flûte et harpe. <strong>Jean-Philippe Tanguay</strong> à la flûte et <strong>Valérie Milot</strong> à la harpe vous interpréteront un répertoire varié inspiré de la <strong>musique impressionniste française</strong> et de <strong>mélodies japonaises.</strong></p>"
      }
    ],
