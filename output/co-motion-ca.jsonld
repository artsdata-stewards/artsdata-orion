  {
    "@id": "https://co-motion.ca/temporary/44e6f438-46c5-4130-b49e-bff55a441a5d",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/hommes-de-pioche-renee-robitaille/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/4134ac5a688eef21"
      }
    ],
    "http://schema.org/url": [
