    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/petits-bonheurs-les-reveries/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><sup>BOA expérience<br /></sup><sup></sup>Plongez dans un monde où la musique, les lumières et les textures se rencontrent pour créer une expérience de bien-être unique.<em> Les Rêveries</em> sont des espaces immersifs et multisensoriels conçus pour éveiller vos sens et vous offrir une relaxation profonde. Chaque détail est pensé pour favoriser la détente, la contemplation et l’harmonie intérieure. Découvrez cet univers apaisant, où chaque moment est un voyage sensoriel.<br /></p>\n\n<p>Durée : 30 minutes</p>\n<p><a href=\"https://www.boaexperience.com/reveries\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Site Internet</a></p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
