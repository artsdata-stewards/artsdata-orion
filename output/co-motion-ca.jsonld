        "@id": "https://co-motion.ca/genid/2d06e7cbb66ab54d"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Musique"
      },
      {
        "@language": "fr",
        "@value": "Jeune public"
      },
      {
        "@language": "fr",
        "@value": "Spectacle de Noël"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/0329d6cf93e85169"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/09cee134142b7498"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><strong>Le Père Nicolas Noël vous invite à vivre un tout nouveau spectacle musicale festif en compagnie de ses fidèles lutins, Pamalin et Trémaline ! </strong></p>\n\n<p>La jeune lutine fraîchement diplômée de l’École des Lutins, revient en force avec une idée des plus déroutantes : moderniser Noël ! Et elle ne fait pas les choses à moitié : </p>\n<p>Adieu les rennes et la Grande Distribution… vive les drones de livraison ! </p>\n<p>Fini les rencontres chaleureuses avec le Père Noël : Bonjour les appels virtuels et la réalité augmentée ! </p>\n<p><strong>La magie de Noël sera-t-elle effacée pour faire place à l’intelligence artificielle ?!</strong> </p>\n<p>Tiraillé entre le respect des traditions et le besoin de s’adapter aux nouvelles technologies, le Grand Magicien à la barbe blanche devra puiser dans sa sagesse pour peut-être sauver la Grande Nuit Magique…  </p>\n<p>Une occasion intergénérationnelle de célébrer, tous ensemble et en famille, une fête traditionnelle merveilleuse…Noël ! </p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Entre deux mondes"
      }
    ],
