  {
    "@id": "https://co-motion.ca/spectacles/une-petite-fete/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Une production: Le Carrousel, compagnie de théâtre Deux personnages fougueux et libres vous reçoivent dans une fête secrète, un peu canaille, un peu…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/MDA/ECC/_1200x630_crop_center-center_82_none/Une-petite-fête.jpg?mtime=1762526485"
      }
    ],
