  {
    "@id": "https://co-motion.ca/temporary/ff8d58af-e252-4034-8719-d72ed50782b0",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/ariane-racicot-en-trio-danser-avec-le-feu/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/65424da36ec059f7"
