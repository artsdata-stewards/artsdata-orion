  {
    "@id": "https://co-motion.ca/spectacles/andre-sauve-nouveau-spectacle/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "André Sauvé fait un retour sur scène avec une création audacieuse où son regard unique sur le monde puise son inspiration dans la nature et ses mystères."
      }
    ],
