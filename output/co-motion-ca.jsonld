  {
    "@id": "https://co-motion.ca/spectacles/philippe-b-cigale/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "La précieuse et vibrante chanson folk de Philippe B résonne depuis plus de 20 ans sur notre scène musicale."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Philippe-B-2.jpg?mtime=1770909142"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
    "http://ogp.me/ns#locale": [
