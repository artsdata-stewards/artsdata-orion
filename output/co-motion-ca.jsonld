  {
    "@id": "https://co-motion.ca/spectacles/pierre-hebert-grandiose/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "C’est à ce moment qu’on réalise que tout ça en valait la peine."
      }
    ],
