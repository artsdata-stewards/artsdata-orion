  {
    "@id": "https://co-motion.ca/temporary/a71d2423-b362-4816-b513-d60e7f9aa81b",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/panorama-historique-du-theatre-quebecois/"
      }
    ],
    "http://schema.org/image": [
      {
