  {
    "@id": "https://co-motion.ca/temporary/495c7789-d3e5-449e-9666-0df5d5d891e9",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/eyevin-nonet/"
      }
    ],
    "http://schema.org/image": [
