  {
    "@id": "https://co-motion.ca/temporary/2bbafd59-72b6-4cd9-92ba-5bb570d562a7",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/premier-ciel-lheritage-musical-dharmonium/"
