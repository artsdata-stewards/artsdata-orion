  {
    "@id": "https://co-motion.ca/temporary/498b3cce-5d1c-48bb-871b-eddaa3e4b600",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/andre-sauve-nouveau-spectacle/"
      }
    ],
    "http://schema.org/image": [
