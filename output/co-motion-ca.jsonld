  {
    "@id": "https://co-motion.ca/spectacles/olivier-martineau-cest-pas-moi-cest-toi/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Société, c’est fini. C’EST PAS MOI, C’EST TOI , c’est du stand-up pur et dur, un véritable feu roulant de gags où chaque punch frappe en plein cœur."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Olivier-Martineau.jpg?mtime=1744723256"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr",
        "@value": "fr_ca"
      }
    ]
  },
  {
    "@id": "https://co-motion.ca/temporary/54d35f83-dad4-42e3-beaa-9f6ca496cb7c",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/olivier-martineau-cest-pas-moi-cest-toi/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2422240"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/olivier-martineau-cest-pas-moi-cest-toi/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-10T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2422260"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2422300"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g2422320"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/olivier-martineau-cest-pas-moi-cest-toi/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p dir=\"ltr\">Société, c’est fini.</p>\n<p dir=\"ltr\">Oui, on a eu de beaux moments, mais là, c’est trop. T’as changé. Moi, je m’en vais. Je te laisse tes règles farfelues et tes promesses en plastique. J’en ai assez de cette mascarade.</p>\n<p dir=\"ltr\"><strong>C’EST PAS MOI, C’EST TOI</strong>, c’est du stand-up pur et dur, un véritable feu roulant de gags où chaque punch frappe en plein cœur. Un regard sans filtre, mordant, mais surtout hilarant, sur une société où la rupture était inévitable.</p>\n<p dir=\"ltr\">Après trois spectacles, celui-ci est le plus audacieux, le plus osé, le plus authentique.</p>\n<p dir=\"ltr\">Bref, c’est la fin d’une histoire… et le début d’un show qui décoiffe. Mais moi, je m’en fous, j’ai pas de cheveux.<br /></p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "C'est pas moi, c'est toi"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Humour"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
