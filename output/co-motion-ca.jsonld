  {
    "@id": "https://co-motion.ca/temporary/c88497d6-3128-440f-bfc7-2bc29b9c74bb",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/aswell-kinji00/"
      }
    ],
    "http://schema.org/image": [
      {
