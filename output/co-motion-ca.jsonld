  {
    "@id": "https://co-motion.ca/temporary/ac3e522d-e11d-443f-9196-adb51d91ec11",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/dominique-fils-aime-the-sunshine-tour/"
      }
    ],
