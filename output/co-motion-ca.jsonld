  {
    "@id": "https://co-motion.ca/temporary/818de1f3-4d37-4e45-91a3-0587080eb9e4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mike-beaudoin-acharne/"
      }
    ],
