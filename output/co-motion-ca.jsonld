        "@value": "Fleurs d’acier raconte l’histoire touchante de six femmes qui se retrouvent chaque semaine dans le salon Chez Thérèse – coiffure et manucure."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
