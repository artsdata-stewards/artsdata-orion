  {
    "@id": "https://co-motion.ca/temporary/932b0b60-ae50-486c-860d-5f25c3239f5d",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/pierre-hebert-grandiose/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1865020"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/pierre-hebert-grandiose/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
