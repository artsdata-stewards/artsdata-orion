  {
    "@id": "https://co-motion.ca/temporary/6f3d854e-d287-4cdd-9787-8f9454f337eb",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/chris-klafford-sinners-tour/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2343320"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/chris-klafford-sinners-tour/"
      }
    ],
    "http://schema.org/startDate": [
