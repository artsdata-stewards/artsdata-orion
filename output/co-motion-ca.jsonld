  {
    "@id": "https://co-motion.ca/temporary/d3c15f01-507f-4e67-914b-60431ca5cadd",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/fleurs-dacier/"
      }
    ],
    "http://schema.org/image": [
      {
