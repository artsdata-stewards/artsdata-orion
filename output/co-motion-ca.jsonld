    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><strong>Simon Leblanc</strong> a plus envie que jamais de sillonner le Québec en quête de paysages et de faces qui rient. Simon repart donc en tournée pour présenter son quatrième spectacle, <em><strong>Présent</strong></em>. Il a hâte de vous voir comme ça s'peut pas!</p>\n<p>À bientôt tout le monde...<sub><br /></sub></p>\n<p><sub><strong>16 ans et plus</strong></sub></p>"
      }
    ],
