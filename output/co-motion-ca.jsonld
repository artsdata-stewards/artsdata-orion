      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/opera-bouffe-du-quebec-orphee-aux-enfers/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-30T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/17b0bf9e8c2a07c8"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/4d21ab30d287358d"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/af0c276759e750d2"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/opera-bouffe-du-quebec-orphee-aux-enfers/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><strong>Orphée aux Enfers, l’opérette la plus délirante de Jacques Offenbach</strong>.</p>\n<p>Mis en scène par Alain Zouvi et sous la direction musicale et artistique de Julien Patenaude, 9 solistes, 40 choristes et l’orchestre de l’OBQ vous offrent un pur moment de plaisir.</p>\n<p>Redécouvrez cette œuvre brillante et satirique où humour, virtuosité et fantaisie s’unissent. Les dieux s’ennuient, Orphée boude, Eurydice s’enfuit, l’Opinion publique réprimande… bref, tout va mal — et c’est hilarant.</p>\n<p>Distribution</p>\n\n\n\n\n\n\n\n\n<ul><li>John Styx: Richard Fréchette</li><li>Orphée: Gustave Richard</li><li>Pluton : Mathieu Abel</li><li>Eurydice : Anne-Sophie Gagnon Metellus</li><li>L’Opinion publique : Louise Robin</li><li>Jupiter : Rémi Ortega</li><li>Diane : Émilie Baillargeon</li><li>Cupidon; Dahlia Genest</li><li>Vénus : Marie-France Koua.</li></ul>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Orphée aux enfers"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Opéra / Opérette"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
