  {
    "@id": "https://co-motion.ca/temporary/68b7842d-bcdb-4756-891c-a4df04dec408",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/le-diner-de-cons-2026/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/71ac044dafb8c26a"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/le-diner-de-cons-2026/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-03T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
