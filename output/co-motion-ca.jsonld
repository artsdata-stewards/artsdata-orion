  {
    "@id": "https://co-motion.ca/spectacles/souldia-en-spectacle/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Spectacle festif : les gens seront debout dès la première chanson! Choisissez les premières rangées si vous aimez vous lever, chanter et danser, sinon…"
      }
    ],
    "http://ogp.me/ns#image": [
