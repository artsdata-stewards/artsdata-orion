  {
    "@id": "https://co-motion.ca/spectacles/scoooootch/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Les Nouveaux Ballets du Nord-Pas de Calais (France) en coproduction avec la Cie Synthèse Additive (Québec) Durée : 35 minutes Trois interprètes dynamiques…"
      }
    ],
    "http://ogp.me/ns#image": [
