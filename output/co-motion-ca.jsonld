  {
    "@id": "https://co-motion.ca/temporary/ed8b8ddc-dc7a-459d-a7ed-216166dedeb3",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/adib-alkhalidey-comme-les-mongols-a-baghdad/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/a12e43305b50b5df"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/adib-alkhalidey-comme-les-mongols-a-baghdad/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-05T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
