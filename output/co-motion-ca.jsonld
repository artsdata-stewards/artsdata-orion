      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>La grande valse, spectacle de gigue contemporaine s’intéressant aux liens amoureux qui perdurent, nourri par les témoignages d’une douzaine de couples de longue date. Une chorégraphie de Vincent-Nicolas Provencher et Mélissandre T-B, sous la bannière de Cent méandres - Arts &amp; découvertes.</p>"
      }
    ],
