  {
    "@id": "https://co-motion.ca/temporary/fd139e70-5fb0-4ef7-94e5-64fed35edda7",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/ariane-racicot-en-trio-danser-avec-le-feu/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2624500"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/ariane-racicot-en-trio-danser-avec-le-feu/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
