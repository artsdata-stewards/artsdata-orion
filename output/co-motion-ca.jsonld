  {
    "@id": "https://co-motion.ca/temporary/bdf17cee-dabd-4bd2-ae7b-47050ca77ce4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/equipage-recherche/"
      }
    ],
    "http://schema.org/image": [
