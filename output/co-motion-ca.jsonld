  {
    "@id": "https://co-motion.ca/spectacles/patrice-lecuyer/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Au fil de sa carrière, Patrice a toujours été discret sur sa vie, même s’il a vécu des situations hors du commun tant avec ses proches qu’avec de grandes…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Patrice-LEcuyer.jpg?mtime=1731012820"
      }
    ],
