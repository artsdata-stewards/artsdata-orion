  {
    "@id": "https://co-motion.ca/spectacles/guy-nantel-bienveillant/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Avec ce 7e spectacle en carrière, Guy Nantel continue de faire ce qu’il fait le mieux : nous dérouter, nous désarmer et surtout nous faire rire à gorge…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Guy-Nantel.jpg?mtime=1762897298"
