  {
    "@id": "https://co-motion.ca/spectacles/dave-morissette-david/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le seul et unique Dave Morissette monte sur scène avec son tout premier one-man-show, David et il en a des histoires à raconter!"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Dave-Morrissette.jpg?mtime=1775852499"
      }
    ],
    "http://ogp.me/ns#type": [
