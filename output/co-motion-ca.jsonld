  {
    "@id": "https://co-motion.ca/temporary/8680324b-96e6-4a36-8bea-318ed54f2c19",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/les-plus-belles-musiques-de-film-en-trio/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1740240"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/les-plus-belles-musiques-de-film-en-trio/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
