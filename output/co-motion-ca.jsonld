  {
    "@id": "https://co-motion.ca/spectacles/la-cumbia-less-toches/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Less Toches, c'est la collision musicale de cinq personnages explosifs, un big-bang de cumbia inattendu et rafraîchissant sur l'île de Montréal. La magie…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
