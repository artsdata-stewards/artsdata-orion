  {
    "@id": "https://co-motion.ca/spectacles/muda/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Musiciens : Lucas Melo, Enzo Lord Mariano, Isabelle Gaudreau, Saulo Omeldo Evans Photo : Mathias Arroyo Bégin Diffusart"
      }
    ],
