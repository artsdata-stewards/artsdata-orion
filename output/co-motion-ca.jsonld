  {
    "@id": "https://co-motion.ca/temporary/ce1a376a-6555-4269-9a82-5ca9652c5318",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/patrice-lecuyer/"
      }
    ],
    "http://schema.org/image": [
