      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mommy-le-retour/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-05T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
