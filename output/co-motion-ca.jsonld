  {
    "@id": "https://co-motion.ca/temporary/e6a48f98-7a9d-476a-af85-641593878c33",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/guy-nantel-bienveillant/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/c15bef0bba493d28"
      }
    ],
    "http://schema.org/url": [
      {
