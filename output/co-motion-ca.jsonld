        "@id": "https://co-motion.ca/genid/d9a30c84d1f5dd11"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/zones-musicales-constellation-de-cordes/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
