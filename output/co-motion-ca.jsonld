      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/guylaine-tanguay-i-love-rockroll/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Avec I LOVE ROCK’N’ ROLL, <strong>Guylaine Tanguay</strong> nous ramène là où tout a commencé : au bar Le Clairon de Normandin, où elle chantait, pendant ses études, les grands succès rock des années 80. De Joan Jett, Pat Benatar, Heart, AC/DC, Queen, Bon Jovi, The Police, Kiss et Tina Turner, jusqu’à Paul Daraîche, elle revisite avec fougue et nostalgie les chansons qui ont marqué son parcours. Un spectacle festif, vibrant et plein d’énergie!</p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
