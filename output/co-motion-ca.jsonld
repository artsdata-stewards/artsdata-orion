  {
    "@id": "https://co-motion.ca/spectacles/boulevard-perusse/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après de nombreuses années à faire rire la francophonie avec ses albums culte (plus de 2 millions de ventes) et ses œuvres à la radio et à la télé,…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/bOul-Pérusse.jpg?mtime=1776176955"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
    "http://ogp.me/ns#locale": [
      {
