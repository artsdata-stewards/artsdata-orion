  {
    "@id": "https://co-motion.ca/spectacles/mona-de-grenoble/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "J’aurais pu appeler ce show d’humour-là Étalon en talons ou Entre Bâton Rouge et matante, mais après j’ai désaoulé pis je me suis rendu compte que vous…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
