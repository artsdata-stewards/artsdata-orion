  {
    "@id": "https://co-motion.ca/temporary/865e6d90-a83f-4615-bda8-bd6596ae687b",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/barka/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/f322bfbf352f7dd9"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/barka/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-09T15:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/17b0bf9e8c2a07c8"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Cirque"
      },
      {
        "@language": "fr",
        "@value": "Musique du monde"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/034ae9d9912bf969"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/781336c7b7b3acb9"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/barka/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p></p>\n<p><sup>Gypsy Kumbia Orchestra<br />Durée : 1 h 30, sans entracte</sup></p>\n<p></p>\n<p><em>Débutez l’année avec du cirque pour toute la famille!</em></p>\n<p>Tout public à partir de 7 ans.</p>\n<p>Barka est un spectacle où se rencontrent les arts du cirque, la danse et la musique par les créateurs du groupe Gypsy Kumbia.</p>\n<p>Dans un extraordinaire chaos festif, <em>BARKA </em>est une célébration de la vie et un appel à l'espoir et à la liberté responsable. Percussions afro-colombiennes, mélodies des Balkans, danse et cirque s'entremêlent joyeusement dans un spectacle rempli d'une énergie et d'une richesse sonore, visuelle et sensorielle délirantes.</p>\n<p>Nous nous trouvons tous et toutes dans un bateau. Explorateurs, migrants ou survivants, peu importe, nous sommes partis. Le voyage a commencé, chacun et chacune d'entre nous étant à la recherche de son rêve. Mais nous flottons ensemble en mouvement, alors qu'une grosse tempête est prévue à l'horizon. Faisons en sorte que notre bateau ne coule pas!</p>\n<p><a href=\"http://www.laval.ca/diffusart\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Diffusart</a></p>\n<p><sub>Suivre l'artiste<a href=\"https://www.girovago.org/barka/\" target=\"_blank\" rel=\"noreferrer noopener\"><br />Site web</a>  <a href=\"http://facebook.com/girovago.org/\" target=\"_blank\" rel=\"noreferrer noopener\">Facebook</a>  <a href=\"http://instagram.com/girovago_org\" target=\"_blank\" rel=\"noreferrer noopener\">Instagram</a></sub></p>"
      }
    ],
