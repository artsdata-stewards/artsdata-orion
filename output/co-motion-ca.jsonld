    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/2f2e38878aadf4d3"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/971acdd69a2d2710"
      }
    ],
    "http://schema.org/organizer": [
