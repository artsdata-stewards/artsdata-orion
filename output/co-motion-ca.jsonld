  {
    "@id": "https://co-motion.ca/temporary/69d68ae0-da38-49c8-9fc1-93fd74f04738",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/muda/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/4005c0a835d3f864"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/muda/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-28T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
