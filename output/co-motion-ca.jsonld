  {
    "@id": "https://co-motion.ca/temporary/16e51170-a22e-47b3-9d83-e8f0a7f0ceb5",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/bruno-pelletier-3-et-moi/"
      }
    ],
    "http://schema.org/image": [
