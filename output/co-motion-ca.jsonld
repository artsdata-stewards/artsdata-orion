  {
    "@id": "https://co-motion.ca/temporary/87a9f300-d171-4f6b-9375-4826a8710b76",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/gab-bouchard-nouveau-spectacle/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1116600"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/gab-bouchard-nouveau-spectacle/"
      }
    ],
