  {
    "@id": "https://co-motion.ca/temporary/1a5c89e4-60e0-4309-96e1-8e65518e609f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/fanfare-sous-le-pommier/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2906040"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/fanfare-sous-le-pommier/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-11T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2906060"
      }
    ],
    "http://schema.org/offers": [
