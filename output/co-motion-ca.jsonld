  {
    "@id": "https://co-motion.ca/temporary/c9b605b0-ffdc-40bd-9667-cbea8aae8788",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/harmonie-des-opposees/"
      }
    ],
