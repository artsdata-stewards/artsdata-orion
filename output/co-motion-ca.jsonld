        "@value": "fr_ca"
      }
    ]
  },
  {
    "@id": "https://co-motion.ca/temporary/7b021a33-feb3-42fc-992b-c193732940ab",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/philippe-b-cigale/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2696880"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/philippe-b-cigale/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-02-13T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2696900"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2696940"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g2696960"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/philippe-b-cigale/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p dir=\"ltr\">La précieuse et vibrante chanson folk de <strong>Philippe B</strong> résonne depuis plus de 20 ans sur notre scène musicale. Reconnu comme l’un de nos plus brillants auteurs-compositeurs-interprètes, l’artiste originaire d’Abitibi est de retour avec <strong><em>Cigale</em></strong>, un septième album sur lequel il plonge plus que jamais dans ses souvenirs. S’inspirant de sa jeunesse pour illustrer la réalité d’un musicien en début de carrière, Philippe B prouve encore une fois sa maîtrise de l’art de la chanson en abordant des thématiques universelles comme le temps qui passe, le rapport à l’âge et le développement de l’identité.</p>\n<p dir=\"ltr\">Si la finesse et l’ingéniosité de ses arrangements ont été maintes fois soulignées, c’est surtout pour la beauté de ses mélodies et l’intimité désarmante de ses textes que son œuvre continue de toucher autant de gens; même réduites à leur plus simple expression, les chansons de Philippe B témoignent d’une rare profondeur. C’est dans cette optique qu’il présentera ses nouvelles pièces comme ses classiques lors d’une série de spectacles intimes en 2026. Alternant entre la guitare acoustique et le piano, Philippe B, seul sur scène, nous invite à le redécouvrir sous un nouvel angle : plus brut et personnel, mais toujours aussi poignant. Une occasion que ses fans ne voudront certainement pas manquer.</p>"
      }
    ],
