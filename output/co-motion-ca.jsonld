  {
    "@id": "https://co-motion.ca/temporary/e7452fdd-baf7-45b8-aa5e-5abaff9e6e05",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/le-vent-du-nord-voisinages/"
      }
    ],
    "http://schema.org/image": [
