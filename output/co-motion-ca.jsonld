  {
    "@id": "https://co-motion.ca/temporary/1addada0-de2c-4302-b6f2-8cf6f57e1fe8",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mike-beaudoin-acharne/"
      }
    ],
    "http://schema.org/image": [
