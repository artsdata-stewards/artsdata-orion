  {
    "@id": "https://co-motion.ca/temporary/541b650e-daea-40ce-892e-82c38e915786",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mathieu-cyr-adulte/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1684880"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mathieu-cyr-adulte/"
      }
    ],
    "http://schema.org/startDate": [
      {
