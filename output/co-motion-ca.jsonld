      }
    ]
  },
  {
    "@id": "https://co-motion.ca/temporary/6a61e2a9-478e-42d7-865c-20bd82c4b11d",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mona-de-grenoble/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/c3e2a441566a190d"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mona-de-grenoble/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-27T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/2d06e7cbb66ab54d"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Humour"
      },
      {
        "@language": "fr",
        "@value": "Drag"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/1b9b509437cfb2d2"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/1c7f8cbf5822975d"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/mona-de-grenoble/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>J’aurais pu appeler ce show d’humour-là <em>Étalon en talons</em> ou <em>Entre Bâton Rouge et matante,</em> mais après j’ai désaoulé pis je me suis rendu compte que vous allez sûrement vous reconnaître dans mon personnage que certains décrivent comme étant “flamboyant, grivois et solvable depuis Big Brother”. Parce que, dans le fond, on le sait, les paillettes, les robes pis les grosses perruques c’est juste «de la poudre aux yeux».</p>\n<p></p>\n\n\n\n<p><a class=\"notice\">Suivre l'artiste<br /></a></p>\n<p><a href=\"https://www.instagram.com/monadegrenoble/?hl=fr\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Instagram</a> <a href=\"https://www.facebook.com/profile.php?id=100070401769309\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Facebook</a></p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "De la poudre aux yeux"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
