  {
    "@id": "https://co-motion.ca/temporary/3f3fd400-03b2-4972-a9b7-9e9f329f8e95",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mariana-mazza-foie-gras/"
      }
    ],
    "http://schema.org/image": [
