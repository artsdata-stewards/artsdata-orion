  {
    "@id": "https://co-motion.ca/temporary/23b9ff83-cbad-41e3-b286-8c92fa6c1795",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/bashir-lazhar-2026-2027/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/1813d6a979c81160"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/bashir-lazhar-2026-2027/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-25T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
