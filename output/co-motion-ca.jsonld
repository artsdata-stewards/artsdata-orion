  {
    "@id": "https://co-motion.ca/temporary/d4ce589e-ae24-447c-9a47-befe56db9e6a",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/jose-gaudet-nouveau-spectacle/"
      }
    ],
    "http://schema.org/image": [
