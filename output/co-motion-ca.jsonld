  {
    "@id": "https://co-motion.ca/spectacles/viviane-audet-le-piano-et-le-torrent/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le nouveau spectacle de Viviane Audet met en lumière son plus récent album instrumental, Le piano et le torrent — un récit pianistique de quinze pièces,…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Viviane-Audet.jpg?mtime=1765470864"
