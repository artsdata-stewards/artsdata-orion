  {
    "@id": "https://co-motion.ca/temporary/d3c7199d-891c-43d3-b4c5-fc6bdd9e304f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/diane-tell-ma-tournee-50-iaime-anniversaire/"
