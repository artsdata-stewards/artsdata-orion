  {
    "@id": "https://co-motion.ca/temporary/c6e5f9ce-996b-4d23-90cd-3c41d221eb67",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/richardson-zephir-punch-creole/"
