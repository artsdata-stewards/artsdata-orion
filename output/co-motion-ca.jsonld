  {
    "@id": "https://co-motion.ca/spectacles/mariana-mazza-foie-gras/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Pour son troisième spectacle, Foie Gras , Mariana Mazza décide de s’exprimer avec sa tête et son cœur… pour faire changement."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Mariana-Mazza.jpg?mtime=1728069886"
