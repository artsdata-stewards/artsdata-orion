  {
    "@id": "https://co-motion.ca/temporary/ca629dff-b712-402e-8ccf-3629bbe088c2",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/cathy-gauthier-humaine/"
      }
    ],
    "http://schema.org/image": [
