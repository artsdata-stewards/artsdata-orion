        "@id": "_:g3437560"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/bruno-pelletier-3-et-moi/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-11-06T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g3437580"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g3437620"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g3437640"
