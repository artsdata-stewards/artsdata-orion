  },
  {
    "@id": "https://co-motion.ca/temporary/c94a5b30-956b-4ceb-a8da-3705b7c5df2f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/josiane-aubuchon-en-promenade/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/c09535fdd060b450"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/josiane-aubuchon-en-promenade/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-09T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/9f2a1fd313c22e65"
      }
    ],
    "http://schema.org/offers": [
