  {
    "@id": "https://co-motion.ca/temporary/468677cd-4917-4abe-b8b9-370d3f2402fa",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/alain-choquette-entre-histoires-et-illusions/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2632080"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/alain-choquette-entre-histoires-et-illusions/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
