  {
    "@id": "https://co-motion.ca/spectacles/jean-michel-anctil-surprise-cest-ma-fete/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Jean-Michel Anctil est de retour. Après plusieurs années loin de la scène en solo, Jean-Michel revient avec un véritable spectacle événement placé sous le…"
      }
    ],
    "http://ogp.me/ns#image": [
