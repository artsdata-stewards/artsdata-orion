  {
    "@id": "https://co-motion.ca/temporary/ce3ab1c1-7fd1-4365-acb7-b65511d496b9",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/le-spectacle-des-finissant-e-s-de-danse-2026/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g988720"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/le-spectacle-des-finissant-e-s-de-danse-2026/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-08T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g988740"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g988780"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g988800"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/le-spectacle-des-finissant-e-s-de-danse-2026/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Cette soirée constitue l’épreuve-synthèse du DEC en danse et comportera des pièces issues des 3 volets du programme : la technique, la création et l’interprétation. </p>\n<p>Au Programme : </p><ul><li>Deux pièces chorégraphiques d'Amélie Rajotte, créées dans le cadre du cours technique <em>Danse contemporaine IV</em> </li><li>Deux courtes créations collectives, élaborées par les finissant·es du cours de <em>Création III</em>, sous la direction de Chantal Lamirande; · </li><li>Un duo poétique créé par Sophie Lavigne </li><li>Une pièce chorégraphique de Chantal Lamirande <em>La chose</em>, ainsi qu'une pièce de Pierre-Marc Ouellette, <em>Rencontres captivantes</em>, toutes deux conçues en collaboration avec les étudiant·es-interprètes des<em> cours d’Interprétation I et II</em></li></ul>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Le Spectacle des finissant·es 2026"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Danse"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
