  {
    "@id": "https://co-motion.ca/spectacles/mommy-le-retour/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Durée : 1 h 40, sans entracte L'ACTIVITÉ et Centre du Théâtre d'Aujourd'hui Une satire politique aux allures d’opéra-rock. « C’est avec un plaisir effaré…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/MDA/Grand-public-2026/_1200x630_crop_center-center_82_none/1-Mommy-le-retour.jpg?mtime=1777592388"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
