    "@id": "https://co-motion.ca/spectacles/skltr/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Durée : 60 minutes SKLTR (« skul-tur ») est une pièce de groupe Krump cocréée et initiée par Charles « Broken » Brecard , chorégraphe montréalais de danse…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/MDA/Grand-public-2026/_1200x630_crop_center-center_82_none/SKULTR.jpg?mtime=1777592399"
