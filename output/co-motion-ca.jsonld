  {
    "@id": "https://co-motion.ca/temporary/8dfdd4a9-8c39-473f-bc3a-c0a2caa7a3f3",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/marie-annick-lepine---le-coeur-est-un-reveur/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/d9545bb453b8a9ae"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/marie-annick-lepine---le-coeur-est-un-reveur/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-30T19:30:00-04:00"
      }
