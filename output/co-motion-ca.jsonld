  {
    "@id": "https://co-motion.ca/temporary/650accd9-cba7-4092-83fa-8acca78c2664",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/la-fanfare-fanfaronne/"
      }
    ],
    "http://schema.org/image": [
      {
