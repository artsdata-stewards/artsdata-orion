  {
    "@id": "https://co-motion.ca/temporary/9beb0daf-5050-4225-8f12-e5bddd0721cf",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mathieu-cyr-adulte/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1100800"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mathieu-cyr-adulte/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-11T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1100820"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1100860"
