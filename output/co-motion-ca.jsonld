  {
    "@id": "https://co-motion.ca/temporary/5f9bb1a6-9fbd-4c71-b803-d715d7b2c89e",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/ladies-night-2025/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2136540"
      }
    ],
    "http://schema.org/url": [
      {
