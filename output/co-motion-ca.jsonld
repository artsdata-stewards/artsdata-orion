  {
    "@id": "https://co-motion.ca/temporary/3ed1c390-6a5d-46f6-847f-7e390f54c444",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/geoffroy-nouveau-spectacle/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/17f5fb3a590139b4"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/geoffroy-nouveau-spectacle/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
