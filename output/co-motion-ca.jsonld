  {
    "@id": "https://co-motion.ca/temporary/774cc1b8-9c74-4d95-aee8-659e2849e60a",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/le-livre-magique/"
      }
    ],
