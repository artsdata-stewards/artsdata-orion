  {
    "@id": "https://co-motion.ca/temporary/3ec50094-bc2c-4126-bdb0-6fcdde4355fd",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/hommes-de-pioche-renee-robitaille/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/4134ac5a688eef21"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/hommes-de-pioche-renee-robitaille/"
      }
    ],
    "http://schema.org/startDate": [
