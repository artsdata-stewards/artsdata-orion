        "@id": "https://co-motion.ca/spectacles/alain-choquette-entre-histoires-et-illusions/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2593980"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/alain-choquette-entre-histoires-et-illusions/"
      }
    ],
