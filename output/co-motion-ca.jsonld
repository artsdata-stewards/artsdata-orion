  {
    "@id": "https://co-motion.ca/spectacles/quest-quon-a-fait-au-bon-dieu/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "» Alain Bouchard, un fier Québécois, a toujours élevé ses filles dans un esprit de tolérance et d’ouverture. Alain y voit une dernière chance de présenter…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Quest-ce-quOn-a-fait-au-bon-dieu.jpg?mtime=1768338397"
