  {
    "@id": "https://co-motion.ca/temporary/77f1eb1d-c037-47f3-8bcf-825d210c1424",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/eric-lapointe-30-ans-dobsession/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1660680"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/eric-lapointe-30-ans-dobsession/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-29T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1660700"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1660740"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g1660760"
