        "@id": "https://co-motion.ca/genid/61915feedb532dc3"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mariana-mazza-foie-gras/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
