    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/betes-de-fete/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><sup>Les Incomplètes</sup></p>\n<p><em>Bêtes de fêt</em>e c’est LE bal costumé de l’année ! Une invitation, spécialement dédiée aux enfants, petits et grands, à venir tout donner sur la piste de danse, vêtu.es des atours les plus loufoques ! Arborant des motifs animaliers, des ponchos fluos et moult paillettes, dénichés dans notre costumier, les fêtards sont invité.es à laisser surgir leur animal intérieur et à se trémousser au son endiablé des platines d’un électrisant DJ. Afro-beat, électro-cumbia, musique moyen-orientale électrisée, hip-hop déjanté… Des rythmes joyeux qui entraîneront les corps dans une danse euphorique! <sup><br /></sup></p>\n<p>Durée : 75 minutes</p>\n<p><a href=\"https://lesincompletes.com\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Site Internet</a> <a href=\"https://www.facebook.com/lesincompletes\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Facebook</a> <a href=\"%3A%20https%3A//www.instagram.com/les_incompletes/\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Instagram</a><br /></p>"
      }
    ],
