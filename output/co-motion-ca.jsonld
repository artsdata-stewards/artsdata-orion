  {
    "@id": "https://co-motion.ca/temporary/15ad9ae5-350e-4cdc-803e-69c30299dc46",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/racontars-arctiques/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/494ede5d1685f5ce"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/racontars-arctiques/"
