  {
    "@id": "https://co-motion.ca/temporary/b5eb5085-1dbc-4a44-b9dc-15bfdb46e6aa",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/matt-lang-aint-that-bad/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2827220"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/matt-lang-aint-that-bad/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-02-25T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
