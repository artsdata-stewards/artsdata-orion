        "@value": "fr_ca"
      }
    ]
  },
  {
    "@id": "https://co-motion.ca/temporary/1d3948b0-01a1-4917-8441-96ced7fdc492",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mommy-le-retour/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/7e13670cb6bef388"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mommy-le-retour/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-05T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/17b0bf9e8c2a07c8"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/590078eea37ec215"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/58d9380280de109e"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/mommy-le-retour/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><sup>Durée : 1 h 40, sans entracte<br /></sup><sup>L'ACTIVITÉ et Centre du Théâtre d'Aujourd'hui</sup><sup><br /><br /></sup>Une satire politique aux allures d’opéra-rock.</p>\n\n<p>Ressuscitée d’entre les morts, Mommy revient hanter le Québec pour se venger des vivants. Horrifiée par le monde actuel, cette grand-mère morte-vivante rêve de le ramener dans le droit chemin en restaurant sa grandeur passée. Pour y parvenir, elle transforme ses opposants idéologiques en zombies, les enrôlant dans un projet de société proprement fasciste. Tour à tour martyre, tyran et <em>pop star</em>, Mommy se métamorphose pour séduire les foules et prendre le pouvoir.</p>\n<p>Dans cette satire politique aux allures d’opéra-rock, Olivier Choinière détourne les codes du théâtre et du rap pour mettre en lumière la montée des mouvements réactionnaires qui essaiment un peu partout sur la planète. Mêlant <em>lip sync</em>, chansons originales, danse, effets spéciaux <em>gore</em> et une généreuse dose de faux sang, la pièce entraîne le public dans un univers où les morts-vivants scandent leurs revendications, guidés par un DJ à l’aura messianique. Jouissif, irrévérencieux et furieusement actuel, <em>Mommy, le retour</em> est un exutoire théâtral aussi délirant que dérangeant.</p>\n<p>« C’est avec un plaisir effaré qu’on découvre cette création aussi grotesque que critique, qui emprunte à la satire politique, au récit de zombies (effets spéciaux hilarants), au <em>show</em> hip-hop, voire au conte de Disney. » – Marie Labrecque, <em>Le Devoir</em></p>\n<p>Spectacle présenté en collaboration avec Les Voyagements – Théâtre de création en tournée.</p>\n<p><strong><em>Pour vous! Une rencontre en bord de scène avec les artistes suivra la représentation.</em></strong></p>\n<p><strong>Profitez de votre venue pour visiter les expositions de <a href=\"https://www.laval.ca/culture/maison-des-arts/expositions-salle-alfred-pellan/\" target=\"_blank\" rel=\"noreferrer noopener\">l’espace muséal Alfred-Pellan.</a><br /></strong></p>\n<p><a href=\"http://www.laval.ca/diffusart\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Diffusart</a><sub><br /></sub></p>\n<p><sub>Suivre l'artiste<a href=\"https://www.lactivite.com\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\"><br />Site web</a>  <a href=\"https://fr-fr.facebook.com/Lactivitetheatre\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Facebook</a></sub></p>"
      }
    ],
