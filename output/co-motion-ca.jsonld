  {
    "@id": "https://co-motion.ca/spectacles/william-cloutier-lamour/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Entre la folle aventure Mixmania et sa performance mémorable dans Starmania , 10 ans plus tard, ce qui est sûr, c’est que le gagnant de Star Académie 2021…"
      }
    ],
