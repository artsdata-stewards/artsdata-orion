  {
    "@id": "https://co-motion.ca/temporary/3f29dd9c-caf1-42bd-bdd7-9cb3465640c9",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/la-fanfare-fanfaronne/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/9efd9e695d2212f5"
      }
    ],
    "http://schema.org/url": [
      {
