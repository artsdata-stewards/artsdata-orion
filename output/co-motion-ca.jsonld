  {
    "@id": "https://co-motion.ca/temporary/1d09f2c3-1fc8-4495-b2fa-57afd6061c49",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mike-beaudoin-acharne/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2152700"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/mike-beaudoin-acharne/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-06T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2152720"
