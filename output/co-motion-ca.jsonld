  {
    "@id": "https://co-motion.ca/spectacles/christian-marc-gendron-trilogie/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après le succès phénoménal de la série de concerts  PianoMan , qui a rassemblé plus de 150 000 spectateurs à travers le Québec au cours des dernières…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Christian-marc-Gendron-2.jpg?mtime=1760118678"
      }
    ],
