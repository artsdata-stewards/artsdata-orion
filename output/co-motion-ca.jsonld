  {
    "@id": "https://co-motion.ca/temporary/4221e695-f682-4fb5-bc05-2fdf5fcccf2b",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/betes-de-fete/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1105240"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/betes-de-fete/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-10T10:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1105260"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1105300"
      }
    ],
    "http://schema.org/performer": [
