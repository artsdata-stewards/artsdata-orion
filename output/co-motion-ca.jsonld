      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/skltr/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><sup>Durée : 60 minutes</sup></p>\n<p><em>SKLTR</em> (« skul-tur ») est une pièce de groupe Krump cocréée et initiée par <strong>Charles « Broken » Brecard</strong>, chorégraphe montréalais de danse contemporaine et <strong>Vladimir « 7Starr » Laurore</strong>, pionnier du Krump canadien et cofondateur du Montreal Krump Alliance (MKA). Conçue pour innover et transcender tout autant l’artistique que le communautaire, la pièce marie les approches « Fluidify » et « 7Skopez », pour développer une nouvelle signature gestuelle oscillant entre chaos et ordre, douceur et agressivité, fluidité et précision, retenue et catharsis.</p>\n<p>Spectacle présenté avec la collaboration de La danse sur les routes du Québec.</p>\n<p><strong><em>Pour vous! Une rencontre en bord de scène avec les artistes suivra la représentation.</em></strong></p>\n<p>Profitez de votre venue pour visiter les expositions de <a href=\"https://www.laval.ca/culture/maison-des-arts/expositions-salle-alfred-pellan/\" target=\"_blank\" rel=\"noreferrer noopener\">l’Espace muséal Alfred-Pellan.</a><strong><em><br /></em></strong></p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
