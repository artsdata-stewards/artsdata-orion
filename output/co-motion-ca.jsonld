  {
    "@id": "https://co-motion.ca/temporary/ae8efa92-cf00-4ebe-bb52-ebcb28332283",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/les-grands-explorateurs-italie/"
      }
    ],
    "http://schema.org/image": [
