  },
  {
    "@id": "https://co-motion.ca/spectacles/francois-bellefeuille-sauvage/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Hilarant, incisif et imprévisible, il livre une performance de stand-up à la fois intelligente et éclatée, repoussant les limites de son style inimitable."
      }
    ],
    "http://ogp.me/ns#image": [
