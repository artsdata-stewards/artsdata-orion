    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Rencontre avec Lyne Lefort Le Panama est l’un des 7 pays d’Amérique centrale. Des rutilants gratte-ciels de la capitale Panama City aux communautés…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
