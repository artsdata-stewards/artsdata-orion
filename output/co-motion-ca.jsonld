    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/52b1e9036c2e6b32"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/0313b0be56b724c9"
      }
    ],
    "http://schema.org/organizer": [
