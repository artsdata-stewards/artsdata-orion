      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Musique"
      },
      {
        "@language": "fr",
        "@value": "Jeune public"
      },
      {
        "@language": "fr",
        "@value": "Spectacle de Noël"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2454460"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g2454480"
