  {
    "@id": "https://co-motion.ca/spectacles/josiane-aubuchon-en-promenade/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Après trois ans en résidence mensuelle à Montréal, Josiane Aubuchon part en promenade à travers la province!"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Josiane-Aubuchon-2.jpg?mtime=1776970473"
