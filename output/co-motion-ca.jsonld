  {
    "@id": "https://co-motion.ca/temporary/b3b7e60b-dd2e-499e-bcf6-ee85345e1d15",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/barka/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/f322bfbf352f7dd9"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/barka/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-09T15:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/17b0bf9e8c2a07c8"
