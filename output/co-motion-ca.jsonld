      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/6be35a89fe34ec9e"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/6cdb4a84f2045a20"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/daniel-grenier-coeur-denfant/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Garder son <strong>CŒUR D'ENFANT</strong>, c’est refuser de laisser la vie user notre émerveillement. <br />C’est continuer à s’étonner devant les petites choses : un coucher de soleil, <strong>un rire sincère</strong>, une chanson qu’on aime. <br />C’est savoir s’émerveiller sans cynisme, rêver sans calcul, aimer sans attendre en retour. </p>\n<p>C’est aussi garder une certaine <strong>légèreté</strong>, la capacité de rire de soi, de jouer, d’être curieux, d’apprendre sans honte. </p>\n<p>Ce n’est pas être naïf, mais choisir de <strong>rester sensible et ouvert</strong>, même quand le monde devient dur ou compliqué. </p>\n<p>Avoir un <strong>CŒUR D'ENFANT</strong>, c’est croire qu’il y a encore du beau, même dans le chaos. </p>\n<p>C’est se souvenir que la joie n’est pas un luxe, mais un instinct qu’on peut nourrir chaque jour. </p>\n<p>Procurez-vous vos billets pour le nouveau spectacle de Daniel Grenier et laisser votre <strong>CŒUR D’ENFANT</strong> prendre toute la place. </p>"
      }
    ],
