  {
    "@id": "https://co-motion.ca/temporary/412bb68a-1d3b-48ba-94d9-9f662e172b4e",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/le-fantome-dans-la-machine/"
      }
    ],
    "http://schema.org/image": [
