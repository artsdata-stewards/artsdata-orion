  {
    "@id": "https://co-motion.ca/temporary/2e99306f-7f9a-4e17-b0fa-7d0a26f4368b",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/stefie-shock-un-stefie-shock-sur-scene/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/06e58ce82c4d89b6"
      }
    ],
    "http://schema.org/url": [
      {
