  {
    "@id": "https://co-motion.ca/spectacles/diane-tell-ma-tournee-50-iaime-anniversaire/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Chez Bonsound, notre belle maison de concerts, quelqu’un a lancé l’idée : « Diane, ça te dirait de faire une tournée anniversaire ?» Je n’ai pas dit oui…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Diane-Tell.jpg?mtime=1757864881"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
