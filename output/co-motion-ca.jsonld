        "@id": "https://co-motion.ca/genid/94a8adc56b233e32"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/pascal-cameron-nouveau-spectacle/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
