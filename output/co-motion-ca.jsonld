  {
    "@id": "https://co-motion.ca/temporary/7a37da44-1f33-4569-8b83-04512b5b4ab2",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/dominic-paquet-nouveau-spectacle/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1796300"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/dominic-paquet-nouveau-spectacle/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-25T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1796320"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1796360"
