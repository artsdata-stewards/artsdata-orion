  {
    "@id": "https://co-motion.ca/temporary/980d4941-3667-40ff-b6d5-7832c3d47279",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/neige-sur-abidjan/"
      }
    ],
    "http://schema.org/image": [
