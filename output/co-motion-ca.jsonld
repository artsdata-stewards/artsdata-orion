        "@value": "Jeune public"
      },
      {
        "@language": "fr",
        "@value": "Danse"
      },
      {
        "@language": "fr",
        "@value": "Théâtre"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/27e70f64544fe769"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/a18ef8537157bd7e"
      }
    ],
    "http://schema.org/organizer": [
