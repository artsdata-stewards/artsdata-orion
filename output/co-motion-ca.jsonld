  {
    "@id": "https://co-motion.ca/temporary/a682fa8d-6bb4-48de-bb52-2f620e68a4b4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/maude-landry-trop-cool/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1019820"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/maude-landry-trop-cool/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-03T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1019840"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1019880"
