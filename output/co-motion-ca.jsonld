  {
    "@id": "https://co-motion.ca/temporary/3e5eaa18-9a56-4696-91ea-21b57ed84126",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/mona-de-grenoble/"
      }
    ],
