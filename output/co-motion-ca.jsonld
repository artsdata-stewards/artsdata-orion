  {
    "@id": "https://co-motion.ca/spectacles/18-practices/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Coproduction Danse-Cité et Andrew Turner Durée : 60 minutes Ce solo interdisciplinaire de danse est inspiré d’une traduction récente de l’ Odyssée…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/MDA/Grand-public-2026/_1200x630_crop_center-center_82_none/18-Practices.jpg?mtime=1777592389"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
    "http://ogp.me/ns#locale": [
