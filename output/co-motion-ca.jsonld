    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/lecole-montessori-dhier-a-aujourdhui/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>À l’occasion de son 20e anniversaire, l’École Montessori International Blainville vous invite à un spectacle de danse rempli d’émotions, de souvenirs et de nostalgie.</p>\n<p>À travers différentes chorégraphies, nos élèves vous feront voyager dans le temps, revisitant de précieux moments et célébrant la mémoire de ces 20 belles années. Chaque numéro est le reflet du chemin parcouru, des expériences vécues et des souvenirs qui ont marqué notre école.</p>\n<p>Venez les encourager et partager avec nous cette célébration unique, où passé et présent se rencontrent sur scène.</p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "D'Hier à Aujourd'hui 2006-2026"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Danse"
      }
    ],
