      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/de16340621d03227"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/32feff2927682ebd"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/adib-alkhalidey-comme-les-mongols-a-baghdad/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Après <em>Québécois Tabarnak </em>et <em>Des putes et des voleurs </em>— tous deux gagnants du prix Spectacle d’humour de l’année au Gala de l’ADISQ, une première deux années de suite en 45 ans — Adib Alkhalidey revient avec <em>Comme les Mongols à </em>Baghdad. <br /> <br />Dans ce nouveau spectacle, il est question de transmission. Transmission du sens, du savoir, des blessures, des peurs, des contradictions et des élans qui traversent une époque ayant parfois l’impression d’avoir perdu confiance en sa propre capacité à transmettre quoi que ce soit. <br /> <br />À l’image de sa pensée arborescente, le spectacle se déploie à travers des thèmes aussi variés que la fraude fiscale, la corruption politique, l’enfer d’endormir des enfants, la Maison de la sagesse de Baghdad, Jésus ou encore la réalité des familles mixtes. En se frottant aux sujets les plus sensibles, intimes ou tabous de notre époque, Adib Alkhalidey cherche moins à donner des réponses qu’à révéler ce qui apparaît lorsqu’on ose regarder certaines vérités en face. Porté par une liberté de ton rare — probablement amplifiée par le manque de sommeil et l’honnêteté douteuse des jeunes parents épuisés —, le spectacle finit par transformer ce chaos en quelque chose d’étrangement limpide, comme si toutes ces branches dispersées provenaient secrètement du même arbre. <br /> <br /><em>Comme les Mongols à </em>Baghdad est un spectacle profondément drôle, parfois brutal, parfois inquiet, mais toujours porté par une volonté sincère de rapprocher ce que l’époque s’acharne à séparer.</p>"
      }
    ],
