  {
    "@id": "https://co-motion.ca/temporary/99708ea9-e6cd-4804-90a0-5570c1a6ae61",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/pierre-verville-pour-une-derniere-voix/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/738acf40e1529301"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/pierre-verville-pour-une-derniere-voix/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-26T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
