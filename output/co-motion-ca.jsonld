  {
    "@id": "https://co-motion.ca/spectacles/les-grands-explorateurs-albanie/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Découvrir l’Albanie, c’est explorer un pays à la nature spectaculaire, à l’histoire complexe et à l’identité forte."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Les-Grands-Explorateurs/2027-2027/_1200x630_crop_center-center_82_none/LGE_2627_Albanie_756x1100.jpg?mtime=1779371120"
