  {
    "@id": "https://co-motion.ca/temporary/4dd04e80-45ba-48a8-962b-534cef2124c4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/dans-lunivers-dastor/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/7a4314bc206aeb34"
      }
    ],
    "http://schema.org/url": [
      {
