  {
    "@id": "https://co-motion.ca/spectacles/neige-sur-abidjan/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Iannicko N’Doua, alors étudiant en théâtre, débarque en Côte d’Ivoire. Iannicko N’Doua signe ici son premier texte mis en scène par son complice de longue…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
