  {
    "@id": "https://co-motion.ca/spectacles/bruno-pelletier-3-et-moi/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Entouré de trois musiciens talentueux, Bruno Pelletier propose une interprétation dépouillée de ses plus grands succès et de chansons coups de cœur,…"
      }
    ],
    "http://ogp.me/ns#image": [
