    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Les élèves et les enseignantes du département de musique du Collège Laval sont fiers de vous présenter les Grands Concerts de musique de fin d'année, qui sont le fruit de plusieurs mois de travail. Venez encourager les élèves de 2e et 4e secondaire le 20 mai. Soyez éblouis par les élèves de 1ère, 3e et 5e secondaire le 21 mai.</p>"
      }
    ],
