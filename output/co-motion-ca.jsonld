  {
    "@id": "https://co-motion.ca/temporary/6708c37e-3383-4b93-a235-a38733edacba",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/guylaine-tanguay-i-love-rockroll/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1849160"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/guylaine-tanguay-i-love-rockroll/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-09-30T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1849180"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g1849220"
      }
    ],
    "http://schema.org/performer": [
