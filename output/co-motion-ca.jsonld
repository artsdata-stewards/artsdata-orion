      }
    ]
  },
  {
    "@id": "https://co-motion.ca/temporary/87f1ee9e-836a-4b8e-8fb7-7eb97bcf1dde",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/18-practices/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/ff2c36edeb1cbdee"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/18-practices/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-08T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/17b0bf9e8c2a07c8"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/b65d55921abafaa4"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/1944377b5d8ddf5a"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/18-practices/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><strong><sup><a href=\"https://andrewturner.dance\" target=\"_blank\" rel=\"noreferrer noopener\">Coproduction Danse-Cité et Andrew Turner</a><br />Durée : 60 minutes</sup></strong></p>\n<p>Ce solo interdisciplinaire de danse est inspiré d’une traduction récente de l’<em>Odyssée</em> d’Homère, par Emily Wilson (2017) – la première version rédigée par une femme érudite, acclamée pour sa perspective critique contemporaine sur ce mythe fondateur.</p>\n<p>À partir de ce mythe, Andrew Turner explore avec un humour absurde et lucide 18 pratiques aux textures variées — mouvement, parole, chant à l’envers, filage au sabre laser, entre autres. La pièce dépoussière les traces complexes et superposées des récits et des comportements qui existent sous le « je » apparemment stable ainsi que les influences culturelles dominantes qui forgent insidieusement notre identité.</p>\n<p>Spectacle présenté en collaboration avec <strong>La danse sur les routes du Québec. </strong><br /><br />Pour vous! Une rencontre en bord de scène avec les artistes suivra la représentation.<strong><em><br /></em></strong></p>\n<p>Profitez de votre venue pour visiter les expositions de <a href=\"https://www.laval.ca/culture/maison-des-arts/expositions-salle-alfred-pellan/\" target=\"_blank\" rel=\"noreferrer noopener\">l’Espace muséal Alfred-Pellan.</a></p>\n<p><strong><em></em></strong><a href=\"http://www.laval.ca/diffusart\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Diffusart</a><br /><br /></p>"
      }
    ],
    "http://schema.org/inLanguage": [
