  {
    "@id": "https://co-motion.ca/spectacles/le-duplex/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Cette pièce de Didier Caron, portée par les excellents comédiens Pascale Desrochers, Sylvain Marcel, Valérie Blais et François Massicotte, promet une…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Le-duplex-2.jpg?mtime=1776629873"
      }
    ],
    "http://ogp.me/ns#type": [
