  {
    "@id": "https://co-motion.ca/spectacles/mehdi-bousaidan-le-garcon-et-la-fenetre/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "C’est un Mehdi qu’on reconnaît, certes, de son sens critique aiguisé, de ses analyses inhabituelles et de ses punchs inattendus, mais c’est aussi un Mehdi…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
