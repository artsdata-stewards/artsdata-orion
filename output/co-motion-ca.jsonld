  {
    "@id": "https://co-motion.ca/temporary/2156916b-d689-4068-aeee-daf193e4041a",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/petits-bonheurs-atelier-sous-la-canopee/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g956260"
      }
    ],
    "http://schema.org/url": [
