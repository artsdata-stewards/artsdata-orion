  {
    "@id": "https://co-motion.ca/temporary/e2297cdb-2a45-4ebc-9307-6e421e8dc528",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2454400"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
