  },
  {
    "@id": "https://co-motion.ca/temporary/98323f8d-69f8-4775-bcbf-91a621056714",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/viviane-audet-le-piano-et-le-torrent/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1423420"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/viviane-audet-le-piano-et-le-torrent/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-09T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
