  {
    "@id": "https://co-motion.ca/temporary/b2df46de-8f79-4867-9243-56087b2c1d99",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/boulevard-perusse/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/1a9b4423c716344a"
      }
    ],
    "http://schema.org/url": [
