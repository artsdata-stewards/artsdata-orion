  {
    "@id": "https://co-motion.ca/temporary/c07214b2-9ecf-4281-9be9-0f70f834ad2e",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/9f8a2e824e0bfc47"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-12T15:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
