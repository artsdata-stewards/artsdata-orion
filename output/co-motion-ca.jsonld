  {
    "@id": "https://co-motion.ca/temporary/d4859406-ab72-434d-8218-2fa736f3c068",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/jf-pauze/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/2cbb8da88bbcee4f"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/jf-pauze/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-19T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/2d06e7cbb66ab54d"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/ced647b7b970a028"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/3e16ca35b6e82955"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
