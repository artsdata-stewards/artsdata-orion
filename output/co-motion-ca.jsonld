        "@language": "fr",
        "@value": "Fack, va pas me citer comme preuve quand tu t'obstines avec du monde «Pascal Cameron a dit ça l'autre jour »."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Pascal-Cameron.jpg?mtime=1741719192"
      }
    ],
