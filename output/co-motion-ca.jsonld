  {
    "@id": "https://co-motion.ca/spectacles/les-grands-explorateurs-maroc/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Voyage libre et inspiré, c'est à bord de son van aménagé que Marc nous fait découvrir \"son\" Maroc depuis Tanger jusqu'à Dakhla, dans l'extrême sud du pays."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Les-Grands-Explorateurs/2025-2026/_1200x630_crop_center-center_82_none/LGE_2526_Maroc_756x1100.jpg?mtime=1748446848"
      }
    ],
    "http://ogp.me/ns#type": [
