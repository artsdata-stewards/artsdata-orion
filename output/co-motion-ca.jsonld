        "@id": "https://co-motion.ca/genid/b6fcc3c43c6810ee"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/patrice-lecuyer/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
