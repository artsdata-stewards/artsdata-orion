  {
    "@id": "https://co-motion.ca/temporary/630c6a06-0eb2-4fcf-9825-a90ae80ad4a6",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/us-pink-floyd-experience/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g625000"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/us-pink-floyd-experience/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
