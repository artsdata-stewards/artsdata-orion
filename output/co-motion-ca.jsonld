  {
    "@id": "https://co-motion.ca/temporary/9c2e0767-6f38-4e2e-90eb-26dbf3282ab3",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/michel-rivard-apres-on-va-ou/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g1645940"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/michel-rivard-apres-on-va-ou/"
      }
    ],
    "http://schema.org/startDate": [
