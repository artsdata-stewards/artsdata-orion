  },
  {
    "@id": "https://co-motion.ca/temporary/4272f134-37bf-4ff0-be0b-a7cc5522f680",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/la-cumbia-less-toches/"
      }
    ],
