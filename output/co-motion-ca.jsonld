        "@value": "On s'lâche pas"
      }
    ]
  },
  {
    "@id": "https://co-motion.ca/spectacles/on-slache-pas/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Mise en scène Anne Dorval Texte Hubert Proulx Avec Hubert Proulx et Viktor Proulx On s’lâche pas! Une famille tissée serrée… « On s’lâche pas, c’est…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/on-slache-pas.jpg?mtime=1776781905"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr",
        "@value": "website"
      }
    ],
    "http://ogp.me/ns#locale": [
      {
