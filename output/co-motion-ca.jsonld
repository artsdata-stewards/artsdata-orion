      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/1eee7f4b3e43d505"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://co-motion.ca/genid/5187edf12ce47ea2"
