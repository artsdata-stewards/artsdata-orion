  {
    "@id": "https://co-motion.ca/temporary/071a42f8-de1f-4d6e-9f77-9cc2df3bc3eb",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/pour-une-autre-histoire-dun-soir/"
      }
    ],
    "http://schema.org/image": [
