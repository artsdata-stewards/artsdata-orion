    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/la-troupe-unik-en-spectacle-2026/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Présenté par <strong>Le Groupe Arcantia</strong>, ce spectacle vocal en mouvement vous invite à découvrir la <strong>Troupe Unik</strong> à travers des harmonies puissantes, des mises en scène vibrantes et une énergie contagieuse. Laissez-vous surprendre et emporter dans un voyage riche en émotions.</p>\n\n<p><strong>UNIK</strong> vous promet une expérience touchante et électrisante où chaque note raconte une histoire et chaque instant résonne longtemps après le dernier accord.</p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
