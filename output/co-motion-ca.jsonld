  {
    "@id": "https://co-motion.ca/temporary/7bf49033-105a-406e-a99a-f3949cf9b125",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/confession/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/bad8bd55ba4c0607"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/confession/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-02-03T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
