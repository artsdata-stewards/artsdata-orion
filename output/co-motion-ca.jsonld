  {
    "@id": "https://co-motion.ca/temporary/5782df7e-0c04-42b0-b30f-02c55c5a95d1",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/eric-lapointe-30-ans-dobsession/"
      }
    ],
    "http://schema.org/image": [
