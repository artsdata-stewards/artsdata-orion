      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/scoooootch/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-05-15T11:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
