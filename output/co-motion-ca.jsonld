  {
    "@id": "https://co-motion.ca/temporary/45eab2bf-0cb5-47b9-88e0-e1af9efd1738",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/josiane-aubuchon-en-promenade/"
      }
    ],
    "http://schema.org/image": [
