  {
    "@id": "https://co-motion.ca/temporary/85d43cfb-e9ed-4339-b872-5a63102c7a0f",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/petits-bonheurs-gzaagiin-malenki/"
      }
