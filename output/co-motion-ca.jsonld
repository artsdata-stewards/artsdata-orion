      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2467740"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2467780"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "_:g2467800"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/megan-brouillard-chiendent/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Le chiendent, c’est subjectif. La mauvaise herbe, c’est quelque chose qui pousse là où toi, tu ne voulais pas. Ce qui est du chiendent pour l’un ne l’est peut-être pas pour l’autre et ce qui est du chiendent quelque part, ne l’est pas ailleurs… Mon spectacle tourne autour de cette perspective, des différentes perceptions de chacun et chacune et autour de mes propres perceptions. </p>\n\n<p>Le premier one-woman-show de Mégan Brouillard est un spectacle mordant et authentique, où Mégan présente elle et les siens, sans filtre et toujours de façon hilarante!</p>"
      }
    ],
