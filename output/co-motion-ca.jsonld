    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Jean-Pierre Ferland , icône de la chanson québécoise, restera à jamais Le Petit Roi pour tous ceux et celles qui ont eu la chance d’entendre, de ressentir…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
