        "@value": "Le Père Nicolas Noël vous invite à vivre un tout nouveau spectacle musicale festif en compagnie de ses fidèles lutins, Pamalin et Trémaline !"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
