    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/la-troupe-fantasia-lodyssee-du-demi-siecle/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>L’Odyssée du demi-siècle est une comédie musicale événement qui traverse onze comédies musicales originales créées par la <strong>Troupe Fantasia</strong> au fil des années.</p>\n\n<p>À travers une histoire inédite, le spectacle revisite les univers, les personnages et les grandes chansons qui ont marqué le parcours artistique de la troupe. Entre souvenirs, passion, amour et transmission, cette création célèbre un demi-siècle d’émotions sur scène.</p>\n\n<p>Le spectacle mêle tableaux emblématiques, nouvelles scènes, réinterprétations musicales et moments d’intense émotion</p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
