  {
    "@id": "https://co-motion.ca/spectacles/major-moran-bunker-a-ciel-ouvert/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Pour la première fois, avec ce projet, ils mettent tout ce qui les habite dans un album et un spectacle intitulés Bunker à ciel ouvert."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
