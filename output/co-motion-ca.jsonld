  {
    "@id": "https://co-motion.ca/temporary/561cadd9-9789-43ec-9226-3485e1c5bbbc",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/opera-bouffe-du-quebec-orphee-aux-enfers/"
      }
    ],
    "http://schema.org/image": [
