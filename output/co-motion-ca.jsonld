  {
    "@id": "https://co-motion.ca/temporary/7fd398c3-11f2-415f-9192-d357023657bf",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/panorama-historique-du-theatre-quebecois/"
      }
    ],
