  {
    "@id": "https://co-motion.ca/spectacles/maude-landry-trop-cool/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Dans un monde où il faut se démarquer tout en suivant les tendances, Maude Landry se demande pourquoi elle n’a jamais fait partie de la gang des cools."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Maude-Landry.jpg?mtime=1756933116"
