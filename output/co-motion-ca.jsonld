        "@language": "fr",
        "@value": "Mais voilà que son frère lui apparaît de nouveau dans d’autres lieux improbables pour prendre de ses nouvelles, poursuivre une conversation laissée en…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Le-fantôme-dans-la-machine.jpg?mtime=1776639318"
