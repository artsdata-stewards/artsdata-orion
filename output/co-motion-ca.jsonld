  {
    "@id": "https://co-motion.ca/temporary/30f5ba35-69f4-46b5-b977-1b5025d19c27",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/skltr/"
      }
    ],
    "http://schema.org/image": [
      {
