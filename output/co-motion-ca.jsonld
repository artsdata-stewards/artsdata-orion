  {
    "@id": "https://co-motion.ca/temporary/d5b9e62b-900f-4879-a469-a7c9d8cd0174",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/dans-lunivers-dastor/"
      }
    ],
    "http://schema.org/image": [
