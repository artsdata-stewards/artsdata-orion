  {
    "@id": "https://co-motion.ca/temporary/367462aa-3315-490c-b5eb-657b0c7e5c9b",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/luc-langevin-lillusionniste/"
      }
    ],
