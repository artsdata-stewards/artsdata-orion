  {
    "@id": "https://co-motion.ca/temporary/bf5cfa2f-6038-400c-859f-50f14fe4b7ad",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/megan-brouillard-chiendent/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2467720"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/megan-brouillard-chiendent/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
