        "@id": "https://co-motion.ca/spectacles/luc-langevin-lillusionniste/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "_:g2501700"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/luc-langevin-lillusionniste/"
      }
    ],
    "http://schema.org/startDate": [
