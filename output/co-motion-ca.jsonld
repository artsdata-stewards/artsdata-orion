  {
    "@id": "https://co-motion.ca/spectacles/megan-brouillard-chiendent/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Le chiendent, c’est subjectif. La mauvaise herbe, c’est quelque chose qui pousse là où toi, tu ne voulais pas. Ce qui est du chiendent pour l’un ne l’est…"
      }
    ],
