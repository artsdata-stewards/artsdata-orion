    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/nouveaux-visages-juste-pour-rire-la-tournee/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p><em>Nouveaux visages Juste pour rire – La tournée</em> met en scène quatre humoristes émergents soigneusement sélectionnés à travers la francophonie par les dépisteuses et dépisteurs professionnels de Juste pour rire.  </p>\n<p>Adapté des légendaires <em>New Faces</em> de Just For Laughs, qui ont révélé les plus grandes vedettes de l’humour anglophone à l’international (Jimmy Fallon, Dave Chappelle, Nikki Glaser), ce spectacle est un véritable gage de qualité.  Il propose aux salles une soirée rythmée, actuelle et audacieuse, portée par des talents de grande efficacité comique qui façonneront l’humour de demain. Un format éprouvé. Une marque forte. Une nouvelle génération d’humoristes d’exception mise de l’avant par une marque emblématique.</p>\n<p><a href=\"http://www.laval.ca/diffusart\" target=\"_blank\" class=\"button btn-primary\" rel=\"noreferrer noopener\">Diffusart</a></p>"
      }
    ],
