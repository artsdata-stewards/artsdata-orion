  {
    "@id": "https://co-motion.ca/temporary/ebc97ba5-a432-4221-aa19-bb10ea3371d4",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/cafe-concerts-voix-celestes/"
      }
    ],
