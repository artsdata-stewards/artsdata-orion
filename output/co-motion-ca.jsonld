        "@id": "https://co-motion.ca/genid/db759b390d7b45f4"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/laurence-jalbert-tournee-35e-anniversaire/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-01T20:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/2d06e7cbb66ab54d"
      }
    ],
    "http://schema.org/offers": [
