  {
    "@id": "https://co-motion.ca/spectacles/les-soeurs-boulay-et-elliot-maginot/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Amis depuis presque 15 ans déjà, autrefois colocataires au 4488 de l’amour , l es soeurs Boulay et Elliot Maginot ont fait leurs débuts côte à côte."
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
