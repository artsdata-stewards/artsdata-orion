  {
    "@id": "https://co-motion.ca/temporary/39d6acab-12d0-4afd-b466-b8b8febb9acd",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/noel-une-tradition-en-chanson-2026/"
      }
    ],
    "http://schema.org/image": [
