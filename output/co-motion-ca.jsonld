  {
    "@id": "https://co-motion.ca/temporary/320ea55d-20ed-4804-a5cd-d8550fd7906a",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/ladies-night-2025/"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://co-motion.ca/genid/9b783c054ce7c74d"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://co-motion.ca/spectacles/ladies-night-2025/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-04T19:30:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://co-motion.ca/genid/2d06e7cbb66ab54d"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://co-motion.ca/genid/77b6b7ec4ec67dcf"
      }
    ],
    "http://schema.org/performer": [
      {
