  {
    "@id": "https://co-motion.ca/spectacles/confession/",
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "De Michel Tremblay Mise en scène René Richard Cyr Distribution Étienne Courville, Élie Dorval, Émile Ouellette, Nour Shoukry et Madani Tall CINQ FACETTES…"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "fr",
        "@value": "https://co-motion.ca/uploads/Spectacles/_1200x630_crop_center-center_82_none/Confession.jpg?mtime=1776451240"
      }
    ],
    "http://ogp.me/ns#type": [
      {
