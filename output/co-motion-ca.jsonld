  {
    "@id": "https://co-motion.ca/temporary/d6450f4d-940c-4f04-a48e-e40d8c3ade89",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/mainEntityOfPage": [
      {
        "@id": "https://co-motion.ca/spectacles/marthe-laverdiere-jai-dit-oui/"
      }
    ],
