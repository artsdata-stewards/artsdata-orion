        "@id": "_:g1237660"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://co-motion.ca/#identity"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://co-motion.ca/spectacles/la-cumbia-less-toches/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "<p>Less Toches, c'est la collision musicale de cinq personnages explosifs, un big-bang de cumbia inattendu et rafraîchissant sur l'île de Montréal. La magie éternelle des paysans troubadours du Sud, acquiert ici un air poétique, passionné et amusant: Less Toches emprunte son nom d’un oiseau latino-américain, et une expression colombienne voulant dire “maladroit”. <br /><br />Leurs origines colombiennes, mexicaines, cubaines et argentines se conjuguent pour faire revivre rythmes qui ont marqué leur enfance à travers la tradition folklorique: la cumbia continental de Montréal!</p>"
      }
    ],
    "http://schema.org/inLanguage": [
      {
        "@language": "fr",
        "@value": "fr"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "La Cumbia SVP!"
      }
    ],
    "http://schema.org/keywords": [
      {
        "@language": "fr",
        "@value": "Musique du monde"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
