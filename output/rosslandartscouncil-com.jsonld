    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Who Is Shirley Gnome?  Shirley Gnome is a Canadian singer-comedian and cabaret musician based in Vancouver/Montreal. Known for her funny, taboo, and irreverent songs, she straddles the line between musician […]"
