    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "The Lake"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Lac, avec ses eaux mouvantes et ses abysses, devient le reflet de la danse elle-même, à la fois exaltante et dévorante."
      }
    ]
  },
