    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A powerful giant in blues performance, Matt Andersen leaves it all on stage in an incredible display of energy, songcraft and guitar prowess."
      },
      {
        "@language": "en-ca",
        "@value": "Pricing\n*NEW* Gold Circle Series shows have a two-tiered price structure\nTier 1 (Rows A-E): $75.00 (HST included)\nTier 2 (Rows F-N): $65.00 (HST included)\nClick Here to Buy Tickets!  \nAurora Cultural Centre Presents\nGold Circle Series\nAurora Winter Blues Festival"
      }
    ],
