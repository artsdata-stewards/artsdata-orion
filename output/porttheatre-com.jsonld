    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en",
        "@value": "Located in Nanaimo, BC, the Port Theatre is a rental venue and important gathering place that serves as a home for many professional arts organizations, promoters, and community groups. Situated on Canada’s western edge, the theatre is a strategically important stop on the touring circuit where many national tours either begin or end their journey. In addition to supporting our rental clients, The Port Theatre Society has earned a national reputation for its acclaimed Spotlight Series, which presents Canadian and internationally renowned artists."
      }
