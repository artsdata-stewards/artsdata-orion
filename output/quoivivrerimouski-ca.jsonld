    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Galerie d&amp;#039;art | Vu en pointillés"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Photographe opportuniste, au gré de mes déplacements&amp;nbsp;spontanés, je&amp;nbsp;cueille et&amp;nbsp;recueille les scènes ou les détails&amp;nbsp;qui seront les images de la journée.\n\nPlusieurs journées se mêlent et j’en extrais des ensembles de photographies&amp;nbsp;qui sont liées entre elles par une&amp;nbsp;cause, une&amp;nbsp;couleur, une&amp;nbsp;matière,&amp;nbsp;enfin par quelque chose qu’elles veulent nous dire&amp;nbsp;quand elles sont juxtaposées les unes aux autres.\n\nCela forme des&amp;nbsp;trios, des&amp;nbsp;quatuors, des&amp;nbsp;mosaïques qui racontent une petite histoire mais imbriquée dans un tout qui nous attire aux premiers abords sans en connaître immédiatement le&amp;nbsp;sens ultime."
      }
    ],
    "http://schema.org/duration": [
      {
        "@language": "fr",
        "@value": "PT1H00M"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/Programmé"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ]
  },
