      {
        "@language": "fr",
        "@value": "Tekkno Tribute Electric Callboy avec Change My Brains With Cakes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "🔥 TEKKNO – Electric Callboy Tribute en live à Rimouski! 🔥\nPrépare-toi pour une soirée complètement explosive 🤯\nLe groupe TEKKNO – Electric Callboy Tribute Band débarque à la Taverne 666 pour un show électro-metal survolté comme tu n’en as jamais vu!\n🎶 Au programme :\nDes hits d’Electric Callboy, des breakdowns violents, des vibes party, du fun non-stop et une ambiance complètement déjantée 💥\n⚡ Invité spécial : Change My Brain With Cakes\nUn set énergique pour bien lancer la soirée comme il faut!\n📍 Lieu : Taverne 666\n📍 45 Rue St Germain E, Rimouski, QC\n🗓 Date : Samedi 6 juin\n🚪 Portes : 20h\n🎤 Spectacle : 21h\n🎟 Billets : 20$"
      }
    ],
    "http://schema.org/duration": [
      {
        "@language": "fr",
        "@value": "PT1H00M"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/Programmé"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ]
  },
