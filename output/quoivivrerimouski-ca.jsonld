    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Triple hommage | Korn - LimpBizkit - Rage against the machine par Mutant Beans"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Venez revivre une époque mythique de la musique avec les puissants Mutant Beans qui nous visitent directement d&#039;Ensenada, Mexique !\nLes boys vont jouer au Gaspesian Metal Fest dans le belle ville de Matane mais avant ça ils vont faire un arrêt à Rimouski pour nous offrir un triple hommage fkn explosif : Korn - LimpBizkit - Rage against the machine.\nLes homies de Dekora seront présents pour ouvrir le bals avec leur power funk dans ta face loco!\nTu peux imaginer le genre de soirée qui s&#039;en vient avec 2 bandes très puissants, très funk, très thrash sur le stage ça va virer fou raide!\nVendredi 5 Juin 2026.\nContribution 15$.\nShowtime 21h00.\nTaverne 666 - 45, rue St-Germain Est, Rimouski,Qc.\nPrésenté par Morro Carnal Prodzsz."
      }
    ],
    "http://schema.org/duration": [
      {
        "@language": "fr",
        "@value": "PT1H00M"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/Programmé"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ]
  },
