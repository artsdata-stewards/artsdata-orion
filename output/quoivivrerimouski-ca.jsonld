    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Groupe originaire de Matane, Benmanque Blues vous régalera avec sa musique chaleureuse et groovy, inspirée du blues de Chicago, du Mississippi et de la Louisiane !\n15$ à la porte - aucune prévente\n21h - 18 ans et plus"
      }
    ],
