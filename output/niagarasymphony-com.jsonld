    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Matt Dusk Sings Sinatra - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Swing Into the Golden Age Step into the glamour and excitment of Las Vegas nightlife as acclaimed vocalist Matt Dusk pays tribute to the legendary Frank Sinatra. Backed by the full Niagara Symphony Orchestra, Dusk brings timeless classics like Fly Me to the Moon, My Way, and New York, New York to dazzling life. Classic style meets Sinatra magic. Kathleen Allan’s appearance is generously sponsored by Lauren and Vaughan Goettler and the Goettler Family Foundation in partnership with The Women in Musical Leadership Program."
      }
    ],
