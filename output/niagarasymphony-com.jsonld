      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A symphonic tribute to the legacy of Deep Purple\r\nBradley Thachuk, conductor\r\nJoe Retta, vocalist\r\n\r\nFrom Hush and Smoke on the Water to Whitesnake’s Here I Go Again, Deep Purple and the bands formed from its former members have delivered music fans some of their most beloved hits and anthems."
      }
    ],
