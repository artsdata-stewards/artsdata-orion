    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Brahms’ Second"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The lineage of German Romanticism can be traced from Weber to one of its undisputed masters, Brahms. The Brahms symphonic cycle continues in Niagara with the cheerful and moving Second Symphony. Visionary pianist Sara Davis Buechner brings her thoughtful artistry to Jared Miller’s Shattered Night – the Canadian composer’s personal emotional response to the eightieth anniversary of Kristallnacht.\r\n"
      }
    ],
