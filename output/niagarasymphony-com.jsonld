    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Bradley Thachuk, conductor Michelle Colton, percussion  Glinka | Overture to Ruslan and Lyudmila Kevin Lau | The Stars Are Not Aligned World Premiere Rimsky-Korsakov | Scheherazade  Tales of fortune and fate are brought to life through steel, skins, and strings in this reimagining of Masterworks 2!"
      }
    ],
