    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Fewer Plays Vivaldi"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Bradley Thachuk, conductor\r\nMark Fewer, leader & violin\r\n\r\nVivaldi | The Four Seasons\r\n\r\nKevin Lau | Le Petit Prince: Concert Suite No. 2 (WORLD PREMIERE)\r\n\r\nRespighi | The Pines of Rome\r\n\r\nCanadian violinist Mark Fewer leads the NSO strings in Vivaldi’s beloved depiction of pastoral Italy through the calm and fury of the passing seasons."
      }
    ],
