  {
    "@id": "https://niagarasymphony.com/event/from-darkness-to-light-mahler-5/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
