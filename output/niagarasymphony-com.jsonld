  {
    "@id": "https://niagarasymphony.com/event/home-for-the-holidays-6/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
