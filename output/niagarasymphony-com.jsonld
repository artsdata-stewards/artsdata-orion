      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-22T14:30:00-05:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-22T17:00:00-05:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://niagarasymphony.com/genid/72001e91346b690b"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://niagarasymphony.com/genid/a85d7da39e102f01"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/concerts/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Dreams & Dances"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Fantasy, Fire, and Symphonic Grandeur&lt;/p&gt;\\n&lt;p&gt;Discover a concert experience filled with imagination and triumphant orchestral power.&lt;/p&gt;\\n&lt;p&gt;Ravel’s enchanting Mother Goose Suite opens the concert with delicate colours and magical charm, transporting audiences into a world of fairy tales and wonder.&lt;/p&gt;\\n&lt;p&gt;Then comes the vibrant energy of The Golden Wok by Dai Wei—a dazzling fusion of music, storytelling, and cultural celebration.&lt;/p&gt;\\n&lt;p&gt;Finally, Mendelssohn’s majestic “Reformation” Symphony brings the evening to a thrilling close, filled with soaring melodies, spiritual depth, and triumphant power.&lt;/p&gt;\\n&lt;p&gt;An inspiring journey through fantasy, tradition, and musical discovery.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://niagarasymphony.com/event/dreams-dances/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Dreams & Dances - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Fantasy, Fire, and Symphonic Grandeur  Discover a concert experience filled with imagination and triumphant orchestral power.  Ravel’s enchanting Mother Goose Suite opens the concert with delicate colours and magical charm, transporting audiences into a world of fairy tales and wonder.  Then comes the vibrant energy of The Golden Wok by Dai Wei—a dazzling fusion of music, storytelling, and cultural celebration.  Finally, Mendelssohn’s majestic “Reformation” Symphony brings the evening to a thrilling close, filled with soaring melodies, spiritual depth, and triumphant power.  An inspiring journey through fantasy, tradition, and musical discovery."
      }
    ],
