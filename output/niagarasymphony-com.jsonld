      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Four Seasons Reimagined"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Experience Vivaldi's iconic Four Seasons like never before in this captivating concert. Max Richter's breathtaking reimagining, steeped in postmodern and minimalist influences, will transport you to a realm of ethereal beauty and profound emotion.\r\n\r\n\r\nThen, let the rhythms of Buenos Aires ignite your soul. Astor Piazzolla's Four Seasons of Buenos Aires blends the fiery passion of tango with the elegance of classical music, creating a captivating and unforgettable musical journey.\r\n\r\n\r\nThis extraordinary evening features the virtuosic talents of Maureen Conlon-Gutierrez, a celebrated violinist whose artistry reflects her rich Mexican-American heritage, and the legendary Hector Del Curto, one of the world's most acclaimed bandoneonists.\r\n\r\n\r\nDon't miss this unique opportunity to experience the timeless beauty of Vivaldi and the fiery passion of Piazzolla in a concert that will stay with you long after the final note fades.\r\n"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
