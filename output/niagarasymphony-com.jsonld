  {
    "@id": "https://niagarasymphony.com/event/requiem-redemption-a-special-co-presentation-with-chorus-niagara/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Requiem & Redemption – A Special Co-Presentation With Chorus Niagara - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Choral Majesty and Spiritual Beauty Combined with Orchestra Power and Soaring Vocal Solos. Join the Niagara Symphony Orchestra and Chorus Niagara for a breathtaking celebration of choral and orchestral masterworks. Gounod’s radiant Messe solennelle de Sainte Cécile fills the hall with soaring melodies and glorious vocal splendour. Then, experience the timeless beauty of Fauré’s Requiem—one of the most beloved choral and orchestral works ever composed. Maestros Bradley Thachuk and Kathleen Allen join forces for a special evening of beauty and incredible musical expression."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/requiem-redemption-a-special-co-presentation-with-chorus-niagara/"
      }
