  {
    "@id": "https://niagarasymphony.com/event/the-stars-are-not-aligned/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
