    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Music of Phil Collins &#038; Genesis"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Experience the unforgettable music of Phil Collins and Genesis like never before—performed live with full symphony orchestra and The Gravel Museum Rock Band.\r\n\r\nThis electrifying concert brings new life to some of the greatest rock songs ever written.\r\n\r\nClassic rock meets symphonic spectacle in one epic concert event!\r\n"
      }
    ],
