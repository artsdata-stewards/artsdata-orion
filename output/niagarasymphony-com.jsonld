    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Requiem & Redemption – A Special Co-Presentation With Chorus Niagara"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Choral Majesty and Spiritual Beauty Combined with Orchestra Power and Soaring Vocal Solos.&lt;br /&gt;\\nJoin the Niagara Symphony Orchestra and Chorus Niagara for a breathtaking celebration of choral and orchestral masterworks.&lt;br /&gt;\\nGounod’s radiant Messe solennelle de Sainte Cécile fills the hall with soaring melodies and glorious vocal splendour.&lt;br /&gt;\\nThen, experience the timeless beauty of Fauré’s Requiem—one of the most beloved choral and orchestral works ever composed.&lt;br /&gt;\\nMaestros Bradley Thachuk and Kathleen Allan join forces for a special evening of beauty and incredible musical expression.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
