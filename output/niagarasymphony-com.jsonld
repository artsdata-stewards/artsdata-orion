    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The Rock Music of the 70's and 80' reimagined with full orchestra. Rock out to the greatest classic rock songs of all time! The music of Queen, Led Zeppelin, The Who, and many more, performed by an all-star band, backed by the full power of the symphony orchestra."
      }
