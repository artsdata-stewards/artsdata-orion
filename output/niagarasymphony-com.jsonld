    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Matt Dusk Sings Sinatra"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Swing Into the Golden Age\r\nStep into the glamour and excitment of Las Vegas nightlife as acclaimed vocalist Matt Dusk pays tribute to the legendary Frank Sinatra.\r\nBacked by the full Niagara Symphony Orchestra, Dusk brings timeless classics like Fly Me to the Moon, My Way, and New York, New York to dazzling life.\r\nClassic style meets Sinatra magic.\r\nKathleen Allan’s appearance is generously sponsored by Lauren and Vaughan Goettler and the Goettler Family Foundation in partnership with The Women in Musical Leadership Program."
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
