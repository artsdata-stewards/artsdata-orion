  {
    "@id": "https://niagarasymphony.com/event/mozart-mystique-concert-garden-party-at-st-marks-in-niagara-on-the-lake/#event",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/image": [
      {
        "@id": "https://niagarasymphony.com/event/mozart-mystique-concert-garden-party-at-st-marks-in-niagara-on-the-lake/#primaryimage"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://niagarasymphony.com/event/mozart-mystique-concert-garden-party-at-st-marks-in-niagara-on-the-lake/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-02T14:30:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
