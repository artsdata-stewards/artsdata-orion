      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Niagara Falls native, Jarred Dunn returns home as featured soloist on Mozart’s intimate and reflective Piano Concerto No. 24."
      }
    ],
