  {
    "@id": "https://niagarasymphony.com/event/pastorale/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Pastorale - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Join us for an evening of musical masterpieces, where the human spirit soars and the beauty of nature unfolds.  Be swept away by the serene beauty of Copland's Appalachian Spring. Experience the joy and tranquility of a wedding day in rural Pennsylvania, as the music paints a vivid picture of dawn's gentle awakening and the peaceful close of day. Immerse yourself in the pastoral splendor of Beethoven's Symphony No. 6, \"Pastorale.\" Feel the composer's deep love for nature as the music evokes the sights, sounds, and emotions of a day in the countryside. Let the symphony's expressive melodies and evocative textures transport you to a world of tranquility and beauty.  Don't miss this opportunity to experience the power and beauty of these timeless works. Let the music ignite your senses and stir your soul.  Special Concert Event – Bring the whole family to our Saturday matinee!  For a special discounted rate, our Saturday April 5 concert will be a family-friendly performance, a perfect way to introduce children of all ages to Beethoven! The concert will be shorter than most other performances, and presented in a relaxed and casual atmosphere.  "
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/pastorale/"
      }
    ],
