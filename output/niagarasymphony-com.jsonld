    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Soulful"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Come celebrate 50 years of R&B, Motown, Funk, Disco, and Pop by some of the finest African American recording artists and performers like Smokey Robinson, Outkast, Stevie Wonder, Pharrell Williams, Isaac Hayes, and Seal. Featuring three-time Juno Award nominee and long-time member of the iconic Canadian a cappella group, The Nylons, Gavin Hope is a natural born performer. With his lightning speed comedic timing, skills on the dance floor, and truly exceptional, velvety, emotional voice, Hope is always a fan favourite!"
      }
    ],
