  {
    "@id": "https://niagarasymphony.com/temporary/3afaea48-6347-4528-811e-7d52d1747b28",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/image": [
      {
        "@id": "https://niagarasymphony.com/wp-content/uploads/2026/06/NSO_MozartMoreNOTLWEB.jpg"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://niagarasymphony.com/event/mozart-mystique-concert-garden-party-at-st-marks-in-niagara-on-the-lake/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-02T17:30:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-02T22:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://niagarasymphony.com/genid/d489a05eddc17997"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://niagarasymphony.com/genid/a85d7da39e102f01"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/concerts/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Mozart & Mystique Concert & Garden Party at St. Mark’s in Niagara on the Lake"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;&lt;b&gt;&lt;span style=&quot;color: #880f04&quot;&gt;THIS IS A STAND ALONE CONCERT AND IS NOT PART OF BUNDLED PURCHASES&lt;/span&gt;&lt;/b&gt;After last season’s tremendously successful Garden Party, the Niagara Symphony Orchestra returns to the beautiful and historic St. Mark’s Church in Niagara-on-the-Lake for another unforgettable evening of music, celebration, and community.&lt;/p&gt;\\n&lt;p&gt;Experience the magic of live orchestral music in one of Niagara’s most stunning settings, followed by an elegant garden soirée featuring wine, food, mingling with the musicians, and more live music along the picturesque St. Mark’s walkway.&lt;/p&gt;\\n&lt;p&gt;The concert itself is a journey through beauty, drama, and wonder. Mozart’s sparkling Eine Kleine Nachtmusik opens the evening with timeless elegance and charm, while acclaimed oboist Ari Cohen Mann brings lyrical warmth and expressive brilliance to Kevin Lau’s atmospheric Prayer in a Green Cathedral.&lt;/p&gt;\\n&lt;p&gt;The evening concludes with Mozart’s emotionally charged Symphony No. 40—a masterpiece filled with passion, urgency, and unforgettable melodies.&lt;/p&gt;\\n&lt;p&gt;Music, wine, conversation, and the charm of Niagara-on-the-Lake come together for one very special NSO celebration event.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://niagarasymphony.com/temporary/c499b52a-323d-4521-a129-22b830e91b0c",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/image": [
      {
        "@id": "https://niagarasymphony.com/wp-content/uploads/2026/06/NSO_MozartMoreWEB.jpg"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://niagarasymphony.com/event/mozart-mystique/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-04T14:30:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-04T17:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://niagarasymphony.com/genid/fcc7072d3016110e"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://niagarasymphony.com/genid/a85d7da39e102f01"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/concerts/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Mozart & Mystique"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Step into a world of luminous melodies and timeless artistry with a concert that pairs Mozart’s brilliance with the evocative imagination of Canadian composer, and NSO audience favourite, Kevin Lau. The concert opens with Mozart’s sparkling Eine Kleine Nachtmusik—one of the most beloved works ever written, overflowing with charm and elegance. Then, acclaimed Canadian oboist Ari Cohen Mann takes centre stage for Kevin Lau’s Prayer in a Green Cathedral, a deeply atmospheric work inspired by the majesty and stillness of nature. The concert concludes with Mozart’s dramatic and emotionally charged Symphony No. 40, a masterpiece that pulses with passion and unforgettable melodies. Classical perfection meets modern wonder not to be missed.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
