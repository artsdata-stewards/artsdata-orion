  {
    "@id": "https://niagarasymphony.com/event/promise-and-hope/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Promise and Hope - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Music of Reflection, Renewal, and Hope  Experience a deeply moving concert of music that journeys from optimism and renewal to profound emotional beauty.  John Estacio’s Spring’s Promise opens the concert with vibrant colour and energy—a radiant celebration of rebirth and possibility.  Then, cellist Mira Kardan performs Elgar’s beloved Cello Concerto, one of the most heartfelt and emotionally powerful works ever written.  The concert concludes with Vaughan Williams’ luminous Symphony No. 5, a work of serenity and compassion.  Music that comforts, inspires, and speaks directly to the soul."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/promise-and-hope/"
      }
