  {
    "@id": "https://niagarasymphony.com/event/postcards-from-vienna/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Postcards from Vienna - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Celebrate the elegance, charm, and exuberance of the Viennese musical tradition in a sparkling evening of beloved classics!  The concert opens with the effervescent Overture to Die Fledermaus by Johann Strauss, Jr., setting the stage for a night of irresistible rhythm and flair. Then, experience the graceful brilliance of Mozart’s Piano Concerto No. 23, performed by the exceptional Eric Guo - a masterpiece of lyrical beauty and refinement.  The second half bursts into full celebration with the rousing Radetzky March by Johann Strauss, Sr., followed by a cascade of iconic Strauss waltzes and polkas, including the regal Emperor Waltzes, the exuberant Thunder and Lightning Polka, the romantic Wine, Women and Song, and the timeless splendor of On the Beautiful Blue Danube.  Waltz through Vienna's golden age—one unforgettable melody at a time!"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/postcards-from-vienna/"
      }
    ],
