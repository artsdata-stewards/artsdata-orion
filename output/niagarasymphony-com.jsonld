    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Rock out to the greatest classic rock songs of all time! The music of Queen, The Who, Foreigner, Led Zeppelin, and many more performed by an all-star band, backed by the full power of NSO!"
      }
