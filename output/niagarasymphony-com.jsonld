    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Walking Through The Fire"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Sultans of String, Alyssa Delbaere-Sawchuk, Marc Meriläinen (Nadjiwan), Shannon Thunderbird, Don Ross, Leela Gilday, The North Sound, and a multimedia extravaganza featuring Northern Cree Powwow Group, Dr. Duke Redbird, Inuit singers, and more!  \r\n\r\nAward-winning First Nations, Métis, and Inuit artists perform with JUNO Award nominees Sultans of String, in a musical multimedia event unlike any other! From Métis fiddling to an East Coast Kitchen Party, to the drumming of the Pacific Northwest, experience the beauty and diversity of music from Turtle Island/Canada."
      }
    ],
