    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Morning Music, Coffee, &#038; Friends"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A Special Non-Subscription Concert\r\n\r\nJoin the Niagara Symphony Orchestra for a delightful morning of timeless music, warm conversation, and unforgettable melodies at our Coffee & Classics concert.\r\n\r\nEnjoy the brilliance and elegance of Mozart’s final symphony, the magnificent “Jupiter” Symphony — a joyful masterpiece overflowing with energy, beauty, and dazzling orchestral writing. Then experience the youthful fire and creativity of Beethoven’s Symphony No. 1, a work bursting with charm, wit, and the bold spirit of a composer ready to change music forever.\r\n\r\nPerfect for classical music lovers in this relaxed daytime concert offering an inviting atmosphere with friends and fellow patrons.\r\n\r\nWonderful music. Great company. A perfect morning at the symphony."
      }
    ],
