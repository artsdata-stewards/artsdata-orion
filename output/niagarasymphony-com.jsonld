    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Nibbles And Notes &#8211; A Pre-Concert Cocktail Hour"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Let the NSO put you in the mood for Valentine's Day. Enjoy a glass of wine, hors d'oeuvres, and the musical stylings of jazz pianist, Doug Mundy prior to the Soulful concert. A long time Niagara resident, Mundy is one of the most in demand musicians in the Niagara Region. He has recently completed a tour of New Zealand working with a collection of the country's finest jazz musicians."
      }
    ],
