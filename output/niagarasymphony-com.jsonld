    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "A Celebration of Broadway & Song"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Broadway Brilliance Meets Cinematic Magic&lt;/p&gt;\\n&lt;p&gt;Get ready for an unforgettable experience of soaring melodies, beloved classics, and breathtaking performances as special guest vocalists Jay Dref and Kelly Holiff take the stage with the full power of the Niagara Symphony Orchestra.&lt;/p&gt;\\n&lt;p&gt;Featuring timeless favourites including Music of the Night, Time to Say Goodbye, You Raise Me Up, and more, this spectacular evening celebrates the songs that have defined generations.&lt;/p&gt;\\n&lt;p&gt;One stage. Endless emotion. Pure musical magic.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
