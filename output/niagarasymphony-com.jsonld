  {
    "@id": "https://niagarasymphony.com/event/matt-dusk-sings-sinatra/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Matt Dusk Sings Sinatra - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Swing Into the Golden Age Step into the glamour and excitment of Las Vegas nightlife as acclaimed vocalist Matt Dusk pays tribute to the legendary Frank Sinatra. Backed by the full Niagara Symphony Orchestra, Dusk brings timeless classics like Fly Me to the Moon, My Way, and New York, New York to dazzling life. Classic style meets Sinatra magic. Kathleen Allen’s appearance is generously sponsored by Lauren and Vaughan Goettler and the Goettler Family Foundation in partnership with The Women in Musical Leadership Program."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/matt-dusk-sings-sinatra/"
      }
    ],
