      {
        "@language": "en",
        "@value": "&lt;p&gt;A Special Non-Subscription Concert&lt;/p&gt;\\n&lt;p&gt;Join the Niagara Symphony Orchestra for a delightful morning of timeless music, warm conversation, and unforgettable melodies at our Coffee &amp; Classics concert.&lt;/p&gt;\\n&lt;p&gt;Enjoy the brilliance and elegance of Mozart’s final symphony, the magnificent “Jupiter” Symphony — a joyful masterpiece overflowing with energy, beauty, and dazzling orchestral writing. Then experience the youthful fire and creativity of Beethoven’s Symphony No. 1, a work bursting with charm, wit, and the bold spirit of a composer ready to change music forever.&lt;/p&gt;\\n&lt;p&gt;Perfect for classical music lovers in this relaxed daytime concert offering an inviting atmosphere with friends and fellow patrons.&lt;/p&gt;\\n&lt;p&gt;Wonderful music. Great company. A perfect morning at the symphony.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
