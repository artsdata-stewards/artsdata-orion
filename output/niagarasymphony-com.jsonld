    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Stravinsky and Tchaikovsky"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Stravinsky’s early work with the Ballets Russe in Paris launched the composer to international stardom. The first of these works, The Firebird, is paired with Stravinsky’s own childhood hero Tchaikovsky, whose thrilling Fourth Symphony depicts his struggle with Fate. Niagara’s own Juliet Dunn joins the NSO in the Canadian premiere of Timothy Adams’ Harriet: A Journey to Freedom, a co-commission honouring the life of Harriet Tubman and the local history of the Underground Railroad. "
      }
    ],
