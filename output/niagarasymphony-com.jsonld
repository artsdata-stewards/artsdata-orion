    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Symphonically Hip"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The Tragically Hip Like You’ve Never Heard Them Before\r\nRock Legends from the Gravel Museum Rock Band meet the power of the full Niagara Symphony in this unforgettable tribute to The Tragically Hip.\r\nSymphonically Hip combines your favourite iconic Hip songs with sweeping symphonic experiences.\r\nBig songs. Big orchestra. Big Canadian heart."
      }
    ],
