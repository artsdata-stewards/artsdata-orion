  {
    "@id": "https://niagarasymphony.com/event/nibbles-and-notes-a-pre-concert-cocktail-hour-2024-02-11/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Nibbles And Notes - A Pre-Concert Cocktail Hour - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Let the NSO put you in the mood for Valentine's Day. Enjoy a glass of wine, hors d'oeuvres, and the musical stylings of jazz pianist, Doug Mundy prior to the Soulful concert. A long time Niagara resident, Mundy is one of the most in demand musicians in the Niagara Region. He has recently completed a tour of New Zealand working with a collection of the country's finest jazz musicians."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/nibbles-and-notes-a-pre-concert-cocktail-hour-2024-02-11/"
      }
    ],
    "http://ogp.me/ns#site_name": [
      {
        "@language": "en-us",
        "@value": "Niagara Symphony"
      }
    ],
    "article:modified_time": [
      {
        "@language": "en-us",
        "@value": "2023-10-07T17:03:29+00:00"
      }
    ],
