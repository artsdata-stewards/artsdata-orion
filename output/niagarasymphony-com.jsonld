    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Stars Are Not Aligned"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Bradley Thachuk, conductor\r\nMichelle Colton, percussion\r\n\r\nGlinka | Overture to Ruslan and Lyudmila\r\nKevin Lau | The Stars Are Not Aligned\r\nWorld Premiere\r\nRimsky-Korsakov | Scheherazade\r\n\r\nTales of fortune and fate are brought to life through steel, skins, and strings in this reimagining of Masterworks 2! "
      }
    ],
