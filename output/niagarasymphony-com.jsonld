    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Bold Beginnings - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Experience the thrilling power of musical greatness as internationally acclaimed pianist Angela Hewitt joins the Niagara Symphony Orchestra for an unforgettable concert of Beethoven and Brahms. Beethoven’s Piano Concerto No. 1 will sparkle with wit, elegance, and brilliance with the stunning artistry of Angela Hewitt. Then comes Brahms’ monumental Symphony No. 1 - a work decades in the making that rises from shadow to triumph in one of the greatest symphonic journeys ever composed. A breathtaking start to the new year."
      }
    ],
