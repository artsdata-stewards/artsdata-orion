      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g3444860"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "_:g3444900"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/events/category/nso-classic/2026-09/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Mozart &#038; Mystique Concert &#038; Garden Party At St. Mark’s In Niagara on the Lake"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "After last season’s tremendously successful Garden Party, the Niagara Symphony Orchestra returns to the beautiful and historic St. Mark’s Church in Niagara-on-the-Lake for another unforgettable evening of music, celebration, and community.\r\n\r\nExperience the magic of live orchestral music in one of Niagara’s most stunning settings, followed by an elegant garden soirée featuring wine, food, mingling with the musicians, and more live music along the picturesque St. Mark’s walkway.\r\n\r\nThe concert itself is a journey through beauty, drama, and wonder. Mozart’s sparkling Eine Kleine Nachtmusik opens the evening with timeless elegance and charm, while acclaimed oboist Ari Cohen Mann brings lyrical warmth and expressive brilliance to Kevin Lau’s atmospheric Prayer in a Green Cathedral.\r\n\r\nThe evening concludes with Mozart’s emotionally charged Symphony No. 40—a masterpiece filled with passion, urgency, and unforgettable melodies.\r\n\r\nMusic, wine, conversation, and the charm of Niagara-on-the-Lake come together for one very special NSO celebration event."
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
