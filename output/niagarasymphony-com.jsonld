  {
    "@id": "https://niagarasymphony.com/event/gilbert-conducts-dvorak/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Gilbert Conducts Dvorak - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Rising star Québécoise conductor Dina Gilbert presents two contrasting visions of Eastern Europe. Dvorak’s optimistic Eighth Symphony pays loving tribute to the landscapes and folk tunes of Bohemia."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/gilbert-conducts-dvorak/"
      }
    ],
