  {
    "@id": "https://niagarasymphony.com/event/the-four-seasons-reimagined/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "The Four Seasons Reimagined - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Experience Vivaldi's iconic Four Seasons like never before in this captivating concert. Max Richter's breathtaking reimagining, steeped in postmodern and minimalist influences, will transport you to a realm of ethereal beauty and profound emotion.   Then, let the rhythms of Buenos Aires ignite your soul. Astor Piazzolla's Four Seasons of Buenos Aires blends the fiery passion of tango with the elegance of classical music, creating a captivating and unforgettable musical journey.   This extraordinary evening features the virtuosic talents of Maureen Conlon-Gutierrez, a celebrated violinist whose artistry reflects her rich Mexican-American heritage, and the legendary Hector Del Curto, one of the world's most acclaimed bandoneonists.   Don't miss this unique opportunity to experience the timeless beauty of Vivaldi and the fiery passion of Piazzolla in a concert that will stay with you long after the final note fades."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/the-four-seasons-reimagined/"
      }
