  {
    "@id": "https://niagarasymphony.com/event/symphonic-pink-floyd-the-wall-2/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Symphonic Pink Floyd: The Wall  - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Get ready for an electrifying fusion of rock and symphony as Pink Floyd’s iconic masterpiece The Wall comes to life like never before - with a full live band and powerhouse symphony orchestra sharing the stage.  Experience every legendary riff, searing lyric, and cinematic sweep of this rock opera epic, reimagined with the grandeur and emotional depth only a full orchestra can deliver. From “Another Brick in the Wall” to “Comfortably Numb,” it’s the music you love - bigger, bolder, and more immersive than ever.  This will be the world premiere of this production featuring arrangements by Music Director Bradley Thachuk and guitarist Steven Thachuk.  One stage. Two worlds. Total sonic impact. This is The Wall as you’ve never heard it before."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/symphonic-pink-floyd-the-wall-2/"
      }
    ],
