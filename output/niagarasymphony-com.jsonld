    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "A Celebration of Broadway &#038; Song"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Broadway Brilliance Meets Cinematic Magic\r\n\r\nGet ready for an unforgettable experience of soaring melodies, beloved classics, and breathtaking performances as special guest vocalists Jay Dref and Kelly Holiff take the stage with the full power of the Niagara Symphony Orchestra.\r\n\r\nFeaturing timeless favourites including Music of the Night, Time to Say Goodbye, You Raise Me Up, and more, this spectacular evening celebrates the songs that have defined generations.\r\n\r\nOne stage. Endless emotion. Pure musical magic."
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
