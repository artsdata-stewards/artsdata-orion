    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "The NSO Comes to Niagara-On-The-Lake  - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Join us for a special Concert and Garden Party event in beautiful Niagara-on-the-Lake! The NSO will present its Mozart & More program at the beautiful St. Mark’s Church. Following the concert, enjoy more music, hors d’oeuvres, wine, and other refreshments as you mingle with our Music Director Bradley Thachuk and other NSO Musicians in the St. Mark’s courtyard (tent covered). An exclusive event not to be missed!  (This is a special non-subscription event)"
      }
    ],
