  {
    "@id": "https://niagarasymphony.com/temporary/bd60f020-36e0-442e-8b3c-def020534c85",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/image": [
      {
        "@id": "https://niagarasymphony.com/wp-content/uploads/2026/06/NSO_RequiemRedemption-2.jpg"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://niagarasymphony.com/event/requiem-redemption-a-special-co-presentation-with-chorus-niagara-2/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-25T14:30:00-04:00"
      }
