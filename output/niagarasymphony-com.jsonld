  {
    "@id": "https://niagarasymphony.com/event/beethovens-ninth/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
