        "@value": "Gilbert Conducts Dvorak - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Rising star Québécoise conductor Dina Gilbert presents two contrasting visions of Eastern Europe. Dvorak’s optimistic Eighth Symphony pays loving tribute to the landscapes and folk tunes of Bohemia."
      }
    ],
