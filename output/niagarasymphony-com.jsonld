  {
    "@id": "https://niagarasymphony.com/event/mozart-mystique/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Mozart & Mystique - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Step into a world of luminous melodies and timeless artistry with a concert that pairs Mozart’s brilliance with the evocative imagination of Canadian composer, and NSO audience favourite, Kevin Lau. The evening opens with Mozart’s sparkling Eine Kleine Nachtmusik—one of the most beloved works ever written, overflowing with charm and elegance. Then, acclaimed Canadian oboist Ari Cohen Mann takes centre stage for Kevin Lau’s Prayer in a Green Cathedral, a deeply atmospheric work inspired by the majesty and stillness of nature. The concert concludes with Mozart’s dramatic and emotionally charged Symphony No. 40, a masterpiece that pulses with passion and unforgettable melodies. Classical perfection meets modern wonder not to be missed."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/mozart-mystique/"
      }
    ],
