  {
    "@id": "https://niagarasymphony.com/event/dreams-dances/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Dreams & Dances - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Fantasy, Fire, and Symphonic Grandeur  Discover an evening filled with imagination and triumphant orchestral power.  Ravel’s enchanting Mother Goose Suite opens the concert with delicate colours and magical charm, transporting audiences into a world of fairy tales and wonder.  Then comes the vibrant energy of The Golden Wok by Dai Wei—a dazzling fusion of music, storytelling, and cultural celebration.  Finally, Mendelssohn’s majestic “Reformation” Symphony brings the evening to a thrilling close, filled with soaring melodies, spiritual depth, and triumphant power.  An inspiring journey through fantasy, tradition, and musical discovery."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/dreams-dances/"
      }
    ],
    "http://ogp.me/ns#site_name": [
      {
        "@language": "en-us",
        "@value": "Niagara Symphony"
      }
    ],
    "article:modified_time": [
      {
        "@language": "en-us",
        "@value": "2026-06-15T16:20:24+00:00"
      }
    ],
