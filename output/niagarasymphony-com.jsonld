    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Classic Rock Unplugged: The New NSO Lounge and Artist Meet and Greet "
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Classic Rock Unplugged – Acoustic Set and Gravel Museum Band Meet &amp; Greet Special Event - Part of the NSO Tour!&lt;/p&gt;\\n&lt;p&gt;Get ready for an unforgettable night of stripped-down classics, raw energy, and pure rock soul! Join us for an intimate unplugged concert where legendary tunes are reimagined in an acoustic setting—up close, personal, and powerful. Enjoy complimentary food and beverages at the bar! &lt;/p&gt;\\n"
      }
    ],
