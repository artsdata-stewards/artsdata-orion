  {
    "@id": "https://niagarasymphony.com/event/earthbeat-a-lunar-new-year-celebration/#event",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/image": [
      {
        "@id": "https://niagarasymphony.com/event/earthbeat-a-lunar-new-year-celebration/#primaryimage"
      }
    ],
