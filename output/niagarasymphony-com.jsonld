  {
    "@id": "https://niagarasymphony.com/event/a-john-williams-finale-2/#event",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/image": [
      {
        "@id": "https://niagarasymphony.com/event/a-john-williams-finale-2/#primaryimage"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://niagarasymphony.com/event/a-john-williams-finale-2/"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-20T19:30:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-20T22:00:00-04:00"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g908960"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "_:g909000"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/events/month/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "A John Williams Finale "
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Step into a world of cinematic magic as the music of John Williams takes centre stage, brought to life by a full symphony orchestra! From the pulse-pounding adventure of Star Wars to the heartwarming triumph of E.T., Williams' iconic scores have defined generations of film lovers.\r\n\r\nJoin us for an exhilarating concert as we journey through the unforgettable melodies of Indiana Jones, Jurassic Park, Harry Potter, and more. The symphony will transport you to epic worlds of adventure, wonder, and emotion, capturing the grandeur and excitement of these timeless films. We are excited to announce that Music Director Bradley Thachuk will feature on these concerts as a special guest soloist.\r\n\r\ntwo performances, one maestro, and a symphonic celebration of music that has shaped the movies we love. Don’t miss this extraordinary tribute to a living legend!"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
