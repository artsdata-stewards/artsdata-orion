        "@id": "https://niagarasymphony.com/event/sutp-summer-serenade/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Summer Under the Pavilion &#8211; Summer Serenade"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Bradley Thachuk, conductor\r\n\r\n\r\nJerod Tate | Shakamaxon (Moccasin Dance)\r\nHolst | St. Paul Suite\r\nElgar | Serenade\r\nBritten | Simple Symphony\r\nVaughan Williams | Fantasia on a Theme by Thomas Tallis\r\nPurcell | Suite for Strings\r\n\r\n\r\nEnjoy a summer serenade by the NSO strings! The Niagara Symphony Orchestra presents Summer Under the Pavilion – an outdoor concert experience for the whole family! Beverages and light snacks available for purchase, free on-site parking. Held at The Pavilion at St. George Orthodox Church."
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
