    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Music of Phil Collins and Genesis"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "From “In the Air Tonight” to “Against All Odds”, and “Turn It On Again” to “Invisible Touch”, Phil Collins has been responsible for some of the most cherished musical moments of the 70’s to the present day. His songs from the legendary band, Genesis and his solo work have been a consistent soundtrack to our lives and will be presented in a way they’ve never been heard before - reimagined for full orchestra with an all-star band."
      }
    ],
