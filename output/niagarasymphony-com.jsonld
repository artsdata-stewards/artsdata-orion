      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/events/month/2026-10/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Mozart &#038; Mystique"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Step into a world of luminous melodies and timeless artistry with a concert that pairs Mozart’s brilliance with the evocative imagination of Canadian composer, and NSO audience favourite, Kevin Lau. The concert opens with Mozart’s sparkling Eine Kleine Nachtmusik—one of the most beloved works ever written, overflowing with charm and elegance. Then, acclaimed Canadian oboist Ari Cohen Mann takes centre stage for Kevin Lau’s Prayer in a Green Cathedral, a deeply atmospheric work inspired by the majesty and stillness of nature. The concert concludes with Mozart’s dramatic and emotionally charged Symphony No. 40, a masterpiece that pulses with passion and unforgettable melodies. Classical perfection meets modern wonder not to be missed."
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
