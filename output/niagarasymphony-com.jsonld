    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://niagarasymphony.com/event/requiem-redemption-a-special-co-presentation-with-chorus-niagara/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Requiem &#038; Redemption – A Special Co-Presentation With Chorus Niagara"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Choral Majesty and Spiritual Beauty Combined with Orchestra Power and Soaring Vocal Solos.\r\nJoin the Niagara Symphony Orchestra and Chorus Niagara for a breathtaking celebration of choral and orchestral masterworks.\r\nGounod’s radiant Messe solennelle de Sainte Cécile fills the hall with soaring melodies and glorious vocal splendour.\r\nThen, experience the timeless beauty of Fauré’s Requiem—one of the most beloved choral and orchestral works ever composed.\r\nMaestros Bradley Thachuk and Kathleen Allan join forces for a special evening of beauty and incredible musical expression."
      }
    ],
