  {
    "@id": "https://niagarasymphony.com/event/morning-music-coffee-friends/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Morning Music, Coffee, & Friends - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Join the Niagara Symphony Orchestra for a delightful morning of timeless music, warm conversation, and unforgettable melodies at our Coffee & Classics concert.  Enjoy the brilliance and elegance of Mozart’s final symphony, the magnificent “Jupiter” Symphony — a joyful masterpiece overflowing with energy, beauty, and dazzling orchestral writing. Then experience the youthful fire and creativity of Beethoven’s Symphony No. 1, a work bursting with charm, wit, and the bold spirit of a composer ready to change music forever.  Perfect for classical music lovers in this relaxed daytime concert offering an inviting atmosphere with friends and fellow patrons.  Wonderful music. Great company. A perfect morning at the symphony."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/morning-music-coffee-friends/"
      }
    ],
