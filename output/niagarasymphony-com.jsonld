  {
    "@id": "https://niagarasymphony.com/event/blockbuster-broadway/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Blockbuster Broadway - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Prepare for an unforgettable concert of pure theatrical brilliance as Broadway's brightest stars take the stage! Join Jessica Hendy, Kelli Rabke, John Boswell, and Scott Coulter for a dazzling celebration of the stage's most iconic hits.  Feel the thrill of soaring melodies and powerful performances from legendary shows like Wicked, The Phantom of the Opera, Annie, Jersey Boys, The Sound of Music, Chicago, CATS, The Lion King, and A Chorus Line.  Be swept away by the sheer talent and passion of these incredible vocalists, each bringing their own unique flair to beloved classics. Experience the magic of Broadway's most unforgettable moments, all in one spectacular concert.  Don't miss this opportunity to be part of a concert that will leave you singing and dancing in your seat!"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://niagarasymphony.com/event/blockbuster-broadway/"
      }
