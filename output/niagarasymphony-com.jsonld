    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Mahler’s Fourth - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Canadian soprano Claire de Sévigné returns to Niagara to muse on the hazy melancholy of childhood in Samuel Barber’s Knoxville: Summer 1915. Mahler’s enchanting Fourth Symphony closes the programme with a child’s serene vision of heaven."
      }
    ],
