      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Postcards from a Blue Planet - Niagara Symphony"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Commissioned by the NSO in 2018, Kevin Lau’s Postcards From A Blue Planet highlights unique habitats with a variety of musical styles and genres. This multi-sensory, audio and visual performance introduces you to wind instruments: flute, alto flute, piccolo, clarinet, saxophone, and bassoon."
      }
    ],
    "http://ogp.me/ns#url": [
      {
