    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "&lt;p&gt;Français English Dans Oppidum, deux personnages sont gardiens d’un grimoire contenant tout leur savoir. Depuis des années, les deux clowns interagissent avec leur environnement grâce aux apprentissages de cette encyclopédie. [&hellip;]&lt;/p&gt;\\n"
      }
