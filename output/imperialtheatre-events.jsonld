    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Thu Sep 3, 2026 • 8:00pm\n\n  \n          Music\n    \n          Tribute\n      \n\n  Event length: 120 minutes\n\n      Admission $35.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Club Rewind: Boy Band Story\n        \n                  \n            Boy Band Story is a world-class tribute to the greatest hits of the world's premiere boy bands of all time.  An entertaining journey that takes you on a trip including pitch perfect melodies and choreography. This dynamic and engaging quartet will top your evening with the biggest hits from Backstreet Boys, NSYNC, Hanson, New Kids on the Block, One Direction, Five, Soul Decision and so much more. An amazing night filled with fun and nostalgia. \n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Tribute      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Kent Theatre\n      \n              24 Coburg St, Saint John, NB E2L 3J5\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/club-rewind-boy-band-story/31601AJQCKSMKVPVHKSNQGKNCQPTMVGLL/#event-31601ajqcksmkvpvhksnqgkncqptmvgll\",\n    \"name\": \"Club Rewind: Boy Band Story\",\n    \"url\": \"https://imperialtheatre.ca/event/club-rewind-boy-band-story/31601AJQCKSMKVPVHKSNQGKNCQPTMVGLL/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"Boy Band Story is a world-class tribute to the greatest hits of the world's premiere boy bands of all time. An entertaining journey that takes you on a trip including pitch perfect melodies and choreography. This dynamic and engaging quartet will top your evening with the biggest hits from Backstreet Boys, NSYNC, Hanson, New Kids on the Block, One Direction, Five, Soul Decision and so much more. An amazing night filled with fun and nostalgia.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/089e33ee-dbab-4a39-beeb-9f4d3b62d74f.jpg\"\n    ],\n    \"startDate\": \"2026-09-03T17:00:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=31601AJQCKSMKVPVHKSNQGKNCQPTMVGLL\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-09-03T17:00:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Age