website/EventDetails.aspx?EventId=20201AVQHKKMVCNSSQSPNTVCQPQCKBBPV\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-10-16T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Loreena McKennitt: The Mask and Mirror\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
