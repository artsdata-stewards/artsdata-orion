    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://imperialtheatre.ca/event/lennie-gallants-innkeeepers-christmas/38601APMJBSGHLBVKJDHHGBQTTKBBSMSJ/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Lennie Gallant's Innkeeepers Christmas"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "$50 A Regular || $45 A Member // $40 B Regular || $35 B Member || \"Celebrate the season in style with Lennie Gallant and his exceptional band as they bring their beloved Christmas concert to the stage! This festive fan favourite blends original holiday songs, heartfelt storytelling, and stunning large- screen visuals for a truly immersive experience. As well as songs from his highly acclaimed original Christmas album, this year’s show will include new compositions and some fabulous new arrangements to some Yuletide favourites! Lennie and his band are spreading cheer with standout tracks like the stellar Christmas Day on Planet Earth, a song already finding its place among modern holiday classics. There are also fun numbers like I’m Gonna Have a Merry Christmas Even If It Kills Me, Love Reigns on Christmas Day, and of course, the iconic show title number, The Innkeeper. After several years of sold-out shows across Eastern Canada, this year’s expanded multimedia production promises to be the most magical yet. Joining Lennie are an all-star lineup: Acadian standout Patricia Richard, virtuoso pianist Julien Robichaud, and gifted violinist Marie-Andrée Gaudet. Together, they’ve been dazzling audiences all year—now they’re ready to fill your holiday with warmth, wonder, laughter, and unforgettable music. Bring your Christmas spirit...and get ready to fall in love with the season all over again.\""
      }
    ],
