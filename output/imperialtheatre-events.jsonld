        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Fri Sep 25, 2026 • 6:00pm\n\n  \n          Comedy\n    \n          Presentation\n      \n\n\n      Admission $57.50\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Tracy & Martina: Live VIP Meet & Greet Add-On\n        \n                  \n            Admission $57.50 | Information about the meet & greet will be provided at a later date. Note: purchase of the VIP meet & greet does not include a ticket to the performance. A ticket to the performance is required for admittance to auditorium.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Comedy      \n    \n          \n        Genre: Presentation      \n    \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/tracy-martina-live-vip-meet-greet-add-on/31401ACGSQBSNGJMMSMSJDBKPVTCCSKMC/#event-31401acgsqbsngjmmsmsjdbkpvtccskmc\",\n    \"name\": \"Tracy & Martina: Live VIP Meet & Greet Add-On\",\n    \"url\": \"https://imperialtheatre.ca/event/tracy-martina-live-vip-meet-greet-add-on/31401ACGSQBSNGJMMSMSJDBKPVTCCSKMC/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.w