    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tFirst City School of Dance: Where Movement Lives\n\t\n\t\n\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Friday, June 12, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 7:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: Adult $25 | Student $15 || Adult (Both Shows) $40 | Student (Both Shows) $22.50\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Dance, Family Friendly\n\n\t\n\n\n\n\t\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Friday, June 12, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 7:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: Adult $25 | Student $15 || Adult (Both Shows) $40 | Student (Both Shows) $22.50\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Dance, Family Friendly\n\n\t\n\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\tWhere Movement Lives is an evening of dance celebrating movement shaped by experience, connection, and purpose.\n\n\t\n\n\n\n\t\t\t\n\t\n\n\t\n\t\t\n\t\n\n\n\t"
