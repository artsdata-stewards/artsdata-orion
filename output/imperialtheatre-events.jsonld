        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sat Sep 5, 2026 • 8:00pm\n\n  \n          Music\n    \n          Tribute\n      \n\n  Event length: 150 minutes\n\n      Admission $58.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Country Boys Tribute\n        \n                  \n            COUNTRY BOYS, a tribute to the music of Alan Jackson, Garth Brooks, Brad Paisley and George Strait. Imagine a concert with these four Country music icons together on one stage, at the same time… The Country Boys show will bring you there!\nFeaturing Scott Delhunty, Gerald Delhunty, Marc Babin and Daniel Goguen, along with 5 other musicians, you’ll hear most of their timeless hit songs, including; Chattahoochee, Friends In Low Places, The Fireman, and Mud On The Tires.\nThe Country Boys band members have backed-up great Country artists such as: Toby Keith, Sammy Kershaw, Ken Mellons, and John Conlee. This is a show for the real Country music fan in you!\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Tribute      \n    \n          \n        Event Length: 150 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/country-boys-tribute/23401AHHMQSVVPPKJGSDQCLPJRGKVPLMQ/#event-23401ahhmqsvvppkjgsdqclpjrgkvplmq\",\n    \"name\": \"Country Boys Tribute\",\n    \"url\": \"https://imperialtheatre.ca/event/country-boys-tribute/23401AHHMQSVVPPKJGSDQCLPJRGKVPLMQ/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$58.00 // COUNTRY BOYS, a tribute to the music of Alan Jackson, Garth Brooks, Brad Paisley and George Strait. Imagine a concert with these four Country music icons together on one stage, at the same time… The Country Boys show will bring you there! Featuring Scott Delhunty, Gerald Delhunty, Marc Babin and Daniel Goguen, along with 5 other musicians, you’ll hear most of their timeless hit songs, including; Chattahoochee, Friends In Low Places, The Fireman, and Mud On The Tires. The Country Boys band members have backed-up great Country artists such as: Toby Keith, Sammy Kershaw, Ken Mellons, and John Conlee. This is a show for the real Country music fan in you!\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/d53dffdf-f027-40d8-9dfb-f2d48fa43122.jpg\"\n    ],\n    \"startDate\": \"2026-09-05T17:00:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=23401AHHMQSVVPPKJGSDQCLPJRGKVPLMQ\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-09-05T17:00:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Country Boys Tribute\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
      }
