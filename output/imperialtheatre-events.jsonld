    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Mon Nov 16, 2026 • 7:00pm\n\n  \n          Film\n    \n          Retro Film\n      \n\n  Event length: 138 minutes\n\n      Admission $10.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Retro Film: A Few Good Men\n        \n                  \n            Rating: R | Year: 1992 // Lt. Daniel Kaffee (Tom Cruise) is a military lawyer defending two U.S. Marines charged with killing a fellow Marine at the Guantánamo Bay Naval Base in Cuba. Although Kaffee is known for seeking plea bargains, a fellow lawyer, Lt. Cdr. JoAnne Galloway (Demi Moore), convinces him that the accused marines were most likely carrying out an order from a commanding officer. Kaffee takes a risk by calling Col. Nathan R. Jessep (Jack Nicholson) to the stand in an effort to uncover the conspiracy.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Film      \n    \n          \n        Genre: Retro Film      \n    \n          \n        Event Length: 138 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/retro-film-a-few-good-men/32201AJKCHKSVHJRMVGRPSJQJNPNNBBBQ/#event-32201ajkchksvhjrmvgrpsjqjnpnnbbbq\",\n    \"name\": \"Retro Film: A Few Good Men\",\n    \"url\": \"https://imperialtheatre.ca/event/retro-film-a-few-good-men/32201AJKCHKSVHJRMVGRPSJQJNPNNBBBQ/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$10.00 // Rating: R | Year: 1992 // Lt. Daniel Kaffee (Tom Cruise) is a military lawyer defending two U.S. Marines charged with killing a fellow Marine at the Guantánamo Bay Naval Base in Cuba. Although Kaffee is known for seeking plea bargains, a fellow lawyer, Lt. Cdr. JoAnne Galloway (Demi Moore), convinces him that the accused marines were most likely carrying out an order from a commanding officer. Kaffee takes a risk by calling Col. Nathan R. Jessep (Jack Nicholson) to the stand in an effort to uncover the conspiracy.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/f2d9b2a8-0418-40b1-929c-1b4f55313f30.jpg\"\n    ],\n    \"startDate\": \"2026-11-16T15:00:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=32201AJKCHKSVHJRMVGRPSJQJNPNNBBBQ\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-11-16T15:00:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Retro Film: A Few Good Men\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
      }
