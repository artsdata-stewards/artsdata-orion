    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://imperialtheatre.ca/event/yamato-the-drummers-of-japan-world-tour-2027/39201APPPJQSCBDBPCLLVKSNCLNHTDTRQ/"
      }
    ],
    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Fri Jan 29, 2027 • 7:30pm\n\n  \n          Other\n    \n          Circus\n      \n\n  Event length: 120 minutes\n\n      Admission $80.00 | Admission $70.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  YAMATO the Drummers of Japan - World Tour 2027\n        \n                  \n            $80 A Regular || $75 A Member // $70 B Regular || $65 B Member ||\nYAMATO is a Japanese Taiko drumming group based in Asuka-mura Nara Prefecture which is well known by Japanese\npeople as the hometown of Japan. They call themselves “YAMATO, the Taiko drumming group that travels all over the\nworld”. They have given more than 5,000 shows across 55countries around the world since their formation in 1993.\nYAMATO’s Taiko work cannot be fully described by the word “performance”.\nThey have performed in theaters, schools, all types of events, and even held workshops and Taiko lessons. They are\nspending a half year on a Japan tour and a half year for the world tour. Their motto is “We go everywhere when somebody\nneeds YAMATO! And bringing energy to the people living in the world!”. They bring joy to the world.\nOn stage, they are standing with more than 40 Taiko drums and all of them are having different characters. For example,\ntheir largest drum called “Odaiko”, produced from a huge tree over 400 years old, is approximately two meters in\ndiameter and weighs 500kg. All other Taiko drums are different sizes and have different sounds.\nThe members of the group have trained their bodies to the limit to beat these massive Taiko drums.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Other      \n    \n          \n        Genre: Circus      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n      \n        \n    \n    \n          \n        Event Sponsor\n        \n                                        \n      \n      \n      \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/yamato-the-drummers-of-japan-world-tour-2027/39201APPPJQSCBDBPCLLVKSNCLNHTDTRQ/#event-39201apppjqscbdbpcllvksnclnhtdtrq\",\n    \"name\": \"YAMATO the Drummers of Japan - World Tour 2027\",\n    \"url\": \"https://imperialtheatre.ca/event/yamato-the-drummers-of-japan-world-tour-2027/39201APPPJQSCBDBPCLLVKSNCLNHTDTRQ/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$80 A Regular || $75 A Member // $70 B Regular || $65 B Member || YAMATO is a Japanese Taiko drumming group based in Asuka-mura Nara Prefecture which is well known by Japanese people as the hometown of Japan. They call themselves “YAMATO, the Taiko drumming group that travels all over the world”. They have given more than 5,000 shows across 55countries around the world since their formation in 1993. YAMATO’s Taiko work cannot be fully described by the word “performance”. They have performed in theaters, schools, all types of events, and even held workshops and Taiko lessons. They are spending a half year on a Japan tour and a half year for the world tour. Their motto is “We go everywhere when somebody needs YAMATO! And bringing energy to the people living in the world!”. They bring joy to the world. On stage, they are standing with more than 40 Taiko drums and all of them are having different characters. For example, their largest drum called “Odaiko”, produced from a huge tree over 400 years old, is approximately two meters in diameter and weighs 500kg. All other Taiko drums are different sizes and have different sounds. The members of the group have trained their bodies to the limit to beat these massive Taiko drums.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/5f77bd7d-5c71-4154-9b3b-054a306e26fb.jpg\"\n    ],\n    \"startDate\": \"2027-01-29T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=39201APPPJQSCBDBPCLLVKSNCLNHTDTRQ\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-01-29T15:30:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"YAMATO the Drummers of Japan - World Tour 2027\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
      }
