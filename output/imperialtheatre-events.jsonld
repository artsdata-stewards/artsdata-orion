    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Wed Mar 17, 2027 • 7:30pm\n\n  \n          Theatre\n    \n          Play\n      \n\n  Event length: 120 minutes\n\n      Adult $55.00 | Senior $50.00 | Student $30.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  SJTC: Murder on the Orient Express\n        \n                  \n            \n\tMurder on the Orient ExpressAll aboard the Orient Express for a thrilling, twist-filled ride! When a passenger is found dead, every glamorous traveler becomes a suspect, and only the brilliant Hercule Poirot can untangle the web of secrets. Fast-paced, suspenseful, and full of shocking twists - this murder mystery will keep you guessing until the very last moment.Performances-Wednesday, March 17th, 2027 at 7:30pm-Thursday, March 18th, 2027 at 7:30pm-Friday, March 19th 2027, at 7:30pm-Saturday, March 20th, 2027 at 2:00pm-Saturday, March 20th, 2027 at 7:30pmPurchase a SJTC Subscription and save 25% off single ticket prices!We are happy to hold prior season subscribers' seats until September 1st 2026. Single tickets on sale September 1st, 2026 at noon.\n\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Theatre      \n    \n          \n        Genre: Play      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t  \t  \n    \tPerformer Website:\n    \t\n      Visit Website\n    \t\n      \n\t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/sjtc-murder-on-the-orient-express/30001ACDNMRPKSDRKSKCJNMSBQHCSMMMG/#event-30001acdnmrpksdrkskcjnmsbqhcsmmmg\",\n    \"name\": \"SJTC: Murder on the Orient Express\",\n    \"url\": \"https://imperialtheatre.ca/event/sjtc-murder-on-the-orient-express/30001ACDNMRPKSDRKSKCJNMSBQHCSMMMG/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$55 Regular | $50 Senior | $30 Student // All aboard the Orient Express for a thrilling, twist-filled ride! When a passenger is found dead, every glamorous traveler becomes a suspect, and only the brilliant Hercule Poirot can untangle the web of secrets. Fast-paced, suspenseful, and full of shocking twists - this murder mystery will keep you guessing until the very last moment.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/6a0c9e91-cf05-49cf-abc3-89533645f209.jpg\"\n    ],\n    \"startDate\": \"2027-03-17T16:30:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=30001ACDNMRPKSDRKSKCJNMSBQHCSMMMG\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-03-17T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"SJTC: Murder on the Orient Express\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
