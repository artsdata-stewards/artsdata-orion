    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Canine Circus Presents: Dogs Do Magic"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Get ready for an unforgettable evening of mind-blowing, hilarious comedy, and jaw-dropping canine tricks in this one-show-only spectacular! Starring one of Canada's favorite magicians, Aaron Matthews--as seen on Disney Plus, YTV, Canada's Wonderland, and the Calgary Stampede--this award-winning show promises excitement for all ages. Mind-Reading Dogs: These talented family pets and rescue dogs will amaze you with impossible feats and dazzling acrobatics! World-Class Canines: All trained using positive reinforcement! Magic &amp; Comedy: Aaron blends illusions with laughter for nonstop fun! Grab your tickets now and feel the magic! [embed]https://youtu.be/CoOEhPsTbt4[/embed]"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ]
  },
