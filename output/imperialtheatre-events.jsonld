    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Tue Dec 1, 2026 • 7:00pm\n\n  \n          Film\n    \n          TIFF\n      \n\n  Event length: 120 minutes\n\n      Admission $12.50\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  TIFF: I Swear\n        \n                  \n            Rating: 14A | Country: United Kingdom | Languages: English | Year: 2026 // Funny, honest, and deeply human, I Swear tells the inspirational true story of John Davidson, a trailblazer whose honesty and humour helped the world better understand what it means to live with Tourette syndrome.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Film      \n    \n          \n        Genre: TIFF      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n      \n        \n    \n          \n        Series Sponsor\n              \n    \n      \n      \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/tiff-i-swear/37802AKQMQCRDGQHPRGHGDKTDKDVRVDTT/#event-37802akqmqcrdgqhprghgdktdkdvrvdtt\",\n    \"name\": \"TIFF: I Swear\",\n    \"url\": \"https://imperialtheatre.ca/event/tiff-i-swear/37802AKQMQCRDGQHPRGHGDKTDKDVRVDTT/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\":