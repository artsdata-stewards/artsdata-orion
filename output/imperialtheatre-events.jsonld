        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Thu Oct 29, 2026 • 7:00pm\n\n  \n          Film\n    \n          Screening\n      \n\n  Event length: 150 minutes\n\n      Admission $40.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Outdoor Outdoor Film Festival\n        \n                  \n            Join us for an evening of short films as The Outdoor Outdoor Film Festival (OOFF) celebrates stories of outdoor playgrounds from around the world. Founded with the mission of sharing natural beauty and adventures in our own backyards, OOFF seeks to bring people together through stories of people living life to their fullest outdoors with special attention to films made in Atlantic Canada.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Film      \n    \n          \n        Genre: Screening      \n    \n          \n        Event Length: 150 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/outdoor-outdoor-film-festival/25801AGPSVCGGNRPVHRSNSQGLMPJPTNDB/#event-25801agpsvcggnrpvhrsnsqglmpjptndb\",\n    \"name\": \"Outdoor Outdoor Film Festival\",\n    \"url\": \"https://imperialtheatre.ca/event/outdoor-outdoor-film-festival/25801AGPSVCGGNRPVHRSNSQGLMPJPTNDB/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$40.00 // Join us for an evening of short films as The Outdoor Outdoor Film Festival (OOFF) celebrates stories of outdoor playgrounds from around the world. Founded with the mission of sharing natural beauty and adventures in our own backyards, OOFF seeks to bring people together through stories of people living life to their fullest outdoors with special attention to films made in Atlantic Canada.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/6a021d25-a8b9-4ccc-b815-4b1eda8ad5b4.jpg\"\n    ],\n    \"startDate\": \"2026-10-29T16:00:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=25801AGPSVCGGNRPVHRSNSQGLMPJPTNDB\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-10-29T16:00:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Outdoor Outdoor Film Festival\"\n    }\