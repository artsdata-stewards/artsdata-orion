    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Classic Albums Live: Led Zeppelin (II)"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Onsale dates: Sept 9 - for Members Sept 12 - Public Classic Albums Live! LED ZEPPELIN - Led Zeppelin II: Is the second studio album by the English rock band Led Zeppelin and is the band’s first album to reach #1 on the UK and U.S. charts.  The album’s production is credited to the band’s lead guitarist and songwriter Jimmy Page and includes the iconic songs, Whole Lotta Love, What Is and What Should Never Be, The Lemon Song and Ramble On.  The album has sold more that 12 million copies in the U.S. and since its release, various writers and music critics cite Led Zeppelin II as one of the greatest and most influential albums of all time."
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ],
