    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Fri Nov 6, 2026 • 7:30pm\n\n  \n          Music\n    \n          Tribute\n      \n\n  Event length: 120 minutes\n\n      Admission $56.25\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Hells Bells\n        \n                  \n            \n\tSince their electrifying inception in 1994 in theheart of Toronto, Hells Bells has soared to becomethe World’s Longest Touring Tribute to thelegendary ACDC, lighting up stages acrossCanada, United States, Mexico and as far as Dubai,United Emirates.Don’t miss your chance to experience the sound,look and attitude, from the wall of MarshallCabinets, the Thundering Cannons, the Giant Bell,and the Mighty Bagpipes!Join us to celebrate the spirit of ACDC !Where the music is contagious, and the memoriesare unforgettable.All Ages! Family friendly!Get ready to rock like never before!WATCH HERE:  HELLS BELLS\n\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Tribute      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t  \t  \n    \tPerformer Website:\n    \t\n      Visit Website\n    \t\n      \n\t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/hells-bells/21001AHGQKHHCBJDNTTTMDTTPLSBDJSQB/#event-21001ahgqkhhcbjdntttmdttplsbdjsqb\",\n    \"name\": \"Hells Bells\",\n    \"url\": \"https://imperialtheatre.ca/event/hells-bells/21001AHGQKHHCBJDNTTTMDTTPLSBDJSQB/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$56.25 // TIME WARP PROMOTIONS PRESENTS: HELLS BELLS Since their electrifying inception in 1994 in the heart of Toronto, Hells Bells has soared to become the world’s longest-touring tribute to the legendary AC/DC, lighting up stages across North America with unstoppable passion and excitement. Don’t miss your chance to experience Hells Bells—a tribute that not only honours but revives the spirit of AC/DC. Join us for a night where the music is contagious, and the memories are unforgettable. All Ages! Family friendly! Get ready to rock like never before! https://www.hellsbellscanada.com/\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/c01f399c-5815-4b28-b2dc-a4557ce58524.jpg\"\n    ],\n    \"startDate\": \"2026-11-06T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=21001AHGQKHHCBJDNTTTMDTTPLSBDJSQB\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-11-06T15:30:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Hells Bells\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
      }
    ]
