    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Fri Dec 4, 2026 • 5:00pm\n\n  \n          Film\n    \n          Screening\n      \n\n\n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Family Sparkles Film Festival\n        \n                  \n            5 PM - Charlie Brown Christmas\n6 PM - Frosty the Snowman\n7 PM - Mickey's Christmas Carol\n8 PM - Rudolph the Red-Nosed Reindeer\nMember RSVP: up to 4 tickets // Join us for a free and fun night of holiday films! Every hour on the hour, we're going to show a different classic! IT Members can reserve up to four seats in our Member VIP section in the Balcony, and join us at Golding's Lounge in the Upper Lobby for treats. Stay for one film or stay for them all, then go enjoy all that Uptown Sparkles has to offer. [IT Members are welcome to sit on the Orchestra level, but it will be open to the public]\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Film      \n    \n          \n        Genre: Screening      \n    \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/family-sparkles-film-festival/44801AVQJMVSBSCDMRGLRKNLTGJPHPNQG/#event-44801avqjmvsbscdmrglrknltgjphpnqg\",\n    \"name\": \"Family Sparkles Film Festival\",\n    \"url\": \"https://imperialtheatre.ca/event/family-sparkles-film-festival/44801AVQJMVSBSCDMRGLRKNLTGJPHPNQG/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"5 PM - Charlie Brown Christmas 6 PM - Frosty the Snowman 7 PM - Mickey's Christmas Carol 8 PM - Rudolph the Red-Nosed Reindeer Member RSVP: up to 4 tickets // Join us for a free and fun night of holiday films! Every hour on the hour, we're going to show a different classic! IT Members can reserve up to four seats in our Member VIP section in the Balcony, and join us at Golding's Lounge in the Upper Lobby for treats. Stay for one film or stay for them all, then go enjoy all that Uptown Sparkles has to offer. [IT Members are welcome to sit on the Orchestra level, but it will be open to the public]\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/25d2fdf1-9777-4bbb-bfa5-caa88c72e107.jpg\"\n    ],\n    \"startDate\": \"2026-12-04T13:00:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=44801AVQJMVSBSCDMRGLRKNLTGJPHPNQG\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-12-04T13:00:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Family Sparkles Film Festival\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
      }
