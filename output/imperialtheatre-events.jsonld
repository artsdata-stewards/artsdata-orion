        "@language": "en",
        "@value": "\n\n\t\t\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tChristmas from the Heart\n\t\n\t\n\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Sunday, December 06, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 3:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: $36\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Community, Family Friendly, Music - Choir, Christmas theme\n\n\t\n\n\n\n\t\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Sunday, December 06, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 3:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: $36\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Community, Family Friendly, Music - Choir, Christmas theme\n\n\t\n\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\tMusic from the Heart presents: Christmas from the Heart. A Holiday Showcase featuring Raise your voice Ladies Choirs, Treble Makers, Tiny Tunes and Pitch Perfect with special guests Sistema NB. Directed by Elaine Boulanger. An afternoon of festive music sure to get you in the holiday Spirit.\n\n\t\n\n\n\n\t\t\t\