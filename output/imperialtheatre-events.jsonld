    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sun Nov 8, 2026 • 7:30pm\n\n  \n          Music\n    \n          Community\n      \n\n\n      Admission $58.75\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Men of the Deeps - 60th Anniversary \n        \n                  \n            Admission $58.75 // In their 60th Anniversary year, Cape Breton’s own coal miners' chorus remembers those men whose lamps have all gone down and honours those who still carry the light forward. Sharing the stories they’ve lived and singing about life underground.\nWe invite you to share in a sixty-year legacy that continues to shine on, not in coal, but in memory, community, story, and song.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Community      \n    \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/men-of-the-deeps-60th-anniversary/26801APBDSSBSQMVTPLPRDJQMMKCLMHMP/#event-26801apbdssbsqmvtplprdjqmmkclmhmp\",\n    \"name\": \"Men of the Deeps - 60th Anniversary\",\n    \"url\": \"https://imperialtheatre.ca/event/men-of-the-deeps-60th-anniversary/26801APBDSSBSQMVTPLPRDJQMMKCLMHMP/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"Admission $58.75 // In their 60th Anniversary year, Cape Breton’s own coal miners' chorus remembers those men whose lamps have all gone down and honours those who still carry the light forward. Sharing the stories they’ve lived and singing about life underground. We invite you to share in a sixty-year legacy that continues to shine on, not in coal, but in memory, community, story, and song.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/d63e82c2-a374-46b4-acbf-dc4346522b60.jpg\"\n    ],\n    \"startDate\": \"2026-11-08T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=26801APBDSSBSQMVTPLPRDJQMMKCLMHMP\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-11-08T15:30:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Men of the Deeps - 60th Anniversary\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\