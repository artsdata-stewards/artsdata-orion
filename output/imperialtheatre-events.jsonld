    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Fri Feb 5, 2027 • 7:30pm\n\n  \n          Music\n    \n          Presentation\n      \n\n  Event length: 55 minutes\n\n      Admission $60.00 | Admission $50.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Take This Waltz: Celebrating the Music of Leonard Cohen\n        \n                  \n            $60 A Regular || $55 A Member // $50 B Regular || $45 B Member ||\nThis evening of music, dance, and stunning visuals, staged by Israeli choreographer and director Idan Cohen of Ne. Sans Opera & Dance, celebrates the legendary Canadian singer-songwriter Leonard Cohen. Performers featured are world-renowned Canadian bass-baritone Daniel Okulitch, described as “flat-out brilliant” by Opera News, the multi-talented dancer/musician Ted Littlemore, and a classical chamber ensemble of violin, accordion and cello.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Presentation      \n    \n          \n        Event Length: 55 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/take-this-waltz-celebrating-the-music-of-leonard-cohen/37603AMJMLBHLQKKMRBSCPMHRTHPVVJDM/#event-37603amjmlbhlqkkmrbscpmhrthpvvjdm\",\n    \"name\": \"Take This Waltz: Celebrating the Music of Leonard Cohen\",\n    \"url\": \"https://imperialtheatre.ca/event/take-this-waltz-celebrating-the-music-of-leonard-cohen/37603AMJMLBHLQKKMRBSCPMHRTHPVVJDM/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$60 A Regular || $55 A Member // $50 B Regular || $45 B Member || This evening of music, dance, and stunning visuals, staged by Israeli choreographer and director Idan Cohen of Ne. Sans Opera & Dance, celebrates the legendary Canadian singer-songwriter Leonard Cohen. Performers featured are world-renowned Canadian bass-baritone Daniel Okulitch, described as “flat-out brilliant” by Opera News, the multi-talented dancer/musician Ted Littlemore, and a classical chamber ensemble of violin, accordion and cello.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/8ded95f7-c8f2-4e51-8556-07cfd897113b.jpg\"\n    ],\n    \"startDate\": \"2027-02-05T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=37603AMJMLBHLQKKMRBSCPMHRTHPVVJDM\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-02-05T15:30:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Take This Waltz: Celebrating the Music of Leonard Cohen\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
