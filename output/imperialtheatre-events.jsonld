    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Fri Dec 11, 2026 • 7:00pm\n\n  \n          Dance\n    \n          Ballet\n      \n\n\n      Adult $39.00 | Senior $34.00 | Student $26.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  The Nutcracker\n        \n                  \n            Regular $39 || Senior/Member $34 || Student $26 ||\nGala Ballet Production Inc. and Rothesay Ballet School Present \"The Nutcracker\", a cherished holiday story by E.T.A. Hoffman. Professional guest artists join local dancers in this classic ballet! The Nutcracker Soldier will battle the Mouse King to protect Clara, while the Sugarplum Fairy, her beloved Cavalier Prince, and all the dolls and candies will come to life on stage! This is a holiday tradition for all ages. \n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Dance      \n    \n          \n        Genre: Ballet      \n    \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/the-nutcracker/44601AVBDVLNHRGJHQBVDLKSCHSSDGBJK/#event-44601avbdvlnhrgjhqbvdlkschssdgbjk\",\n    \"name\": \"The Nutcracker\",\n    \"url\": \"https://imperialtheatre.ca/event/the-nutcracker/44601AVBDVLNHRGJHQBVDLKSCHSSDGBJK/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"Regular $39 || Senior/Member $34 || Student $26 || Gala Ballet Production Inc. and Rothesay Ballet School Present \\\"The Nutcracker\\\", a cherished holiday story by E.T.A. Hoffman. Professional guest artists join local dancers in this classic ballet! The Nutcracker Soldier will battle the Mouse King to protect Clara, while the Sugarplum Fairy, her beloved Cavalier Prince, and all the dolls and candies will come to life on stage! This is a holiday tradition for all ages.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/1751d210-7556-40fd-b2c5-0ecb23835dab.jpg\"\n    ],\n    \"startDate\": \"2026-12-11T15:00:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=44601AVBDVLNHRGJHQBVDLKSCHSSDGBJK\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-12-11T15:00:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Age