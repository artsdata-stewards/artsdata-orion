    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sun Mar 7, 2027 • 7:30pm\n\n  \n          Theatre\n    \n          Circus\n      \n\n  Event length: 55 minutes\n\n      Admission $50.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  By a Thread: One Fell Swoop Circus\n        \n                  \n            $50 Regular || $45 Member ||\nSEVEN ACROBATS AND 30 METRES OF ROPE\nLong spools of white rope run through pulley sheaves and wrap around\nbodies, explicitly connecting the artists’ movements above and off the\nground. Like the booms and sheets of a sailing ship the performers are\nhoisted and swung by one another to create striking tableaux and breath-\ntaking dynamics. The actions of one acrobat affect and implicate the\nmovements of others in a mesmerising negotiation of cause and effect.\nBy A Thread offers rich visuals of inventive aerial acrobatics from some of\nAustralia’s best circus artists. The relationships between ensemble\nmembers on stage mimic the everyday relationships we have as human\nbeings. The acrobatic ensemble is the vehicle through which ideas of risk\nand trust are explored, creating an intimate audience experience around\nthe dangers and joys implicit in engaging with others.\nMore than mere bodies in space, By A Thread is an exploration of\ntensions physical, emotional and relational.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Theatre      \n    \n          \n        Genre: Circus      \n    \n          \n        Event Length: 55 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n      \n        \n    \n    \n          \n        Event Sponsors\n        \n                                                              \n      \n      \n      \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/by-a-thread-one-fell-swoop-circus/42001AQJJQTSKLLKMRKNHHDRNVHRLPNPB/#event-42001aqjjqtskllkmrknhhdrnvhrlpnpb\",\n    \"name\": \"By a Thread: One Fell Swoop Circus\",\n    \"url\": \"https://imperialtheatre.ca/event/by-a-thread-one-fell-swoop-circus/42001AQJJQTSKLLKMRKNHHDRNVHRLPNPB/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$50 Regular || $45 Member || SEVEN ACROBATS AND 30 METRES OF ROPE Long spools of white rope run through pulley sheaves and wrap around bodies, explicitly connecting the artists’ movements above and off the ground. Like the booms and sheets of a sailing ship the performers are hoisted and swung by one another to create striking tableaux and breath- taking dynamics. The actions of one acrobat affect and implicate the movements of others in a mesmerising negotiation of cause and effect. By A Thread offers rich visuals of inventive aerial acrobatics from some of Australia’s best circus artists. The relationships between ensemble members on stage mimic the everyday relationships we have as human beings. The acrobatic ensemble is the vehicle through which ideas of risk and trust are explored, creating an intimate audience experience around the dangers and joys implicit in engaging with others. More than mere bodies in space, By A Thread is an exploration of tensions physical, emotional and relational.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/2530705d-2273-4167-aaca-a8e7fd04ec64.jpg\"\n    ],\n    \"startDate\": \"2027-03-07T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=42001AQJJQTSKLLKMRKNHHDRNVHRLPNPB\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-03-07T15:30:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"By a Thread: One Fell Swoop Circus\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
      }
    ]
