    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Tue Sep 29, 2026 • 7:00pm\n\n  \n          Theatre\n    \n          Play\n      \n\n\n      Admission $69.00 | Admission $64.00 | Admission $59.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  SEVEN DRUNKEN NIGHTS: The Story Of The Dubliners\n        \n                  \n            Admission $69 || $64 || $59 ||\nDirect from Dublin and London’s West End!\nProudly celebrating its incredible 10th Anniversary Seven Drunken Nights - The\nStory of The Dubliners is back for 2026!\nPerformed by a phenomenal cast of Irish Musicians, the show is packed full of\nclassics like Whiskey in the Jar, The Irish Rover and Rocky Road to Dublin -\nguaranteed to get your toes tapping as they bring the joy of this much-loved Irish\nfolk band back to the stage.\nThis ultimate feel-good production celebrates the musical mastery of The\nDubliners, Ireland's favourite sons, in association with the legendary\nO'Donoghue's pub.\nWith breathtaking performances and authentic Irish spirit, the show spans over 50\nyears, commemorating The Story of The Dubliners for a night of great music, and\na celebration of the band that influenced many generations of Irish music.\nDon't miss your chance to see the world class production that's brought a decade\nof unforgettable nights to packed out theatres. Seven Drunken Nights is the\nultimate Irish show that has audiences across the globe returning year after year.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Theatre      \n    \n          \n        Genre: Play      \n    \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/seven-drunken-nights-the-story-of-the-dubliners/46201AMLCVHRCMSRMCBPBJCBDJSGKTGPC/#event-46201amlcvhrcmsrmcbpbjcbdjsgktgpc\",\n    \"name\": \"SEVEN DRUNKEN NIGHTS: The Story Of The Dubliners\",\n    \"url\": \"https://imperialtheatre.ca/event/seven-drunken-nights-the-story-of-the-dubliners/46201AMLCVHRCMSRMCBPBJCBDJSGKTGPC/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"Admission $69 || $64 || $59 || Direct from Dublin and London’s West End! Proudly celebrating its incredible 10th Anniversary Seven Drunken Nights - The Story of The Dubliners is back for 2026! Performed by a phenomenal cast of Irish Musicians, the show is packed full of classics like Whiskey in the Jar, The Irish Rover and Rocky Road to Dublin - guaranteed to get your toes tapping as they bring the joy of this much-loved Irish folk band back to the stage. This ultimate feel-good production celebrates the musical mastery of The Dubliners, Ireland's favourite sons, in association with the legendary O'Donoghue's pub. With breathtaking performances and authentic Irish spirit, the show spans over 50 years, commemorating The Story of The Dubliners for a night of great music, and a celebration of the band that influenced many generations of Irish music. Don't miss your chance to see the world class production that's brought a decade of unforgettable nights to packed out theatres. Seven Drunken Nights is the ultimate Irish show that has audiences across the globe returning year after year.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/ba18e984-f25f-4a12-9492-c00a076d8cb5.jpg\"\n    ],\n    \"startDate\": \"2026-09-29T16:00:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=46201AMLCVHRCMSRMCBPBJCBDJSGKTGPC\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-09-29T16:00:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"SEVEN DRUNKEN NIGHTS: The Story Of The Dubliners\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
      }
