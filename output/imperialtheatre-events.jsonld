        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Thu Nov 5, 2026 • 7:30pm\n\n  \n          Dance\n    \n          Circus\n      \n\n  Event length: 75 minutes\n\n      Admission $50.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Sophie's Surprise 29th\n        \n                  \n            $50 Regular || $45 Member ||\n\"Sophie’s Surprise 29th is an immersive circus and cabaret show.\nIt is full of humour, music grown-up fun. \nFeaturing world-leading performers from La Clique, The 7 Fingers, Cirque du Soleil\nand more, this is circus and comedy disguised as the best house party of your life.\nDeath-defying circus and cabaret feats weaved into a nostalgic 90s house party, set\nto a pumping soundtrack of old faves including Sugababes, Basement Jaxx and The\nKillers.\nWhat more could you ask for in a night out?\"\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Dance      \n    \n          \n        Genre: Circus      \n    \n          \n        Event Length: 75 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n      \n        \n    \n    \n          \n        Event Sponsor\n        \n                                        \n      \n      \n      \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/sophies-surprise-29th/36801AVRGVGRDVPNHVPNNQVLKLPKNJBND/#event-36801avrgvgrdvpnhvpnnqvlklpknjbnd\",\n    \"name\": \"Sophie's Surprise 29th\",\n    \"url\": \"https://imperialtheatre.ca/event/sophies-surprise-29th/36801AVRGVGRDVPNHVPNNQVLKLPKNJBND/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$50 Regular || $45 Member || \\\"Sophie’s Surprise 29th is an immersive circus and cabaret show. It is full of humour, music grown-up fun. Featuring world-leading performers from La Clique, The 7 Fingers, Cirque du Soleil and more, this is circus and comedy disguised as the best house party of your life. Death-defying circus and cabaret feats weaved into a nostalgic 90s house party, set to a pumping soundtrack of old faves including Sugababes, Basement Jaxx and The Killers. What more could you ask for in a night out?\\\"\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/6d44b2be-2b54-46ee-8589-0f2a70649398.jpg\"\n    ],\n    \"startDate\": \"2026-11-05T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=36801AVRG