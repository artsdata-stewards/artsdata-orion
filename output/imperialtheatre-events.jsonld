        "@language": "en",
        "@value": "\n\n\t\t\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tDal Med Launch Ceremony 2026\n\t\n\t\n\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Friday, May 08, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 2:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: Free\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Graduation Ceremony\n\n\t\n\n\n\n\t\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Friday, May 08, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 2:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: Free\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Graduation Ceremony\n\n\t\n\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\t\n\n\n\n\t\t\t\n\t\n\n\t\n\t\t\n\t\n\n\n\t"
