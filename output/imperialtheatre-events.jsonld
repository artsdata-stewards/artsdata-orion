    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Boy Band Story is a world-class tribute to the greatest hits of the world's premiere boy bands of all time. An entertaining journey that takes you on a trip including pitch perfect melodies and choreography. This dynamic and engaging quartet will top your evening with the biggest hits from Backstreet Boys, NSYNC, Hanson, New Kids on the Block, One Direction, Five, Soul Decision and so much more. An amazing night filled with fun and nostalgia."
      }
