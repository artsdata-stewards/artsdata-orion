    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Saint John Mayoral Candidates Forum"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "THIS IS NOT A TICKETED EVENT. With just weeks to go before the municipal election, Saint John residents will have a final, high-profile opportunity to hear directly from those seeking the city’s top elected office at the Mayoral Candidate Forum on Tuesday, April 28 at the Imperial Theatre. Hosted by the Human Development Council and Civic Tech Saint John as part of the Saint John Votes 2026 initiative, the forum will bring mayoral candidates together on one stage to share their priorities, respond to community questions, and discuss the future direction of the city. The event is free and open to the public, with doors opening at 5:30 p.m. Residents are encouraged to attend in person to hear directly from the candidates and participate in an informed democratic process. The forum will also be livestreamed. All the candidates and details can be found here: https://strongtownssj.ca/election-2026/mayor/ Community-Driven Questions Residents can submit questions through an online survey, helping shape the conversation at each forum and ensuring real community concerns—especially around housing, poverty, and access to services—are front and centre. [maxbutton id=\"3\" url=\"https://forms.office.com/pages/responsepage.aspx?id=0m5OJJoz80e5XORTUcGYt-Y-ElqBfOtPsmpGZiqUTHhUNVJTRkxUMzBROUI2N0pNQ0JNSklIMk80Ny4u&amp;route=shorturl\" text=\"SUBMIT A QUESTION \" ]"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ]
  },
  {
    "@id": "https://imperialtheatre.ca/temporary/1a50c3cf-b5be-43bc-be05-d896f1d2491c",
