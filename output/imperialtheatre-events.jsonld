        "@value": "Imperial Theatre"
      }
    ]
  },
  {
    "@id": "https://imperialtheatre.ca/temporary/ab31cdf8-bb65-44dd-9c1a-662635e52f2c",
    "@type": [
      "https://schema.org/WebPage"
    ],
