    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Thu Apr 15, 2027 • 7:30pm\n\n  \n          Theatre\n    \n          Musical\n      \n\n  Event length: 80 minutes\n\n      Admission $30.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Hey Viola!\n        \n                  \n            $30 Regular || $10 Member ||\nHey Viola! is a musical production created by Krystle Dos Santos and Tracey Power that explores the life and legacy of Canadian civil rights hero Viola Desmond.\nThe show serves as both a history lesson and a musical revue, highlighting Desmond’s courage as a businesswoman, feminist, and civil rights pioneer who famously challenged racial segregation at Nova Scotia’s Roseland cinema in 1946.\nFormat: The production uses inspirational music to tell Desmond’s story, featuring a diverse song list including tracks like \"\"A Change is Gonna Come\"\" and \"\"Feeling Good\"\".        Lead Performer: Krystle Dos Santos.\nDirector/Co-Creator: Tracey Power.\nAssociate Director: Sereana Malani.\nMusicians: Steve Charles (MD/Guitar/Bass), Chris Davis (Drums/Trumpet), and Mary Ancheta (Piano).\nDesigners: Drew Facey (Set), CS Fergusson-Vaux (Costume), and Jillian White (Lighting).\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Theatre      \n    \n          \n        Genre: Musical      \n    \n          \n        Event Length: 80 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n      \n        \n    \n    \n          \n        Event Sponsor\n        \n                                        \n      \n      \n      \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/hey-viola/43201AJDRNMMDNNQTNJHJVCVNCQGVJMVN/#event-43201ajdrnmmdnnqtnjhjvcvncqgvjmvn\",\n    \"name\": \"Hey Viola!\",\n    \"url\": \"https://imperialtheatre.ca/event/hey-viola/43201AJDRNMMDNNQTNJHJVCVNCQGVJMVN/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$30 Regular || $10 Member || Hey Viola! is a musical production created by Krystle Dos Santos and Tracey Power that explores the life and legacy of Canadian civil rights hero Viola Desmond. The show serves as both a history lesson and a musical revue, highlighting Desmond’s courage as a businesswoman, feminist, and civil rights pioneer who famously challenged racial segregation at Nova Scotia’s Roseland cinema in 1946. Format: The production uses inspirational music to tell Desmond’s story, featuring a diverse song list including tracks like \\\"\\\"A Change is Gonna Come\\\"\\\" and \\\"\\\"Feeling Good\\\"\\\". Lead Performer: Krystle Dos Santos. Director/Co-Creator: Tracey Power. Associate Director: Sereana Malani. Musicians: Steve Charles (MD/Guitar/Bass), Chris Davis (Drums/Trumpet), and Mary Ancheta (Piano). Designers: Drew Facey (Set), CS Fergusson-Vaux (Costume), and Jillian White (Lighting).\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/058a39cb-a923-492f-aae1-a7f243f4d123.jpg\"\n    ],\n    \"startDate\": \"2027-04-15T16:30:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=43201AJDRNMMDNNQTNJHJVCVNCQGVJMVN\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-04-15T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Hey Viola!\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
