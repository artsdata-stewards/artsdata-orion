    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Grace, 2 - Celebrating The Tragically Hip"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "$54.50 // Join us for a night of Canadian anthems and community spirit as the Second Annual \"Tour For the Cure\" rolls into Saint John. To truly honour the legacy of Gord Downie, Grace, 2 believes we must use the power and influence of The Tragically Hip’s music to drive change. Gord asked us all to \"do something,\" and so we shall. United by the soundtrack of a generation, this event aims to raise vital funds and awareness for The Canadian Cancer Society. By gathering to sing the songs we love, we are also joining in the fight for a future where no one has to face cancer alone."
      }
    ],
