      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "In their 60th Anniversary year, Cape Breton’s own coal miners' chorus remembers those men whose lamps have all gone down and honours those who still carry the light forward. Sharing the stories they’ve lived and singing about life underground. We invite you to share in a sixty-year legacy that continues to shine on, not in coal, but in memory, community, story, and song."
      }
    ],
