    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Nutcracker"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Regular $39 || Senior/Member $34 || Student $26 || Gala Ballet Production Inc. and Rothesay Ballet School Present \"The Nutcracker\", a cherished holiday story by E.T.A. Hoffman. Professional guest artists join local dancers in this classic ballet! The Nutcracker Soldier will battle the Mouse King to protect Clara, while the Sugarplum Fairy, her beloved Cavalier Prince, and all the dolls and candies will come to life on stage! This is a holiday tradition for all ages."
      }
    ],
