        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sun Dec 6, 2026 • 3:00pm\n\n  \n          Music\n    \n          Community\n      \n\n  Event length: 100 minutes\n\n      Admission $36.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Christmas from the Heart\n        \n                  \n            Music from the Heart presents: Christmas from the Heart. A Holiday Showcase featuring Raise your voice Ladies Choirs, Treble Makers, Tiny Tunes and Pitch Perfect with special guests Sistema NB. Directed by Elaine Boulanger. An afternoon of festive music sure to get you in the holiday Spirit.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Community      \n    \n          \n        Event Length: 100 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/christmas-from-the-heart/26001APLNVRTPLBBPSVMJQSVGGNQMBRBG/#event-26001aplnvrtplbbpsvmjqsvggnqmbrbg\",\n    \"name\": \"Christmas from the Heart\",\n    \"url\": \"https://imperialtheatre.ca/event/christmas-from-the-heart/26001APLNVRTPLBBPSVMJQSVGGNQMBRBG/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\