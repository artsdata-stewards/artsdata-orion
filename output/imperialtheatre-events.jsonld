    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Can You Sing Canada presents Saint John Sings!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "$40 Regular || $35 Member || \"Can You Sing Canada\" is an all-ages singing showcase in its seventh year that provides local singers the opportunity to perform live on stage with a professional all-star rock band. The production aims to discover local talent across various genres, including rock, country, piano ballads, crooner, and pop. Performances are backed by industry veterans who have worked with renowned acts such as Burton Cummings, Big Wreck, Moist, David Usher, Helix, and Killer Dwarfs. The Process Auditions: Held 2–3 months before the show, auditions take place in-person at the host venue. Between 80–150 people generally attend, with the team handling outreach, hosting, and selection. Selection: 15–20 singers are chosen to perform. Preparation: The team coordinates song choices and key changes with selected performers. A sound check and rehearsal occur on the day of the show. AUDITIONS will be held on the Imperial stage Sunday, July 12 9:30 -12 noon & 2-5pm. REGISTER HERE: https://www.canyousing.ca/register"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
