    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sat Nov 14, 2026 • 7:30pm\n\n  \n          Music\n    \n          Folk / Alt\n      \n\n  Event length: 75 minutes\n\n      Admission $40.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Mass for Shut-Outs\n        \n                  \n            $40 Regular || $35 Member ||\n\"Mass for Shut-Outs is a shout out to anyone grappling with the complexity of faith, the inconsistency of awe, and the politics of organized religion. Loosely referencing the framework of a Catholic mass, it is a poetic take on Sunday service, exploring enduring questions through a joyful, critical, and comedic lens. It is for atheists seeking connection, agnostics asking questions, and believers kindly curious about other people’s gods.\n\"\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Folk / Alt      \n    \n          \n        Event Length: 75 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/mass-for-shut-outs/38001AJMJGLMVGBGPDQNMJJMCJDLNBDQB/#event-38001ajmjglmvgbgpdqnmjjmcjdlnbdqb\",\n    \"name\": \"Mass for Shut-Outs\",\n    \"url\": \"https://imperialtheatre.ca/event/mass-for-shut-outs/38001AJMJGLMVGBGPDQNMJJMCJDLNBDQB/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$40 Regular || $35 Member || \\\"Mass for Shut-Outs is a shout out to anyone grappling with the complexity of faith, the inconsistency of awe, and the politics of organized religion. Loosely referencing the framework of a Catholic mass, it is a poetic take on Sunday service, exploring enduring questions through a joyful, critical, and comedic lens. It is for atheists seeking connection, agnostics asking questions, and believers kindly curious about other people’s gods. \\\"\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/6c651dfa-97b8-4821-9981-191321cf4781.jpg\"\n    ],\n    \"startDate\": \"2026-11-14T15:30:00-04:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=38001AJMJGLMVGBGPDQNMJJMCJDLNBDQB\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-11-14T15:30:00-04:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        