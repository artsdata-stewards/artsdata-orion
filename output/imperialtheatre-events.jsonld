      {
        "@language": "en",
        "@value": "Imperial Theatre"
      }
    ]
  },
  {
    "@id": "https://imperialtheatre.ca/temporary/ea7b7239-d446-4ed1-b8a8-6e6ffb01b705",
    "@type": [
      "https://schema.org/WebPage"
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
