        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sun Dec 20, 2026 • 2:00pm\n\n  \n          Music\n    \n          Community\n      \n\n  Event length: 60 minutes\n\n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Imperial Holiday Sing Along\n        \n                  \n            An annual sing along that is free and open to everyone. Join us to sing or just to listen. All welcome.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Community      \n    \n          \n        Event Length: 60 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/imperial-holiday-sing-along/37602ALKKDHHGRMMTJJNPRTLSCQHRJTSL/#event-37602alkkdhhgrmmtjjnprtlscqhrjtsl\",\n    \"name\": \"Imperial Holiday Sing Along\",\n    \"url\": \"https://imperialtheatre.ca/event/imperial-holiday-sing-along/37602ALKKDHHGRMMTJJNPRTLSCQHRJTSL/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress