    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Thu Apr 1, 2027 • 7:30pm\n\n  \n          Music\n    \n          Pop\n      \n\n  Event length: 120 minutes\n\n      Admission $65.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n      \n      IT Member Event\n    \n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Dwayne Gretzky\n        \n                  \n            $65 Regular || $60 Member || Canada’s greatest party band is back with Big Shiny Dwayne - a can’t miss live music experience celebrating classic hits from the 90s. Celebrating the classic pop and rock songs that unite people across generations, Dwayne Gretzky has delivered electrifying renditions of over 800 songs.\nFor the past 15 years, Dwayne Gretzky has developed a fervent fanbase across Canada solely on the strength of their live show – performing timeless classic hits with faithful precision, and breathtaking energy not seen in these songs since the original artists in their prime. This culminated in the band headlining one of Toronto’s biggest outdoor venues, Budweiser Stage, to over 7000 people in the summer of 2025. Also in summer 2025, the band launched their new Youtube series, Dwayne’s World, which has gone viral and caught the attention of music fans globally, expanding their audience through the world.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Pop      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/dwayne-gretzky/41602ACQKSQHLPVVRQGPMQSJQTTRRKTRJ/#event-41602acqksqhlpvvrqgpmqsjqttrrktrj\",\n    \"name\": \"Dwayne Gretzky\",\n    \"url\": \"https://imperialtheatre.ca/event/dwayne-gretzky/41602ACQKSQHLPVVRQGPMQSJQTTRRKTRJ/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$65 Regular || $60 Member || Canada’s greatest party band is back with Big Shiny Dwayne - a can’t miss live music experience celebrating classic hits from the 90s. Celebrating the classic pop and rock songs that unite people across generations, Dwayne Gretzky has delivered electrifying renditions of over 800 songs. For the past 15 years, Dwayne Gretzky has developed a fervent fanbase across Canada solely on the strength of their live show – performing timeless classic hits with faithful precision, and breathtaking energy not seen in these songs since the original artists in their prime. This culminated in the band headlining one of Toronto’s biggest outdoor venues, Budweiser Stage, to over 7000 people in the summer of 2025. Also in summer 2025, the band launched their new Youtube series, Dwayne’s World, which has gone viral and caught the attention of music fans globally, expanding their audience through the world.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/ce4225bf-272d-4bfc-a8f5-788f725f7602.jpg\"\n    ],\n    \"startDate\": \"2027-04-01T16:30:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=41602ACQKSQHLPVVRQGPMQSJQTTRRKTRJ\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-04-01T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Dwayne Gretzky\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
