    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sat Oct 3, 2026 • 7:30pm\n\n  \n          Music\n    \n          Tribute\n      \n\n  Event length: 150 minutes\n\n      Admission $54.50\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Grace, 2 - Celebrating The Tragically Hip\n        \n                  \n            Join us for a night of Canadian anthems and community spirit as the Second Annual \"Tour For the Cure\" rolls into Saint John. To truly honour the legacy of Gord Downie, Grace, 2 believes we must use the power and influence of The Tragically Hip’s music to drive change. Gord asked us all to \"do something,\" and so we shall. United by the soundtrack of a generation, this event aims to raise vital funds and awareness for The Canadian Cancer Society. By gathering to sing the songs we love, we are also joining in\nthe fight for a future where no one has to face cancer alone.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Tribute      \n    \n          \n        Event Length: 150 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/grace-2-celebrating-the-tragically-hip/22801AGSKTJDCRVHCKQCVVHGLQCVGCCGM/#event-22801agsktjdcrvhckqcvvhglqcvgccgm\",\n    \"name\": \"Grace, 2 - Celebrating The Tragically Hip\",\n    \"url\": \"https://imperialtheatre.ca/event/grace-2-celebrating-the-tragically-hip/22801AGSKTJDCRVHCKQCVVHGLQCVGCCGM/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$54.50 // Join us for a night of Canadian anthems and community spirit as the Second Annual \\\"Tour For the Cure\\\" rolls into Saint John. To truly honour the legacy of Gord Downie, Grace, 2 believes we must use the power and influence of The Tragically Hip’s music to drive change. Gord asked us all to \\\"do something,\\\" and so we shall. United by the soundtrack of a generation, this event aims to raise vital funds and awareness for The Canadian Cancer Society. By gathering to sing the songs we love, we are also joining in the fight for a future where no one has to face cancer alone.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/9d2fa15e-7e87-474b-99ef-5f254da397e8.jpg\"\n    ],\n    \"startDate\": \"2026-10-03T16:30:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=22801AGSKTJDCRVHCKQCVVHGLQCVGCCGM\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-10-03T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Grace, 2 - Celebrating The Tragically Hip\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
      }
