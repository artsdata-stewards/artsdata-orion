    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Wed Oct 21, 2026 • 7:30pm\n\n  \n          Music\n    \n          Rock\n      \n\n  Event length: 130 minutes\n\n      Admission $79.00 | Admission $69.00 | Admission $59.00 | Student $49.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Relive the Music: 50's 60's and 70's Show\n        \n                  \n            Price Level One $79 || Price Level Two $69 || Price Level Three $59 || Student $49 ||\n\"RELIVE THE MUSIC\" is now even better as we’ve cranked it up a notch by adding the biggest hits of 70s ROCK, DISCO & FUNK. We still keep the biggest, most popular hits of the 50s & 60s, but have added our favourite 70s Artists.  \n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Rock      \n    \n          \n        Event Length: 130 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/relive-the-music-50s-60s-and-70s-show/35201AQQRSLKMCNNBJNMJCGMJTGPJQHBV/#event-35201aqqrslkmcnnbjnmjcgmjtgpjqhbv\",\n    \"name\": \"Relive the Music: 50's 60's and 70's Show\",\n    \"url\": \"https://imperialtheatre.ca/event/relive-the-music-50s-60s-and-70s-show/35201AQQRSLKMCNNBJNMJCGMJTGPJQHBV/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.o