    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sat Oct 17, 2026 • 7:30pm\n\n  \n          Music\n    \n          Tribute\n      \n\n  Event length: 120 minutes\n\n      Admission $56.25\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  The Piano Men\n        \n                  \n            \n\t$56.25 // TIME WARP PROMOTIONS PRESENTS THE PIANO MEN – Celebrating the music of Billy Joel and Elton John Get ready for an ultimate concert experience that is out of this world! Together, Billy Joel and Elton John have sold over a billion records worldwide. Join us in a tribute to and celebration of two of the biggest musical superstars on the planet. This full band musical experience with musicians from Rock of Ages will feature vocalist, pianist extraordinaire and tribute artist Jeff Brewer, who has performed internationally to large, sold-out audiences everywhere! This will be a very interactive show, inviting YOU, THE AUDIENCE to sing along to hit after hit to musical anthems that have been the soundtrack to many of our lives!WATCH HERE:  Piano Men\n\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Tribute      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t  \t  \n    \tPerformer Website:\n    \t\n      Visit Website\n    \t\n      \n\t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/the-piano-men/21201ARBBTMBLNJJTVHKLSDDJRJTLMNRD/#event-21201arbbtmblnjjtvhklsddjrjtlmnrd\",\n    \"name\": \"The Piano Men\",\n    \"url\": \"https://imperialtheatre.ca/event/the-piano-men/21201ARBBTMBLNJJTVHKLSDDJRJTLMNRD/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$56.25 // TIME WARP PROMOTIONS PRESENTS THE PIANO MEN – Celebrating the music of Billy Joel and Elton John Get ready for an ultimate concert experience that is out of this world! Together, Billy Joel and Elton John have sold over a billion records worldwide. Join us in a tribute to and celebration of two of the biggest musical superstars on the planet. This full band musical experience with musicians from Rock of Ages will feature vocalist, pianist extraordinaire and tribute artist Jeff Brewer, who has performed internationally to large, sold-out audiences everywhere! This will be a very interactive show, inviting YOU, THE AUDIENCE to sing along to hit after hit to musical anthems that have been the soundtrack to many of our lives!\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/ceb6cd7e-5f15-4555-aeaf-0d326a838b72.jpg\"\n    ],\n    \"startDate\": \"2026-10-17T16:30:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=21201ARBBTMBLNJJTVHKLSDDJRJTLMNRD\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-10-17T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"The Piano Men\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
