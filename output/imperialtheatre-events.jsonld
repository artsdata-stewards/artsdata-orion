    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Retro Film: Napoleon Dynamite"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "$10.00 // Rating: PG | Year: 2004 // In small-town Preston, Idaho, awkward teen Napoleon Dynamite has trouble fitting in. After his grandmother is injured in an accident, his life is made even worse when his strangely nostalgic uncle, Rico, shows up to keep an eye on him. With no safe haven at home or at school, Napoleon befriends the new kid, Pedro, a morose Hispanic boy who speaks little English. Together the two launch a campaign to run for class president."
      }
    ],
