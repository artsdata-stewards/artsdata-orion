    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "From Paris to the Maritimes"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "$35 Regular || $30 Member || From Paris to the Maritimes is a new chamber music collaboration uniting four distinguished artists — pianist Bertrand Giraud, violinist David Adams, cellist Sonja Adams, and composer Martin Kutnowski — in a program that celebrates the meeting of international artistry and New Brunswick creativity. The project proposes a shared presentation by the Imperial Theatre (Saint John), Fredericton Playhouse, and Capitol Theatre (Moncton), connecting audiences across the province through a single artistic experience of excellence and innovation. Each theatre’s concert-quality grand piano will allow Giraud’s artistry to shine at its fullest, while the Adams’ celebrated partnership and Kutnowski’s original composition anchor the program in New Brunswick’s musical identity. The bilingual and cultural fabric of the province finds a natural resonance through Giraud’s French origins and the Adams’ deep roots in the region’s classical tradition."
      }
    ],
