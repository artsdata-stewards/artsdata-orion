        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Tue Jul 14, 2026 • 7:00pm\n\n  \n          Dance\n    \n          Hip Hop\n      \n\n  Event length: 90 minutes\n\n      Admission $10.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Music Video Workshop with Melissa Feltus\n        \n                  \n            Admission $10 ||\nLearn the choreography from Everybody by the Backstreet Boys with Melissa Feltus from First City School of Dance! Dress in your best 90s outfit and join us for this fun workshop. All levels and abilities welcome!\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Dance      \n    \n          \n        Genre: Hip Hop      \n    \n          \n        Event Length: 90 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/music-video-workshop-with-melissa-feltus/46001ANTMSCJPQGDHCBQLMJHRHSLVRCJM/#event-46001antmscjpqgdhcbqlmjhrhslvrcjm\",\n    \"name\": \"Music Video Workshop with Melissa Feltus\",\n    \"url\": \"https://imperialtheatre.ca/event/music-video-workshop-with-melissa-feltus/46001ANTMSCJPQGDHCBQLMJHRHSLVRCJM/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": 