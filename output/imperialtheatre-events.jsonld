        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Sat Oct 17, 2026 • 9:00pm\n\n  \n          Music\n    \n          Tribute\n      \n\n  Event length: 120 minutes\n\n      Admission $35.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Club Rewind: Big Shiny 90s\n        \n                  \n            Advance $35 | Door $40 // BIG SHINY 90s is back by popular demand!  This band recreates those nostalgic and iconic Big Shiny Tunes cds we all had in the past.  Be transported in time as they cover hits from Bush, Collective Soul, Our Lady Peace, Green Day, Creed and so much more! Advance tickets $35.  If not sold out, they will be $40 at the door. Doors open at 8:00PM, the show will begin at 9:00PM.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Tribute      \n    \n          \n        Event Length: 120 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Kent Theatre\n      \n              24 Coburg St, Saint John, NB E2L 3J5\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/club-rewind-big-shiny-90s/25601AQKSSGTVJVSMNNRKRHMGHGVLKJGV/#event-25601aqkssgtvjvsmnnrkrhmghgvlkjgv\",\n    \"name\": \"Club Rewind: Big Shiny 90s\",\n    \"url\": \"https://imperialtheatre.ca/event/club-rewind-big-shiny-90s/25601AQKSSGTVJVSMNNRKRHMGHGVLKJGV/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"Advance $35 | Door $40 // BIG SHINY 90s is back by popular demand! This band recreates those nostalgic and iconic Big Shiny Tunes cds we all had in the past. Be transported in time as they cover hits from Bush, Collective Soul, Our Lady Peace, Green Day, Creed and so much more! Advance tickets $35. If not sold out, they will be $40 at the door. Doors open at 8:00PM, the show will begin at 9:00PM.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/34ccee86-9e74-4a1c-8884-5115c36dcf7f.jpg\"\n    ],\n    \"startDate\": \"2026-10-17T18:00:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=25601AQKSSGTVJVSMNNRKRHMGHGVLKJGV\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2026-10-17T18:00:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Club Rewind: Big Shiny 90s\"\n    }\n}\n\n\n\n\n\t\n\t\t\n