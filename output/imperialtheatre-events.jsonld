    "https://schema.org/text": [
      {
        "@language": "en",
        "@value": "\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Mon Apr 19, 2027 • 7:00pm\n\n  \n          Film\n    \n          Retro Film\n      \n\n  Event length: 174 minutes\n\n      Admission $10.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Retro Film: The Sound of Music\n        \n                  \n            Rating: G | Year: 1965 // A tuneful, heartwarming story, it is based on the real life story of the Von Trapp Family singers, one of the world's best-known concert groups in the era immediately preceding World War II.\n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Film      \n    \n          \n        Genre: Retro Film      \n    \n          \n        Event Length: 174 minutes\n      \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n      \n        \n    \n    \n          \n        Event Sponsor\n        \n                                        \n      \n      \n      \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/retro-film-the-sound-of-music/33001ATHPSRJLTTHKPJHTBJLTTSMCRPQH/#event-33001athpsrjltthkpjhtbjlttsmcrpqh\",\n    \"name\": \"Retro Film: The Sound of Music\",\n    \"url\": \"https://imperialtheatre.ca/event/retro-film-the-sound-of-music/33001ATHPSRJLTTHKPJHTBJLTTSMCRPQH/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"$10.00 // Rating: G | Year: 1965 // A tuneful, heartwarming story, it is based on the real life story of the Von Trapp Family singers, one of the world's best-known concert groups in the era immediately preceding World War II.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/407f0c8f-f592-45ae-8eea-d9b4879f5b14.jpg\"\n    ],\n    \"startDate\": \"2027-04-19T16:00:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=33001ATHPSRJLTTHKPJHTBJLTTSMCRPQH\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-04-19T16:00:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Retro Film: The Sound of Music\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t"
