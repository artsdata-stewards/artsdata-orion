    "http://schema.org/url": [
      {
        "@id": "https://imperialtheatre.ca/event/hells-bells-celebrating-the-music-of-ac-dc/"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Hells Bells: Celebrating the Music of AC/DC"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "TIME WARP PROMOTIONS PRESENTS: HELLS BELLS Since their electrifying inception in 1994 in the heart of Toronto, Hells Bells has soared to become the world’s longest-touring tribute to the legendary AC/DC, lighting up stages across North America with unstoppable passion and excitement. Don’t miss your chance to experience Hells Bells—a tribute that not only honours but revives the spirit of AC/DC. Join us for a night where the music is contagious, and the memories are unforgettable. All Ages! Family friendly! Get ready to rock like never before! https://www.hellsbellscanada.com/ [embed]https://youtu.be/Is8qBXfc2WI[/embed]"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ]
  },
  {
    "@id": "https://imperialtheatre.ca/temporary/42c7efe2-0e99-4488-bd96-2b195be6df43",
    "@type": [
      "http://schema.org/WebSite"
    ],
    "http://schema.org/url": [
      {
        "@id": "https://imperialtheatre.ca"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
