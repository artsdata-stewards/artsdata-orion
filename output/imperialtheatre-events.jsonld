    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Experience the magic of Frozen! Join Anna, Elsa, Olaf, and friends on an electrifying, heart-melting adventure packed with unforgettable songs, dazzling magic, and a celebration of sisterhood that will have you laughing, crying, and cheering all the way to the final note. SJTC Subscriptions onsale now Regular: $143 | Senior: $131 | Student: $79 Single tickets onsale September 1st Performances: Wed, Nov 25 @ 7:30pm Thurs, Nov 26 @ 7:30pm Fri, Nov 27 @ 7:30pm Sat, Nov 28 @ 2pm Sat, Nov 28 @ 7:30pm"
      }
    ],
