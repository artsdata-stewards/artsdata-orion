        "@language": "en",
        "@value": "\n\n\t\t\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tSaint John Comedy Classic 2026\n\t\n\t\n\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Saturday, September 26, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 7:30 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: Early Bird $49 // Standard Admission $59\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Comedy, Stand Up Comedy\n\n\t\n\n\n\n\t\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Saturday, September 26, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 7:30 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: Early Bird $49 // Standard Admission $59\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Comedy, Stand Up Comedy\n\n\t\n\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\tBack by popular demand! Canada’s best comedians return to Saint John. Enjoy the funniest night of the year from your city’s amazing theatre. Audiences can expect to see some of the funniest and most accomplished comedians in our country. – No refunds – No minors\n\n\t\n\n\n\n\t\t\t\n\t\n\n\t\n\t\