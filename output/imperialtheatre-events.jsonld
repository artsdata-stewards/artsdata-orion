    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://imperialtheatre.ca/event/jimmy-rankin-song-dog-25th-anniversary-tour/35801AHSQHGLDRQDGJQNMNBKJMSLGBGCB/"
