        "@language": "en",
        "@value": "\n\n\t\t\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tGreen River Revival: CCR Tribute Concert Experience\n\t\n\t\n\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Saturday, June 20, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 8:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: $49\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Music - Rock, Music - Country, Tribute show\n\n\t\n\n\n\n\t\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\t\t\t\n\t\t\t\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\t\t\n\t\n\t\n\t\t\n\t\tLocation: Imperial Theatre\n\t\n\t\n\n\n\t\n\t\t\n\t\tDate: Saturday, June 20, 2026\n\t\n\t\n\n\n\t\n\t\t\n\t\tShow Starts: 8:00 PM\n\t\n\t\n\n\n\t\n\t\t\n\t\tTickets: $49\n\t\n\t\n\n\n\t\n\t\t\n\tSTYLE OF SHOW: Music - Rock, Music - Country, Tribute show\n\n\t\n\n\n\t\n\t\t\n\t\n\t\t\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tBuy Tickets\n\t\t\t\t\t\n\t\n\n\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tRead More\n\t\t\t\t\t\n\t\n\t\n\n\t\n\n\n\n\t\t\t\t\t\t\n\t\n\t\n\t\t\n\t\n\t\n\n\n\n\t\n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\n\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t\n\t\tBreaking News! CCR Tribute Green River Revival is excited to open the show with a set of the greatest hits of Steppenwolf with Gregg Dechert, keyboardist for Bad Company, Uriah Heep and Pink Floyd’s David Gilmour Band.\n\n\t\n\n\n\n\t\t\t\n\t\n\n\t\n\t\t\n\t\n\n\n\t"
