      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "All aboard the Orient Express for a thrilling, twist-filled ride! When a passenger is found dead, every glamorous traveler becomes a suspect, and only the brilliant Hercule Poirot can untangle the web of secrets. Fast-paced, suspenseful, and full of shocking twists - this murder mystery will keep you guessing until the very last moment. SJTC Subscriptions onsale now Regular: $143 | Senior: $131 | Student: $79 Single tickets onsale September 1st Performances: Wed, Mar 17 @ 7:30pm Thurs, Mar 18 @ 7:30pm Fri, Mar 19 @ 7:30pm Sat, Mar 20 @ 2pm Sat, Mar 20 @ 7:30pm"
      }
    ],
