    "https://schema.org/mainContentOfPage": [
      {
        "@language": "en",
        "@value": "\n\n\t\t\n\n\t\n\t\t\n\t\t\t\n\n\t\t\t\n\t\t\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n          \n        \n      \n    \n\n    Thu May 27, 2027 • 7:30pm\n\n  \n          Music\n    \n          Folk / Alt\n      \n\n\n      Admission $59.00\n    \n      Ticket prices include all taxes and fees.\n    \n  \n\n\n      \n  \n    Buy tickets\n  \n\n  \n  \n  \n  \n\n\n\t\n\t\t\n\t\n\n\n\t\n\t\t\t\t\t\t\n\t\t\n\n\t\t\t\n\t\n\t  \n    \n      \n                  Old Friends: The Songs of Simon & Garfunkel\n        \n                  \n            Admission $59 ||\nExperience the soaring harmonies, beautiful guitar playing and poetic lyrics of one of the most celebrated vocal duos of all time - Simon and Garfunkel! \nRelive the hits like Mrs. Robinson, The Sound of Silence, Homeward Bound, Bridge Over Troubled Water, Me and Julio Down  By the Schoolyard, Kodachrome, Cecilia, and many more!\nAct 1 starts with the origins of Simon and Garfunkel as school friends and their hits as an acoustic duo. \nAct 2 is a stunning recreation of the 1981 concert in Central Park, featuring the full band playing Simon and Garfunkel songs and Paul Simon's solo hits. \nOld Friends is David Skolnick as Paul Simon, Danny Zaldman as Art Garfunkel, John Collin on drums and Abbey Sholzberg on bass. \n          \n        \n              \n\n      \n  \n    Event Info\n\n          \n        Category: Music      \n    \n          \n        Genre: Folk / Alt      \n    \n    \n      \n  \n  \t\t\n\n\n      \n      Venue\n\n              Imperial Theatre\n      \n              12 King Square South, Saint John NB, E2L 5B8\n      \n              \n          \n            View on Google Maps\n          \n        \n          \n  \n  \n\n\n\n{\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Event\",\n    \"@id\": \"https://imperialtheatre.ca/event/old-friends-the-songs-of-simon-garfunkel/45801APJPHDJMJCSGNSRNCNRNHDDTHVGL/#event-45801apjphdjmjcsgnsrncnrnhddthvgl\",\n    \"name\": \"Old Friends: The Songs of Simon & Garfunkel\",\n    \"url\": \"https://imperialtheatre.ca/event/old-friends-the-songs-of-simon-garfunkel/45801APJPHDJMJCSGNSRNCNRNHDDTHVGL/\",\n    \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n    \"eventStatus\": \"https://schema.org/EventScheduled\",\n    \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Imperial Theatre\",\n        \"sameAs\": [\n            \"http://kg.artsdata.ca/resource/K11-193\",\n            \"http://www.wikidata.org/entity/Q3527482\"\n        ],\n        \"address\": {\n            \"@type\": \"PostalAddress\",\n            \"streetAddress\": \"12 King Square South\",\n            \"addressLocality\": \"Saint John\",\n            \"postalCode\": \"E2L 5B8\",\n            \"addressRegion\": \"New Brunswick\",\n            \"addressCountry\": {\n                \"@type\": \"Country\",\n                \"name\": \"CA\"\n            }\n        }\n    },\n    \"organizer\": {\n        \"@type\": \"Organization\",\n        \"name\": \"Imperial Theatre\",\n        \"url\": \"https://imperialtheatre.ca/\"\n    },\n    \"description\": \"Admission $59 || Experience the soaring harmonies, beautiful guitar playing and poetic lyrics of one of the most celebrated vocal duos of all time - Simon and Garfunkel! Relive the hits like Mrs. Robinson, The Sound of Silence, Homeward Bound, Bridge Over Troubled Water, Me and Julio Down By the Schoolyard, Kodachrome, Cecilia, and many more! Act 1 starts with the origins of Simon and Garfunkel as school friends and their hits as an acoustic duo. Act 2 is a stunning recreation of the 1981 concert in Central Park, featuring the full band playing Simon and Garfunkel songs and Paul Simon's solo hits. Old Friends is David Skolnick as Paul Simon, Danny Zaldman as Art Garfunkel, John Collin on drums and Abbey Sholzberg on bass.\",\n    \"image\": [\n        \"https://system.spektrix.com/imperialtheatrenewbrunswick/files/ad3c11cf-30cf-4b69-876a-53b6614dfe34.jpg\"\n    ],\n    \"startDate\": \"2027-05-27T16:30:00-03:00\",\n    \"offers\": {\n        \"@type\": \"Offer\",\n        \"url\": \"https://imperialtheatrenewbrunswick.spektrix.com/imperialtheatrenewbrunswick/website/EventDetails.aspx?EventId=45801APJPHDJMJCSGNSRNCNRNHDDTHVGL\",\n        \"availability\": \"https://schema.org/InStock\",\n        \"validFrom\": \"2027-05-27T16:30:00-03:00\"\n    },\n    \"performer\": {\n        \"@type\": \"Thing\",\n        \"additionalType\": [\n            \"http://dbpedia.org/ontology/Agent\",\n            \"http://xmlns.com/foaf/0.1/Agent\"\n        ],\n        \"name\": \"Old Friends: The Songs of Simon & Garfunkel\"\n    }\n}\n\n\n\n\n\t\n\t\t\n\t\n\n\t\n\t\n\n\n\n\t\t\n\t\n\n\n\n\t"
      }
