  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/1999-the-ultimate-prince-experience/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "1999 - The Ultimate Prince Experience - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The purple revolution is coming to Canada! Experience the music, the magic, and the legacy of Prince in a high-energy, hit-packed live tribute show when 1999 The Ultimate Prince Experience performs."
      }
    ],
    "http://ogp.me/ns#url": [
