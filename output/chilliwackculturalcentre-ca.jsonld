    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Chilliwack Rock Choir - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The Chilliwack Rock Choir is back to crank your favourites up to 11! This isn’t just any choir performance—backed by a live band, they deliver classic rock anthems with the raw energy and excitement of a full-blown rock show. Feel the powerful vocals and infectious rhythms that will have you singing along and dancing in your seat."
      }
    ],
    "http://ogp.me/ns#url": [
      {
