    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Chilliwack Rock Choir"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;The Chilliwack Rock Choir is back to crank your favourites up to 11! This isn’t just any choir performance—backed by a live band, they deliver classic rock anthems with the raw energy and excitement of a full-blown rock show. Feel the powerful vocals and infectious rhythms that will have you singing along and dancing in your seat.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
