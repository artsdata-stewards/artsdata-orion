    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Unnecessary Farce"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;In this riotous, lightning-quick farce, there’s some confusion as to who’s in which room, who’s being videotaped, who has the money, who hired a hitman and why the accountant keeps taking off her clothes.&lt;/p&gt;\\n"
      }
    ],
    "http://schema.org/performer": [
      {
        "@language": "en",
        "@value": "Organization"
      }
    ],
