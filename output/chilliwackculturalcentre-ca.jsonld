  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/colin-james-blues-trio/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Colin James Blues Trio - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
