  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/a-symphony-of-emotion-beethoven-meets-einaudi/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
