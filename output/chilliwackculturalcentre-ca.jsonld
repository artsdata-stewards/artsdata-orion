      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The Rewilders is a visually spectacular short documentary that follows pioneering conservationists on three continents, working to rewild iconic species like jaguar, elephant, bison and salmon."
      }
