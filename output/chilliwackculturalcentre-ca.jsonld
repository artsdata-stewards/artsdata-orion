      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "This phenomenal production tells the story of the most successful musical duo of all time – The Everly Brothers. Featuring hits such as Bye Bye Love, All I Have To Do Is Dream and Cathy’s Clown, this unique concert-based musical entwines the wonderful, sad yet glorious story of The Everly Brothers."
      }
    ],
