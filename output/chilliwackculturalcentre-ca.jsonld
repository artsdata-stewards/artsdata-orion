    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The cast of Middle Aged Boy Band have picked up Canadian Comedy Awards, performed with Second City, and appeared on CBC’s The Debaters, Netflix, and Amazon Prime. Now they’re back together for the funniest reunion tour ever - 100% improvised and 1000% ridiculous."
      }
    ],
