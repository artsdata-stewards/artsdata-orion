    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "ARRIVAL & DREAMS – Ultimate Tributes to ABBA & Fleetwood Mac - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "ARRIVAL & DREAMS – Ultimate Tributes to ABBA & Fleetwood Mac is a world-class performance. Credits include a 5-show run in Las Vegas including Opening for the Original 3 Dog Night, Dominican Republic Shows, Vancouver 2010 Pre-Olympic World Figure Skating Gala, Pacific National Exhibition, NHL Vancouver Canucks, B.C. Lions, along with extensive touring in the USA and Canada! "
      }
    ],
