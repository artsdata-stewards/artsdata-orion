    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Vividus, a dynamic triple bill featuring some of Canada’s finest choreographers. With Simone Orlando’s spirited Rite of Spring and Lesley Telford’s gripping An Instant, this high-energy program is complemented by a breathtaking world premiere by Guillaume Côté."
      }
