    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Celebrate Jackson’s creative genius and unsurpassed talent with riveting live performances covering his early days as a member of the Jackson 5, his groundbreaking theatrics in the 80s and his continued domination of Pop culture into the 21st century."
      }
