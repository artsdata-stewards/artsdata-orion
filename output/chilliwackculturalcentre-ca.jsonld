        "@language": "en-us",
        "@value": "Louisa May Alcott’s Little Women - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Brimming with warmth, wit, and emotional honesty, this radiant production invites audiences to rediscover a beloved classic while celebrating the enduring strength of home, hope, and human connection through a modern, deeply human lens."
      }
    ],
