    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The Liverpool 4 — Canada’s Tribute to The Beatles — has been captivating audiences across North America for nearly 20 years. Whether you're singing along, dancing in the aisles, or just rattling your jewelry — you'll feel the magic of Beatlemania all over again."
      }
