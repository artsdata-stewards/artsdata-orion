    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "A fusion of music from around the world comes to The Chilliwack Cultural Centre with Moneka Arabic Jazz! High-energy rhythms from Iraq and African groove meld with Jazz to create a new, indescribably sensational sound."
      }
    ],
