      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "This powerful showcase features artwork by individuals with lived experience of homelessness, poverty, and addiction, offering a rare opportunity to encounter each artist through their creative expression."
