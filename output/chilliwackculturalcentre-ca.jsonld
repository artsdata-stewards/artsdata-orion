    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Back by popular demand! Chilliwack’s signature pro standup comedy event returns in September.  Enjoy an evening with Canada’s BEST comedians live from your city’s amazing theatre.  Audiences can expect to see FRESH LINEUPS and occasional returning favourites:)Lineup to be announced.  "
      }
