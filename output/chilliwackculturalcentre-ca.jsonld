    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The Chilliwack Metropolitan Orchestra is putting on a Gala fundraiser at the Evergreen Hall next to the Cultural Centre. There will be a full orchestra, dancing to waltzes and polkas, a buffet dinner and a live auction."
      }
