    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "From Storm to Stillness: Great Symphonies in Pocket Size. Bergmann Duo joins Jasper Wood, violin, and Sungyong Lim, cello, in a compelling programme that highlights the vitality and expressive range of “pocket” ensembles. "
      }
