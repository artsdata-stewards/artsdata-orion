  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/ron-james-the-noise-between-our-ears/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Ron James - The Noise Between Our Ears - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
