  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/fleetwood-magic-the-authentic-tribute-to-fleetwood-mac-2/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "FLEETWOOD MAGIC: The Authentic Tribute to Fleetwood Mac - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Fleetwood Magic Tribute Show masterfully transports audiences in sound and time through a musical journey performing Fleetwood Mac’s greatest hits from the 60’s to the 80’s, authentically recreating the sound, style and mystique of Fleetwood Mac’s most iconic line-up."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://www.chilliwackculturalcentre.ca/ccc-event/fleetwood-magic-the-authentic-tribute-to-fleetwood-mac-2/"
      }
    ],
    "http://ogp.me/ns#site_name": [
      {
        "@language": "en-us",
        "@value": "Chilliwack Cultural Centre"
      }
    ],
