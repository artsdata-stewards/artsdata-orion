  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/lisa-brokop-presents-the-patsy-cline-tribute-hank-lives/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
