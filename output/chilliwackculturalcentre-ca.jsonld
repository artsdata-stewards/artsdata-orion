    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "The Legacy of Lightfoot was born out of a deep reverence for the music of Gordon Lightfoot, one of Canada’s most iconic songwriters. This tribute takes audiences on a journey through one of the most profound and prolific catalogs in folk music history."
      }
    ],
