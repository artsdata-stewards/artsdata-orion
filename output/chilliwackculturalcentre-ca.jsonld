        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "THE UNOFFICIAL TRIBUTE SHOW - TAYLOR: A Tribute to the Eras of Taylor Swift - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Calling all Swifties - make a ‘sweet escape’ to the world of Taylor Swift with THE UNOFFICIAL TRIBUTE SHOW - TAYLOR: A Tribute to the Eras of Taylor Swift Music!Showtime presents Josette with international band and dancers in this joyous concert experience, complete with sparkly costumes, cosmic stage production and over 20 of Taylor’s biggest hits performed live."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://www.chilliwackculturalcentre.ca/ccc-event/the-unofficial-tribute-show-taylor-a-tribute-to-the-eras-of-taylor-swift/"
      }
