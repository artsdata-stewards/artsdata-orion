        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Birdy: Hung Dance (Taiwan) - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Birdy is Hung Dance’s exhilarating call to the wild, where creatures of a feather move together and fracture apart. Featuring the Ling Zi headpiece, pheasant tail feathers from traditional Chinese opera symbolizing a warrior’s power, the work conjures a magpie-inspired vision, flashing moments of freedom against the cage of history."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://www.chilliwackculturalcentre.ca/ccc-event/birdy-hung-dance-taiwan/"
      }
    ],
