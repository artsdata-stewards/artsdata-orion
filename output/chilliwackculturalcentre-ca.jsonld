    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "THE UNOFFICIAL TRIBUTE SHOW &#8211; TAYLOR: A Tribute to the Eras of Taylor Swift"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Calling all Swifties - make a ‘sweet escape’ to the world of Taylor Swift with THE UNOFFICIAL TRIBUTE SHOW - TAYLOR: A Tribute to the Eras of Taylor Swift Music!\r\n\r\nShowtime presents Josette with international band and dancers in this joyous concert experience, complete with sparkly costumes, cosmic stage production and over 20 of Taylor’s biggest hits performed live.\r\n"
      }
    ],
