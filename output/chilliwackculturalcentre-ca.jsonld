    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Derek Edwards – Oxy Moron!"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Join Derek for his latest show, Oxy Moron, as it makes its way across Canada. Expect a night of perceptive guesswork and charmingly misguided jabs from a cherished performer. Enjoy some hearty laughs, a sprinkling of wisdom, and the pleasure of mingling with fellow humans. It's a triple win!"
      }
    ],
