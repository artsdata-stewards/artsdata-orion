    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Virtuosic showpieces and romantic ballads, blazing gypsy tunes, and forgotten musical gems—brought vividly to life through dazzling multi instrumental mastery—define Quartetto Gelato, a popular and wonderfully unconventional classical quartet. "
      }
