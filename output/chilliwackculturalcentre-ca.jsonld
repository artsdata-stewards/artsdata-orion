    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Latin Heat Live"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Celebrating the women who changed the sound of Latin music. Featuring the iconic hits of Gloria Estefan, Shakira, Karol G, and Jennifer Lopez, this show shines a spotlight on the voices, rhythms, and stories that helped shape Latin pop across generations."
      }
    ],
