        "@language": "en-us",
        "@value": "PWRUP – AC/DC TRIBUTE - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "PWR/UP is heading to HUB International Theatre to bring you the ultimate AC/DC experience. This is ain't your grandpa's pub band. Our lineup is packed with raw energy and youth, channeling AC/DC in their prime."
      }
    ],
    "http://ogp.me/ns#url": [
