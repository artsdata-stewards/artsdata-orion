      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Experience the many lives of international superstar, Josephine Baker, at this award-winning biographical musical! Cabaret, theatre, and dance retell her story as one of the 20th century’s most revolutionary figures; both on and off the stage as a singer, movie star, WWII spy, civil rights activist, and cultural icon."
      }
    ],
    "http://ogp.me/ns#url": [
