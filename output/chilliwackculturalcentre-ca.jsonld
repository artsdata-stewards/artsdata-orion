  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/the-micheal-jackson-history-show/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "The Micheal Jackson HIStory show - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Celebrate Jackson’s creative genius and unsurpassed talent with riveting live performances covering his early days as a member of the Jackson 5, his groundbreaking theatrics in the 80s and his continued domination of Pop culture into the 21st century."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://www.chilliwackculturalcentre.ca/ccc-event/the-micheal-jackson-history-show/"
