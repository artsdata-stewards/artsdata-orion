    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Celebrate the freedom to read at The Art of Banned Books, a cozy gathering with snacks, coffee, and tea. We’ll explore why banned and challenged books matter, discuss their impact in Canada, and reflect on the role readers play in protecting diverse voices and ideas."
      }
    ],
