  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/the-unofficial-tribute-show-taylor-a-tribute-to-the-eras-of-taylor-swift/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
