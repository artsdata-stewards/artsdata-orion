  {
    "@id": "https://www.chilliwackculturalcentre.ca/ccc-event/monsters-of-rock/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-us",
        "@value": "en_US"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-us",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Monsters of Rock - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "Prepare for a full-throttle night of arena rock as four powerhouse tribute bands hit the stage to deliver the ultimate rock and roll experience."
