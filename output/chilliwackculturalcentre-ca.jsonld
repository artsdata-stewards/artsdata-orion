    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;The Chilliwack Rock Choir is back to crank your favourites up to 11! This isn’t just any choir performance — backed by a live band, they deliver classic rock anthems with the raw energy and excitement of a full-blown rock show.&lt;/p&gt;\\n"
