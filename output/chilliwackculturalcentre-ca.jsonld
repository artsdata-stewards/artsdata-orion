    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "JUNO award winning and OUR LADY PEACE lead vocalist/songwriter RAINE MAIDA together with JUNO and Grammy award winning artist CHANTAL KREVIAZUK provide a night of incredible music from their new album I’M GOING TO BREAK YOUR HEART."
      }
    ],
