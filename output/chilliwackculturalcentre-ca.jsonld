    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Lisa Brokop presents The Patsy Cline Tribute &#038; Hank Lives"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The show featuring Canada's Country Sweetheart Lisa Brokop and Nashville Hit-maker Paul Jefferson.\r\nThe Hank Sr Paul Jeffereson is Lisa's husband who has written a No.1 song for Aaron Tippin and has worked with Georgette Jones George and Tammys daughter. Buddy Jewell and Keith Urban among others. He also did Hank Lives in the Live Stage production in San Jose so we have brought them both together as Lisa Brokop presents The Patsy Cline Tribute and Hank Lives.  \r\n"
      }
    ],
