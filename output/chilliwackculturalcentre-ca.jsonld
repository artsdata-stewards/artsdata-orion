        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "The Music of Hans Zimmer & Others – Live in Concert - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "An unforgettable concert event as a pirate from Pirates of the Caribbean leads you through the iconic scores of Hans Zimmer!"
      }
    ],
    "http://ogp.me/ns#url": [
