        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-us",
        "@value": "Black Dog - The Spirit of Led Zeppelin - Chilliwack Cultural Centre"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "“Black Dog—The Spirit of Led Zeppelin” captures Led Zep's early years in a show that brings to life the essence of Led Zeppelin. From the first crushing riff of Whole Lotta Love to the final echos of Kashmir and Stairway to Heaven, Black Dog delivers an authentic experience with the chemistry and respect the music deserves: raw, electric, and alive."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-us",
        "@value": "https://www.chilliwackculturalcentre.ca/ccc-event/black-dog-the-spirit-of-led-zeppelin/"
      }
