    "http://ogp.me/ns#description": [
      {
        "@language": "en-us",
        "@value": "It's Saturday Night Fever every night with \"The Australian Bee Gees Show - A Tribute to the Bee Gees\". One of the most successful and adored acts in musical history is recreated live in concert. You'll hear hits like, \"Staying Alive\", \"You Should Be Dancing,\" \"How Deep Is Your Love,\" and \"Jive Talkin.”"
      }
    ],
