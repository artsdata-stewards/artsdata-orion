        "@language": "en-ca",
        "@value": "Opening Doors Speaker Series featuring Darren Ng"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Opening Doors speaker series with high school science teacher Darren Ng. A chance to experience “the best science class ever,” followed by a moderated conversation on what it takes to unlock potential on September 17, 7:30 pm at the Vancity Culture Lab."
      }
    ],
    "http://ogp.me/ns#url": [
      {
