    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Here Here: Songs We Sing for Home | Little Chamber Music"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "An evening of song featuring eight Vancouver writers, exploring the meaning of home. The Cultch Historic Theatre | MAR 17–21"
      }
    ],
    "http://ogp.me/ns#url": [
