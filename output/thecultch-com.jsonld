    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Angelo Tsarouchas is back with his new show Diaspora. Come for the jokes, stay for the stories—then call your mother. Vancouver one night ONLY September 12, 2026 at the York Theatre!"
      }
