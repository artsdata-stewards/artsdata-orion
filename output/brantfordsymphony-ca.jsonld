    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "It's the annual Brantford Symphony Christmas extravaganza! Dust off your bells again and bring them along to ring in the Christmas season with a sleigh full of your favourite Christmas-time music. Our special guests this year – Brantford’s <strong>Assumption College Choir</strong>!"
      }
