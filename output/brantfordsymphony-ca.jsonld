        "@language": "en-ca",
        "@value": "A Musical Meandering Through Time (1700-2025) - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A musical meandering through time performed by the Multitaskers Inc."
      },
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra proudly presents A Musical Meandering Through Time (1700- 2025) as performed by Multitaskers Inc.\n\nThe Multitaskers are great friends who juggle busy careers in teaching, engineering, and medicine while keeping music close to their hearts. Between dog training, weaving, and cooking, they still find time to perform beautiful classical and jazz pieces"
      }
    ],
