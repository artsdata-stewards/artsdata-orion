  {
    "@id": "https://brantfordsymphony.ca/event/bach-to-the-future-with-the-platypus-theatre-3/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "en-ca",
        "@value": "en_US"
      },
      {
        "@language": "en-ca",
