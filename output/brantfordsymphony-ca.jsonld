      {
        "@language": "en-ca",
        "@value": "Ring the Christmas Bells! - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra, together with conductor Philip Sarabura, invite you to enjoy an enchanted evening of music and bells on Saturday, Dec 12, 2015, at 7:30 for our annual Christmas show ~ Ring The Christmas Bells."
      },
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra, together with conductor Philip Sarabura, invite you to enjoy an enchanted evening of music and bells on Saturday, Dec 12, 2015, at 7:30 for our annual Christmas show ~ Ring The Christmas Bells.\n\nThis year, the orchestra features 45 professional musicians of the highest calibre and will be joined by the Brantford"
      }
    ],
