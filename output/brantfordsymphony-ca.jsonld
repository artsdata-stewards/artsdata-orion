    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A gala evening of great Italian music\n\nOn the Culture Days weekend, join us for a Serata Incantevole ('Enchanting Evening') of the finest music inspired by Italy. You will be treated to the best from the worlds of opera, stage and popular song, performed by the fabulous Brantford Symphony and two stunning guest artists – the"
      }
