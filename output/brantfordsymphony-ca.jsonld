    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "From the Majesty of Mozart to the Magic of Sinatra - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra proudly presents a special Mother's Day concert on Saturday, May 9 at 7:30pm. Featuring the Royer Ensemble, the program will include beautiful classical, movie and pop favorites."
      },
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra proudly presents a special Mother's Day concert on Saturday, May 9 at 7:30pm. Featuring the Royer Ensemble, the program will include beautiful classical, movie and pop favorites by Wolfgang Amadeus Mozart, Carl Maria Weber, Manuel de Falla, Antonio Vivaldi, John Williams, Nat King Cole, Frank Sinatra and Canadian composer (and mother)"
      }
    ],
