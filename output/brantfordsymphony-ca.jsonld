    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Come watch Brian and Kelly Sloat, ballroom dancers extraordinaire, as they bring to life Salon music from the early 1900's!\n\nFrom the Golden Age of \"light\" classical and popular music comes the Grand Salon Orchestra, performing tunes that everybody knew and loved in the early 1900s. Every grand hotel in the major world cities had its"
      }
    ],
