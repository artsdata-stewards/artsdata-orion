    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Mary Stedman Memorial Family Concert. Bring the whole family for an entertaining Brantford Symphony concert filled with great music."
      },
      {
        "@language": "en-ca",
        "@value": "A Brantford Symphony Tradition Returns!\n\nThe Mary Stedman Memorial\nFamily Concert\nThe Mary Stedman Memorial Family Concert brings the whole family together for an entertaining Brantford Symphony concert filled with great music for all listening tastes. Enjoy music from Mozart and Bach, Disney, and even a trip through the “Stars”. These selections, and much more, are packed"
      }
