    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "An evening of music evoking hope and tenacity in the face of uncertain times, featuring Howard Shore's Symphonic Suite from The Lord of the Rings, and Beethoven's exuberant Second Symphony.\n\nTickets for the BSO 2026-27 season will be available for sale starting July 2, 2026 at the Sanderson Centre box office.\n\nMore details of this concert to"
      }
