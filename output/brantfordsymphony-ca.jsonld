    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Brantford Symphony Orchestra Book Fair Committee\n\n2025 BOOK FAIR\nAPRIL 23, 24, 25, & 26\nSince 1964,\nLargest second-hand book sale in Ontario.\n9:30am-8pm on Wed/Thurs/Fri April 23-25,\nand 9:30am-3pm on Sat. April 26\nOne Market St., Brantford\nGently used\nBooks • Music • Puzzles • Vinyl • CDs & DVDs • Cookery •"
      }
    ],
