    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join the BSO for “His and Hers” with guest conductors Sharon Lee & Marcus Scholtes.\n\nExploring music and relationships through their own distinct artistic lenses, conducting duo Sharon Lee and Marcus Scholtes present a program of complementary works that reflect connection, contrast, and shared inspiration.\n\nAt the heart of the program is the music of Fanny Mendelssohn"
      }
    ],
