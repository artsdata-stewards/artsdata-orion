    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "More great arrangements of your favourite Christmas tunes. More new season gems to be discovered. More terrific soloists from the Orchestra. Bring your bells to the annual Brantford Symphony Christmas variety show! It is sure to get you into a happy mood that will last through the holidays.\n\nBUY TICKETS \n\n2019-20 Season tickets go"
      }
    ],
