    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Award-winning First Nations, Metis, and Inuit artists performing with JUNO Award nominees Sultans of String, WALKING THROUGH THE FIRE is a musical multimedia event unlike any other! From Métis fiddling to an East Coast Kitchen Party, Rumba to Rock, to the drumming of the Pacific Northwest, experience the beauty and diversity of music from Turtle"
      }
    ],
