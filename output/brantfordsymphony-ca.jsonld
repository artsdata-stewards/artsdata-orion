    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "It’s the return of the big, exciting, spectacular Brantford Symphony Christmas Show! Great new seasonal arrangements, a few grand old chestnuts, a full orchestra of virtuoso musicians on stage, and this year we are SO excited to present our special Guests – The Toronto Northern Lights men’s Barbershop Chorus. The TNL has been International Chorus"
      }
