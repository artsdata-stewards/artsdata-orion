    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra proudly presents From Bach to Belafonte as performed by Multitaskers Inc. featuring the talented Saxophone Quartet \"Low Notes, High Hopes\".\n\nOrganized by our own Jennifer Langton, this diverse group features Jackie Chalmers (tenor sax), Jess Wharram (alto sax), Blake Lanbert (alto and soprano sax), Han Schuster (baritone sax), as well as Scott"
      }
