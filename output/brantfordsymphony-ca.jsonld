    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Platypus Theatre’s “How the Gimquat Found Her Song” has sold out over two hundred family shows in \u001eve countries on three continents. It has been seen by over a quarter of a million people, and been made into TV specials by PBS and TVO. Now it’s coming"
      }
