    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Brantford Symphony Orchestra Book Fair Committee\n\n2026 BOOK FAIR\nAPRIL 22, 23, 24, & 25\nSince 1964,\nLargest second-hand book sale in Ontario.\n9:30am-8:00pm on Wed/Thurs/Fri April 22-24,\nand 9:30am-3pm on Sat. April 25\nOne Market St., Brantford\nGently used\nBooks • Music • Puzzles • Vinyl • CDs & DVDs • Cookery •"
      }
    ],
