    "http://ogp.me/ns#type": [
      {
        "@language": "en-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mozart's Concerto with Flute & Harp - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Two of Canada’s premiere soloists – flautist Leslie Newman (also the BSO’s Principal Flute) and harpist Erica Goodman, together perform one of Mozart’s most popular Concertos, in the marvellous sanctuary at St. Andrew’s United Church. Two other works by Mozart, a Cassation, and Symphony #29, will fill out the program, making it a delightful Amadeus evening."
      },
      {
        "@language": "en-ca",
        "@value": "Two of Canada’s premiere soloists – flautist Leslie Newman (also the BSO’s Principal Flute) and harpist Erica Goodman, together perform one of Mozart’s most popular Concertos, in the marvellous sanctuary at St. Andrew’s United Church. Two other works by Mozart, a Cassation, and Symphony #29, will fill out the program, making it a delightful Amadeus"
      }
    ],
