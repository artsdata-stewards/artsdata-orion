    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "We celebrate the music of the famous Bach family with selections written by various members - Carl Philipp Emanuel, Johann Christian, Wilhelm Friedmann, and of course the great Johann Sebastian. This concert is also a farewell to our Maestro Sarabura, retiring after seventeen years on our podium, and to our fabulous Concertmaster, Leslie Dawn Knowles,"
      }
    ],
