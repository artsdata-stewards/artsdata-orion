        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Bach to the Future with The Platypus Theatre - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Young audiences learn the power of creativity and self-empowerment while exploring musical eras and forms. The story weaves from the baroque period to present day, leading the audience in rhythm exercises and some of history’s most beloved symphonic music. Bach to the Future lasts approximately 55 minutes."
      },
      {
        "@language": "en-ca",
        "@value": "The Platypus Theatre returns with another one of their exciting children-oriented shows, \"Bach to the Future\" featuring young Corky.\n\nCorky’s eccentric Uncle Siegfried is the obvious person to help her with her student project on classical music. While poking around in his peculiar workshop, she accidentally combines"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://brantfordsymphony.ca/event/bach-to-the-future-with-the-platypus-theatre-3/"
      }
    ],
