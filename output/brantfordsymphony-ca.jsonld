    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The world’s first global musical \"hit\" the \"Messiah\" has remained in the international Top 40 ever since. The Grand River Chorus and four fabulous soloists join the BSO to bring you this classic. Concert starts at 7:30pm, but we invite you to join the Pre-concert talk from 7:00-7:15pm (doors open at 6:50pm).\n\nPurchase Tickets Online Here"
      }
    ],
