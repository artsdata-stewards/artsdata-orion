    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Music by Bach and his Baroque buddies. Includes a brunch buffet and live music performance by a group of Brantford Symphony Orchestra musicians.\n\nPresented at the Brantford Polish Hall, 154 Pearl Street, Brantford ON.\n\nTickets are $45 and available online at onstagedirect.com/bso."
      }
