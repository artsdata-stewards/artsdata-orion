    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Brantford Symphony Orchestra, Grace Anglican Church and the Anglican Foundation Canada present:\nBaroque Summer: Odin Quartet with Kylie Ho, piano\n\nPROGRAM\nPerforming Bach Keyboard Concerto in D Minor, Vivaldi Summer, and works by Scarlatti and Hasse.\n\nODIN QUARTET\nAlex Toskov, Violin\nTanya Charles, Violin\nMatthew Antal, Viola\nSamuel Bisson, Cello\nKwan Yi (Kylie) Ho, Piano\n\nTickets: $20\nAvailable at the door or by phone"
      }
    ],
