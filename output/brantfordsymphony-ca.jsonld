    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Our Annual Book Fair is taking place April 25-28 at 50 Craig Street, Brantford.\nGently used books, music, puzzles, vinyl, CD’s & DVD’s, cookery, crafts, magazines, children, travel, history.\n\nHours of operation are:\nWednesday-Friday 9:30am-8pm\nSaturday 9:30am-3pm\n\nWe accept cash & cheque payments only.\n\nBooks can be dropped off at 50 Craig Street between 10am-4pm Mon-Sat, March"
      }
    ],
