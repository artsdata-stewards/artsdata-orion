      {
        "@language": "en-ca",
        "@value": "Celebrate Canada! - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for our biennial celebration of fantastic Canadian musical talent. We present three or four exceptional young local artists who will perform solos with the symphony, along with a number of orchestral works by outstanding Canadian composers. Some of the composers will be present to talk about their piece and their craft."
      },
      {
