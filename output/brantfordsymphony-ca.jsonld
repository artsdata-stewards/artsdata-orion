    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "BAROQUE DANCE - LIVE! has been cancelled in response to the challenges presented during the COVID-19 pandemic. Learn more about what the BSO doing here.\n\nThe relationship between music and dance in the Courts of Europe was symbiotic - the steps and gestures of a dance was reflected in the music, and the music influenced"
      }
    ],
