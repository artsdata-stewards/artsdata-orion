    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "On Sunday, Feb 12, 2016, treat your valentine to a trio performance of music by Bach and his Baroque buddies. Includes brunch buffet and live music performance by a group of Brantford Symphony Orchestra musicians."
      },
      {
        "@language": "en-ca",
        "@value": "On Sunday, Feb 12, 2017, treat your valentine to a performance of music by Bach and his Baroque buddies. Includes brunch buffet and live music performance by a group of Brantford Symphony Orchestra musicians.\n\nJohann Sebastian Bach had a musical style that fit in the conventions of his day, emulating Vivaldi in the final stages of"
      }
    ],
