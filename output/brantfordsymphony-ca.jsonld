    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Deck your halls with boughs of holly! Put up the mistletoe! Decorate the Christmas tree! Bake the Christmas cookies! And most important of all, come to the Sanderson on Saturday December 9,to enjoy your favourite holiday music performed live by the fabulous Brantford Symphony! The Christmas show is always the BSO’s most popular concert. If"
      }
