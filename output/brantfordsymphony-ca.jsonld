    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Come visit us at the Brant Performing Arts booth on Canada Day in the Young Canadians Area from 12-6pm. Try out a musical instrument or a costume, find out about upcoming performances, and fill out a ballot to win free concert tickets!\nFor more info about Canada Day: Brantford.ca/CanadaDay\nFor more info about Brant"
      }
