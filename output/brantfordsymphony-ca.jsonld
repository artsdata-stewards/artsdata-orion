    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Spring, Baroque! - Brantford Symphony Orchestra"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "No music says “spring” better than light and lively Baroque music."
      },
      {
        "@language": "en-ca",
        "@value": "Purchase Tickets Online \nSpring, Baroque!\nWith Special Guest oboist Nancy Nelson\nNo music says “spring” better than light and lively Baroque music. Come enjoy an evening of spring-fresh music in the cheerful sanctuary of St. Andrew’s Church with the BSO’s new Principal Oboe and the BSO “Lite” string section.\n\nSpring, Baroque!\nPhilip Sarabura, Conductor\n\nConcerto for Strings, RV 151 \"Alla"
      }
    ],
