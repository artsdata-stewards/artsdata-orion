    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Shane Cook is a master of the Canadian old-time fiddle tradition. The recipient of multiple Grand Champion titles, performing across North America and far abroad, Shane will captivate you with his danceable playing that is as adventurous as it is technically thrilling. Shane is part of a four-member group named \"The Woodchippers\", who rely on"
      }
