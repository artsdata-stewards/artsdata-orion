    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Music by Bach and his Baroque buddies. Includes a brunch buffet and live music performance by a group of Brantford Symphony Orchestra\nmusicians.\n\nTickets are $45 and available online at onstagedirect.com/bso.\n\nClick here to purchase tickets"
      }
