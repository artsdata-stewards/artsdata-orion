    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Grande mobilisation pour les arts au Québec - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "La GMAQ propose une journée de réflexion militante, le 20 septembre au Petit Théâtre afin de mettre un filet social pour les artistes."
      },
      {
        "@language": "fr-ca",
        "@value": "La GMAQ invite à une journée de réflexion militante, le 20 septembre dans plusieurs villes du Québec, donc à Rouyn-Noranda afin de poser ensemble les bases d’un véritable filet social pour les artistes.\n\nCette journée vise deux choses : s’instruire pour développer une pensée critique, et"
      }
    ],
