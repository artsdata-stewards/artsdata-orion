  {
    "@id": "https://petittheatre.org/evenement/soleil-launiere/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Soleil Launière - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "L’artiste innue Soleil Launière vous propose un voyage musical puissant, entre percussions, harmonies vocales et performance artistique."
      },
      {
        "@language": "fr-ca",
        "@value": "Innue originaire de Mashteuiatsh sur les rives du lac Pekuakami, Soleil Launière vit et œuvre à Tiohtià:ke (Montréal). Artiste multidisciplinaire alliant le chant, le mouvement et le théâtre tout en passant par l’art performance, elle entremêle la présence du corps bi-spirituel et l’audiovisuel expérimental tout en s’inspirant de la cosmogonie et l’esprit sacré"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/soleil-launiere/"
      }
    ],
