    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "100 ans de cinéma à Rouyn-Noranda est un projet culturel qui célèbre, tout au long de l’année 2026, le lien unique entre le cinéma et sa population."
      },
      {
        "@language": "fr-ca",
        "@value": "Films présentés:\n\nEntre l'épinette et la licorne /  2010 / Réalisation de Dominic Leclerc / 21m\nSynopsis : Court documentaire de commande d’une vingtaine de minutes présentant les arts et la culture de l'Abitibi-Témiscamingue. \n\nAlex marche à l’amour / 2013 / Réalisation de Dominic"
      }
    ],
