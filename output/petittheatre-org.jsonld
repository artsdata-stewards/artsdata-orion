    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "The Swindlers - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un concert folk où les cultures se rencontrent et se mélangent dans une explosion de sets entraînants et de gigues endiablées."
      },
      {
        "@language": "fr-ca",
        "@value": "En collaboration avec le Festival Trad de Val-d'Or.\n\nNé dans l'obscurité du ventre de la scène des pubs irlandais de Montréal, les Swindlers est un groupe de musiciens folk chevronnés liés par un amour commun de l'improvisation et un mépris partagé pour la convention. Le groupe se spécialise dans la musique folk traditionnelle, mais de quelle"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/the-swindlers/"
      }
