    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "L'IMPROVISATORIUM - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "L’Improvisatorium est un spectacle d’improvisation non traditionnel qui pousse les improvisateur·trice·s de RN et de l’AT à se dépasser."
      },
      {
        "@language": "fr-ca",
        "@value": "L’Improvisatorium est un spectacle d’improvisation non traditionnel qui pousse les improvisateur·trice·s de Rouyn-Noranda et de l’Abitibi-Témiscamingue à se dépasser. Ce concept unique sera orchestré de main de maître par nos deux animateurs, Louis-Jean Lebel et Christian Matte.\n\nDernière édition de l'année en partenarait avec le FHE.\n\nLes scènes, riches en surprises, peuvent inclure"
      }
    ],
