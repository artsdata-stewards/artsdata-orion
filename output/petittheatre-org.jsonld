        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "L'IMPROVISATORIUM - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "L’Improvisatorium est un spectacle d’improvisation non traditionnel qui pousse les improvisateur·trice·s de RN et de l’AT à se dépasser."
      },
      {
        "@language": "fr-ca",
        "@value": "L’Improvisatorium est un spectacle d’improvisation non traditionnel qui pousse les improvisateur·trice·s de Rouyn-Noranda et de l’Abitibi-Témiscamingue à se dépasser. Ce concept unique sera orchestré de main de maître par nos deux animateurs, Louis-Jean Lebel et Christian Matte.\n\nCette nouvelle soirée d’improvisation, organisée en collaboration entre L’Improvisatorium et le Petit Théâtre"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/limprovisatorium-3/"
      }
    ],
