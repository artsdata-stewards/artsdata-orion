    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Une pièce de théâtre à saveur scientifique, suivie d’une conférence interactive, qui mettent en lumière la science!"
      },
      {
        "@language": "fr-ca",
        "@value": "Une pièce de théâtre à saveur scientifique, suivie d’une conférence interactive, qui mettent en lumière la science et nos cerveaux rebelles !\n\n« Alex, 19 ans, étudie au cégep en environnement. Très active sur les réseaux sociaux, elle décortique la méthode scientifique sur sa chaîne Twitch. Mais son travail est remis en"
      }
