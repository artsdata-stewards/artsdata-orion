    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Mahéja - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Mahéja et sa tournée Eau Potable!"
      },
      {
        "@language": "fr-ca",
        "@value": "Mahéja, c’est un concentré de joie de vivre et d’émotions brutes. Originaire de l’Anse-Saint-Jean, elle charme avec ses textes sincères, son charisme naturel et sa bonne humeur contagieuse. Depuis l’enfance, la musique fait partie de sa vie, et aujourd’hui, elle en fait son chemin. Elle prend la vie comme elle vient, avec authenticité"
      }
    ],
