        "@language": "fr-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Chic Shack - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le Petit Théâtre du Vieux Noranda est fier de recevoir le duo de drag queens le plus adoré de la région pour une soirée de Chic Shack!"
      },
      {
        "@language": "fr-ca",
        "@value": "Le Petit Théâtre du Vieux Noranda est extrêmement fier d’accueillir le duo de drag queens le plus adoré de la région : Les Bitches de bois !\n \nPréparez-vous pour une soirée éclatée, haute en couleur et pleinement assumée"
      }
    ],
    "http://ogp.me/ns#url": [
