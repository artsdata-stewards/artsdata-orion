    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Ariane Roy monte sur la scène du Petit Théâtre du Vieux Noranda pour son deuxième album à succès, Dogue."
      },
      {
        "@language": "fr-ca",
        "@value": "Ariane Roy monte sur la scène du Petit Théâtre du vieux Noranda pour vous livrer son deuxième album, Dogue.\n\n Tous s’entendent pour dire qu’Ariane Roy, figure de proue de la désormais célèbre scène de Québec, récipiendaire du prix Révélation de l’année au Gala de l’ADISQ 2022, Révélation Radio-Canada 2021-2022, nommée à deux"
      }
    ],
