    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "La tournée mondiale du Festival du Film de Montagne de Banff au Québec - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Préparez-vous à être ébloui·es par des images spectaculaires d’expéditions à travers des paysages extraordinaires."
      },
      {
        "@language": "fr-ca",
        "@value": "La 29e édition de la Tournée mondiale du Festival du film de montagne de Banff au Québec est de retour ! Le festival met en lumière des courts et moyens métrages créés par des aventuriers audacieux au cœur des de lieux sauvages et isolés. Ces récits captivants mêlent exploits sportifs et histoires humaines,"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/festival-du-film-de-montagne-de-banff/"
      }
