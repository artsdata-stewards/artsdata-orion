    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le Petit Théâtre du Vieux Noranda reçoit l’Espace Court et le Ciné-Muffin du Festival du Cinéma international en Abitibi-Témiscamingue."
      },
      {
        "@language": "fr-ca",
        "@value": "Le Petit Théâtre du Vieux Noranda reçoit l'Espace Court du Festival du Cinéma international en Abitibi-Témiscamingue les 23 et 24 octobre prochains.\n\nEspace Court : 23 ans de courts métrages déjantés \n\nAmateur.trices de films en marge, de thrillers"
      }
