    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "L’Improvisatorium, c’est une expérience où les improvisateur·trice·s de la région repoussent leurs limites."
      },
      {
        "@language": "fr-ca",
        "@value": "L’Improvisatorium, c’est bien plus qu’un spectacle d’improvisation : c’est une expérience non conventionnelle où les improvisateur·trice·s de Rouyn-Noranda et de l’Abitibi-Témiscamingue repoussent leurs limites. Ce concept unique sera orchestré de main de maître par nos deux animateurs, Louis-Jean Lebel et Christian Matte.\nPour l'événement du 25 septembre, nous avons droit"
      }
    ],
