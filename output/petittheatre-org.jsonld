    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "BIEN DANS MA PEAU - ATELIER DE DANSE - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "3 ateliers culturels, pour les 12-17 ans, offrant un parcours autour de l'acceptation à travers la danse, l'écriture, la musique et la lutte."
      },
      {
        "@language": "fr-ca",
        "@value": "Participe à un atelier de danse donné par deux jeunes chorégraphes-interprètes de la relève en danse québécoise : Maïka Giasson et Simik Komaksiutiksak. Nous les accueillons pour la diffusion de leur première pièce respective, le 17 février à 20h, lors de l’événement Futur Danse - Entrez en contact avec le"
      }
    ],
