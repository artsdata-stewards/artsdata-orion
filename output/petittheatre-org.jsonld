        "@value": "Mosaïco"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Flamenco, gigue, danse africaine, latine et urbaine se joignent sur scène pour explorer l’identité plurielle. En trame de fond, une projection numérique texturée et colorée réagit aux mouvements des danseurs, en écho à l'évolution des ancrages identitaires."
      }
    ],
