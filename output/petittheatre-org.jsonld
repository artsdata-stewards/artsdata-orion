  {
    "@id": "https://petittheatre.org/evenement/futur-danse-entrez-en-contact-avec-le-mouvement-de-demain/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Futur danse - Entrez en contact avec le mouvement de demain - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Découvrez les chorégraphes de demain avec deux créations visionnaires qui explorent l’avenir de la danse."
      },
      {
        "@language": "fr-ca",
        "@value": "Le programme double FUTUR DANSE vous invite à découvrir les œuvres d’artistes émergent·e·s et vous entraîne au contact d’une danse surprenante, intrigante et pleine d’avenir. Propulsant de nouvelles créations visionnaires, ambitieuses et généreuses, FUTUR DANSE ouvre une porte sur le renouveau du mouvement et interroge notre époque avec une bonne dose de fougue,"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/futur-danse-entrez-en-contact-avec-le-mouvement-de-demain/"
      }
    ],
    "http://ogp.me/ns#site_name": [
      {
        "@language": "fr-ca",
        "@value": "Le Petit Théatre du Vieux Noranda"
      }
    ],
    "article:publisher": [
      {
        "@language": "fr-ca",
        "@value": "https://www.facebook.com/petittheatreduvieuxnoranda"
      }
    ],
