        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Espace Court - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un festival de courts métrages qui célèbre la créativité cinématographique dans une ambiance cabaret."
      },
      {
        "@language": "fr-ca",
        "@value": "L'Espace court incarne l'essence même de la créativité cinématographique, un endroit où les émotions sont amplifiées, où les talents s'épanouissent, où la programmation est éclatée. Comédie, drame, horreur, films expérimentaux : il y en a pour tous les goûts ! \n\nC'est l'occasion idéale pour célébrer le cinéma entre amis, dans une ambiance cabaret. "
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
