    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "FESTIVAL D'HUMOUR ÉMERGENT EN ABITIBI-TÉMISCAMINGUE - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le Festival d’humour émergent revient du 25 au 28 juin 2025 avec une 5e édition éclatée : plus de 40 artistes et de pigeons mutants."
      },
      {
        "@language": "fr-ca",
        "@value": "Le Festival d’humour émergent revient du 25 au 28 juin 2025 avec une 5e édition follement éclatée : plus de 40 artistes, des shows originaux, des podcasts, des galas, de la drag, de la musique live, de l’impro, des spectacles gratuits et une ambiance printanière pleine de renouveau… et de pigeons mutants."
      }
    ],
