      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Corail et les adhérences, par Solène Bernier - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Une installation qui mêle théâtre, arts visuels et performance pour explorer la résilience humaine et la crise climatique à travers une métaphore visuelle puissante."
      },
      {
        "@language": "fr-ca",
        "@value": "Dans cette installation, qui manie à la fois théâtre, arts visuels et performance, l’artiste explore les limites de la résilience par la métaphore visuelle. Elle donne la voix à 4 femmes, 4 artistes qui unissent leurs expériences, leurs regards et leurs créations. \n\nLes valeurs humanistes et écologiques de Solène Bernier nourrissent ses"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/corail-et-les-adherences-par-solene-bernier/"
      }
    ],
