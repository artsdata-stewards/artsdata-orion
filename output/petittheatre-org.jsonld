  {
    "@id": "https://petittheatre.org/evenement/la-tournee-mondiale-du-festival-du-film-de-montagne-de-banff-au-quebec/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "La tournée mondiale du Festival du Film de Montagne de Banff au Québec - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Préparez-vous à être ébloui·es par des images spectaculaires d’expéditions à travers des paysages extraordinaires."
      },
      {
        "@language": "fr-ca",
        "@value": "50e édition! La Tournée mondiale du Festival du film de montagne de Banff est de retour!\n\nEn janvier et février 2026, la tournée marque 50 ans de pur dépassement. \n\nVibrez devant des images spectaculaires où des hommes et des femmes d’exception poussent souvent leurs exploits à la limite du possible. Une expérience cinématographique"
      }
    ],
