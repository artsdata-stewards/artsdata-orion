    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Le Japon, avec François Ruph - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Découvrez le Japon sous tous ses angles, des mégalopoles aux montagnes sauvages, avec des récits fascinants et des images à couper le souffle."
      },
      {
        "@language": "fr-ca",
        "@value": "Hypermoderne et conservateur. Déjanté et discipliné. Surdéveloppé et traditionaliste. Le Japon fascine par sa multiplicité et ses différents visages. Depuis la levée des restrictions sanitaires, le pays est à la mode et les touristes affluent d’Asie centrale, de Chine, de Corée, de l’Inde, de l’Europe et même du Québec. \n\nDe la mégalopole"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/le-japon-avec-francois-ruph/"
      }
    ],
