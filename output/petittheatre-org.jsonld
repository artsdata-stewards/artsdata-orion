    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Jay Scøtt - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Une soirée où rap, pop et folk se mêlent pour des performances qui touchent le cœur et captivent l’esprit."
      },
      {
        "@language": "fr-ca",
        "@value": "Jay Scøtt est un auteur-compositeur-interprète natif de Terrebonne. Son multitasking musical se décline par l'écriture rap, le chant, le piano, la guitare, le ukulélé (qu’il joue à l’envers) et le beatmaking. Anciennement connu sous le nom de scène PL3, l’artiste est actif sur la scène montréalaise depuis une décennie déjà.   \n\nLa versatilité"
      }
    ],
