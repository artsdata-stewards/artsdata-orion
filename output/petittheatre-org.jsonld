    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Primavera di Noranda - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "20 ans plus tard, rejoignez Marco Calliari et Sylvie Richard pour une soirée italo-festive qui célèbre l’arrivée du printemps dans une ambiance chaleureuse et conviviale."
      },
      {
        "@language": "fr-ca",
        "@value": "20 ans après leur venue au Petit Théâtre du Vieux Noranda, Marco Calliari et Sylvie Richard vous proposent une soirée italo-festive mariant danse et musique. Accompagnés de trois musiciens, ils nous feront célébrer l’arrivée du printemps dans une ambiance de fête familiale italienne. Joignez-vous à nous !\n\nPréparez-vous à danser !"
      }
    ],
    "http://ogp.me/ns#url": [
