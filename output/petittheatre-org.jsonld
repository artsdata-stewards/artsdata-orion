        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Searching for Love de Jerry Tremblay - SOLD OUT - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Jerry Tremblay : Cultivateur de malaises et de bonheur."
      },
      {
        "@language": "fr-ca",
        "@value": "“Un expert du timing réservé, un roi des occasions manquées, un empereur au jeu des attentes déçues, un géant en tant qu'artiste du vélo.” - Leipziger-Volkszeitung, Leipzig\n\nCultivateur de malaise expérimenté mais involontaire, Jerry rayonne par son manque d’habileté sociale et son désir profond d’être aimé. Le spectacle, un cocktail"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/searching-for-love/"
      }
