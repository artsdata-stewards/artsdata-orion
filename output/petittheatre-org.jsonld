  {
    "@id": "https://petittheatre.org/evenement/searching-for-love/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
