    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "ANNULÉ - Les Dauphins et les Licornes - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "En scène, une enfant, des danseurs neurotypiques et d'autres issus de la neurodiversité pour vous présenter les Dauphins et les Licornes."
      },
      {
        "@language": "fr-ca",
        "@value": "Nous sommes contraints d'annuler le spectacle de ce soir en raison de la température. Pour toutes questions, écrivez-nous sur Messenger ou au info@petittheatre.org.\nComme un voyage en Utopie... qui dérape!\nEn scène, une enfant, des danseurs neurotypiques et d'autres issus de la neurodiversité. Ils se partagent le monde en"
      }
    ],
