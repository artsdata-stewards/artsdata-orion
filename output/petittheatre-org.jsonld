    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Mononc' Serge & Anonymus à Rouyn-Norande le 29 mars 2023"
      },
      {
        "@language": "fr-ca",
        "@value": "Mononc' Serge & Anonymus (COMPLET) - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Mononc’ Serge & Anonymus de passage à Rouyn-Noranda pour présenter leur nouvel album, Métal canadien-francais ! Première partie : Abitabyss."
      },
      {
        "@language": "fr-ca",
        "@value": "Mononc’ Serge & Anonymus seront de passage à Rouyn-Noranda pour nous présenter leur nouvel album, Métal canadien-francais !\n\nIls seront accompagnés des joyeux lurons d'Abitabyss.\n\nLa musique est violente, les paroles grafignent, les oreilles silent à la frontière de l’enfer et du Québec profond : y’a pas de doute, l’oncle"
      }
    ],
    "http://ogp.me/ns#url": [
