    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "100 ans de cinéma #2 - Nuit blanche et expérimental - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "100 ans de cinéma #1 - nuit blanche et expérimental"
      },
      {
        "@language": "fr-ca",
        "@value": "Films présentés:\n\nCourts métrages indépendants\nLa charge mental pour les nuls, L’opéra d’Or, Cocotte, Agorus Desiris, Conflit, À l’aveuglette, \n\nCourts métrages du Documenteur et de Les Racamés:\nLes Oubliés, La planète des chats, Abitibi Gold, Ville Nomade, Étoile filante, À chacun sa fortune, Hurtubise, Poisson Smoke, Tricoté le mystère, La crèmerie"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
