    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Jérôme 50 - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "« La plus belle fille du moshpit », « Y’a pu d’poude dans poude » et « Le pauvre riche » : extraits du nouvel album de Jérôme 50 : Anarcolique"
      },
      {
        "@language": "fr-ca",
        "@value": "Jérôme 50 nous présente son troisième album : Anarcolique\n \n\nOriginaire de la ville de Québec, Jérôme 50 débute sa carrière comme musicien de rue. Fort du succès de son premier album La hiérarchill et de son projet Le camp de vacances de Jérôme 49, Jérôme 50 a vu sa chanson « Tokébakicitte »"
      }
    ],
    "http://ogp.me/ns#url": [
