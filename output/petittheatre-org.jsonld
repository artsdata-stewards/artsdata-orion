  {
    "@id": "https://petittheatre.org/evenement/petits-explorateurs-georgie/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Petits Explorateurs - Roadtrip en Géorgie - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Découvrez le voyage en Géorgie de Marie-Hélène Basque et Jacquelin Petit et leurs enfants dans cette soirée des Petits Explorateurs!"
      },
      {
        "@language": "fr-ca",
        "@value": "On se retrouve pour une nouvelle soirée de Petits Explorateurs!\n \n\nÀ la croisée de l’Europe et de l’Asie, encadrée par la mer Noire, et partageant des frontières avec la Russie, l’Arménie, l’Azerbaïdjan et la Turquie ; les montagnes du Caucase de la Géorgie ont su maintenir à travers les siècles leur culture"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/petits-explorateurs-georgie/"
      }
    ],
