    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "JOAT en tournée - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Des battles de street dance endiablées, un DJ set et des performances interactives, ambiance survoltée garantie."
      },
      {
        "@language": "fr-ca",
        "@value": "Les battles de street dance débarquent en ville ! Formule sur la route du Festival international de street dance, JOAT en tournée est un spectacle délirant où les prouesses physiques n’ont d’égal que l’électrisante ambiance de compétition. Interactive, animée et accompagnée par un DJ set en direct, cette enfilade de performances nous tirent de notre"
      }
    ],
