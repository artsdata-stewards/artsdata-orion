    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Le festival de musique émergente est de retour au Petit Théâtre du Vieux Noranda"
      },
      {
        "@language": "fr-ca",
        "@value": "JEUDI\nLes Petites Tounes - 09h45\n\nWe are Wolves x Baby Berserk - 23h30\n\nMary Shelley - 01h30\n\n \nVENDREDI\nLes Breastfeeders x La Flemme - 23h30\n\nPuffer - 01h30\n\n \nSAMEDI\nMoonshine - 23h30\n\nBaby Volcano - 01h30\n\n \nDIMANCHE\nDespised Icon x Scorching Tomb x Digital Ghosts - 20h00\n\nAutomelodi - 00h00"
      }
    ],
