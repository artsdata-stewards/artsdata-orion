  {
    "@id": "https://petittheatre.org/evenement/chic-shack-mai/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
