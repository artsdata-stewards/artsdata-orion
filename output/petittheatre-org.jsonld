    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Laboratoire de création et de recherche sur l'interactivité - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un laboratoire de co-création alliant arts vivants et technologies numériques, où artistes et techno-créatif·ves explorent l’interactivité."
      },
      {
        "@language": "fr-ca",
        "@value": "Pour la 8e année, le laboratoire de création et de recherche sur l’interactivité est de retour au Petit Théâtre. Pour cette édition, une dizaine d’artistes et 7 technocréatif·ves créeront des expérimentations multidisciplinaires interactives dans un processus de co-création.  Inspiré de textes de Les Édition du Quartz abordant les thématiques de L’attachement au"
      }
    ],
