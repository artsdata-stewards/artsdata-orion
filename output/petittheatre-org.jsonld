    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "LES EXILÉES SONT COMME DES LOUVES - GRANDE PREMIÈRE - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "4 femmes immigrantes, de générations différentes, ont pris racines à Rouyn-Noranda. Déchirées entre deux mondes, leur histoire de vie croisée."
      },
      {
        "@language": "fr-ca",
        "@value": "Événement présenté en collaboration avec la Société du 100e de Rouyn-Noranda\n4 femmes immigrantes, de générations différentes, ont pris racines à Rouyn-Noranda. Déchirées entre deux mondes, leur histoire de vie s'entremêle entre moments nostalgiques et sororité. Elles nous offrent, sous la plume et la mise en scène de Lara Kanso, leur histoire"
      }
    ],
    "http://ogp.me/ns#url": [
