    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Lutte à l'Est - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Un tsunami de puissance féministe vous attend dans ce spectacle de lutte pas comme les autres, où les valeurs de feminist killjoys sont à l’honneur."
      },
      {
        "@language": "fr-ca",
        "@value": "Dans les contrées éloignées de l'Est-du-soi-disant-Québec, à 600 miles de la ville colonialement connue sous le nom de Montréal et 600 miles de Gespeg, une gang de chums friandes de tapes su'a yeule ont mis sur pied une ligue de lutte pas comme les autres. Fidèles à leurs valeurs de feminist killjoys, les membres de"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
