    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "Loreim - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Loreim, Rosalie Lemieux de son vrai nom, nous dévoile son premier album au Petit Théâtre!"
      },
      {
        "@language": "fr-ca",
        "@value": "Loreim, ou Rosalie Lemieux de son vrai nom, est une artiste-compositrice-interprète de Rouyn-Noranda.\nPassionnée des mots et de la musique, elle écrit depuis qu'elle est enfant et compose depuis l'adolescence. Lauréate de deux éditions de Secondaire en Spectacle et d'une édition de Cégep en Spectacle, sa chanson Poussière"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/loreim/"
      }
    ],
