  {
    "@id": "https://petittheatre.org/evenement/la-lni-presente-lusine-de-theatre-potentiel/",
    "http://ogp.me/ns#locale": [
      {
        "@language": "fr-ca",
        "@value": "fr_CA"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "fr-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "La LNI présente L’Usine de théâtre potentiel - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Une performance d’improvisation unique où la machine impose tout, et où le public choisit les paramètres du spectacle en temps réel."
      },
      {
        "@language": "fr-ca",
        "@value": "Par le biais d’une plateforme numérique interactive, c’est le public qui choisit les éléments dramaturgiques et scénographiques qui servent de cadre pour la représentation : lumière, musique, thèmes, etc. L’acteur·rice est au cœur de ce spectacle et en développe le contenu, mais ce n’est pas lui ou elle qui en définit les paramètres."
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "fr-ca",
        "@value": "https://petittheatre.org/evenement/la-lni-presente-lusine-de-theatre-potentiel/"
      }
    ],
