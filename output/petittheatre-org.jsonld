    "http://ogp.me/ns#title": [
      {
        "@language": "fr-ca",
        "@value": "BIEN DANS MA PEAU - ATELIER ÉCRITURE ET COMPOSITION MUSICALE - Le Petit Théatre du Vieux Noranda"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr-ca",
        "@value": "Atelier d'écriture créative d'un texte et composition musicale abordant les questions de l'expression de soi pour les 12 à 17 ans."
      },
      {
        "@language": "fr-ca",
        "@value": "Tu as envie d'utiliser une manière plus créative pour faire passer des messages et t'exprimer librement ?  Cet atelier est pour toi ! \n\nLe samedi 12 avril, tu seras accompagné.e par Gabrielle Demers, mère-poète-artiste visuelle multidisciplinaire, pour un atelier d'écriture créative d'un texte collectif abordant les questions de l'affirmation et l'expression de"
      }
    ],
