    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "&lt;p&gt;Saturday, April 11th, 2026 7:30 PM Blueshore Financial Centre for the Performing Arts (North Vancouver) VIM is proud to support this multigenerational, multicultural, multigenre show. Expect Baroque excerpts by Vivaldi, sounds of the East, works by Indigenous composers, and popular favourites showcased through Capilano University\\'s choral ensembles. Featuring daring vocalist Shruti Ramani (Raagaverse), santoor virtuoso [&hellip;]&lt;/p&gt;\\n"
      }
